<div class="container def-bg-settings">
    <div class="row row-cols-1 row-cols-md-1 g-3" style="height: 800px;">
        <div class="col">
            <div>
                <form action="/logoutandchange" method="POST">
                <div class="container py-5" style="padding-top: 8px !important;">
                    <div class="row">
                        <div class="col-12 mb-4">
                            <div class="profile-header position-relative mb-4"></div>
                            <div class="text-center">
                                <div class="position-relative d-inline-block">
                                    <a href="/select_thumbnail"><img src="<%- session.userThumbnail %>" class="rounded-circle profile-pic" alt="Profile Picture"></a>
                                </div>
                            <h3 class="mt-3 mb-1"><%- session.userName %></h3>
                            </div>
                        </div>
                        <div class="col-12">  
                            <div class="col-lg-12">
                                <div class="p-4">
                                    <div class="mb-4">
                                        <h5 class="mb-4">Зови меня</h5>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label class="form-label">Погоняло</label>
                                                <input type="text" class="form-control" name="acc_label_name" value="<%- session.userName %>" style="width: 80%;">
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label">Мыло</label>
                                                <p style="font-size: 22px;"><%- session.userEmail %></p>  
                                            </div>
                                            <div class="col-md-4">
                                                <label class="form-label">Ранг</label>
                                                <p style="font-size: 22px;"><%- session.userRank %></p>  
                                            </div>
                                        </div>
                                    </div>
                                </div>                                        
                            </div>
                        </div>
                    </div>
                </div>
                <div class='d-flex justify-content-end'>
                    <% if (session.userId && session.userRank == "Разработчик") { %>
                        <button type="submit" name="logoutandchange" value="mygame" class="btn ButtonSmBG m-4 ml-auto" style="margin-right: 0 !important;">
                            Мои игры
                        </button>
                    <% } %>  
                    <button type="submit" name="logoutandchange" value="achivements" class="btn ButtonMdBG m-4 ml-auto" style="margin-right: 0 !important;">
                        Достижения
                    </button>
                    <button type="submit" name="logoutandchange" value="update" class="btn ButtonMdBG m-4 ml-auto" style="margin-right: 0 !important;">
                        Применить изменения
                    </button>
                    <button type="submit" name="logoutandchange" value="logout" class="btn ButtonMdBG m-4 ml-auto">
                        Отречься от Ислама
                    </button>
                </div>
                </form>
            </div>
        </div>
    </div>
</div>
