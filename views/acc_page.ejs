<div class="container def-bg-settings">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <!-- Хлебные крошки -->
            <nav aria-label="breadcrumb" class="mb-4 mt-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Главная</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Мой аккаунт</li>
                </ol>
            </nav>

            <!-- Заголовок -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h2 fw-bold">
                    <i class="fas fa-user-circle text-primary me-2"></i>
                    Мой аккаунт
                </h1>
                <% if (session.userRank === 'admin') { %>
                    <span class="badge admin-badge">
                        ADMIN
                    </span>
                <% } %>
            </div>

            <!-- Основной контент -->
            <div class="card border-0 shadow-lg rounded-3">
                <!-- Шапка профиля -->
                <div class="profile-header position-relative" style="height: 200px; margin-bottom: 10px;">
                    <div class="position-absolute w-100 h-100" 
                         style="background: linear-gradient(135deg, var(--primary-color), var(--primary-light)); 
                                border-radius: 12px 12px 0 0;">
                    </div>
                </div>
                
                <!-- Аватар и основная информация -->
                <div class="card-body p-4">
                    <div class="text-center mb-4" style="margin-top: -100px;">
                        <div class="position-relative d-inline-block mb-3">
                            <a href="/select_thumbnail" class="text-decoration-none" title="Изменить аватар">
                                <img src="<%= session.userThumbnail %>" 
                                     class="rounded-circle border border-4 border-white shadow-sm profile-pic" 
                                     alt="Profile Picture"
                                     style="width: 150px; height: 150px; object-fit: cover;">
                                <div class="position-absolute bottom-0 end-0 bg-primary rounded-circle p-2 border border-3 border-white"
                                     style="width: 40px; height: 40px;">
                                    <i class="fas fa-camera text-white" style="font-size: 1rem;"></i>
                                </div>
                            </a>
                        </div>
                        <h2 class="mb-1"><%= session.userName %></h2>
                        <p class="text-muted mb-3">
                            <i class="fas fa-envelope me-1"></i>
                            <%= session.userEmail %>
                        </p>
                        <div class="d-flex justify-content-center gap-2">
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-3 py-2">
                                <i class="fas fa-user me-1"></i>Покупатель
                            </span>
                            <% if (session.userRank === 'admin') { %>
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2">
                                    <i class="fas fa-shield-alt me-1"></i>Администратор
                                </span>
                            <% } %>
                        </div>
                    </div>

                    <form action="/logoutandchange" method="POST" class="needs-validation" novalidate>
                        <!-- Основная информация -->
                        <div class="mb-5">
                            <h5 class="text-primary mb-4 pb-2 border-bottom">
                                <i class="fas fa-info-circle me-2"></i>
                                Личная информация
                            </h5>
                            
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">
                                        <i class="fas fa-user me-1"></i>Псевдоним
                                    </label>
                                    <input type="text" 
                                           class="form-control" 
                                           name="acc_label_name" 
                                           value="<%= session.userName %>"
                                           required
                                           placeholder="Введите ваш псевдоним">
                                    <div class="form-text">Максимум 16 символов</div>
                                </div>
                                
                                <div class="col-md-6">
                                    <label class="form-label fw-semibold">
                                        <i class="fas fa-envelope me-1"></i>Электронная почта
                                    </label>
                                    <input type="email" 
                                           class="form-control" 
                                           value="<%= session.userEmail %>" 
                                           disabled
                                           style="background-color: #f8f9fa;">
                                    <div class="form-text">Email нельзя изменить</div>
                                </div>
                                
                                <div class="col-12">
                                    <div class="alert alert-info border-0 bg-info bg-opacity-10" role="alert">
                                        <div class="d-flex">
                                            <i class="fas fa-info-circle me-3 mt-1 text-info"></i>
                                            <div>
                                                <h6 class="alert-heading mb-1">Смена аватара</h6>
                                                <p class="small mb-0">Чтобы изменить аватар, нажмите на текущее изображение выше или 
                                                    <a href="/select_thumbnail" class="alert-link">перейдите в галерею аватаров</a>.
                                                </p>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Быстрые действия -->
                        <div class="mb-5">
                            <h5 class="text-primary mb-4 pb-2 border-bottom">
                                <i class="fas fa-bolt me-2"></i>
                                Быстрые действия
                            </h5>
                            
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <a href="/favorites" class="text-decoration-none">
                                        <div class="card border-0 shadow-sm h-100 text-center hover-lift">
                                            <div class="card-body py-4">
                                                <div class="mb-3">
                                                    <i class="fas fa-heart fa-2x text-danger"></i>
                                                </div>
                                                <h6 class="mb-1">Избранное</h6>
                                                <p class="text-muted small mb-0">
                                                    <% if (session.favorites && session.favorites.length > 0) { %>
                                                        <%= session.favorites.length %> товар(ов)
                                                    <% } else { %>
                                                        Пока пусто
                                                    <% } %>
                                                </p>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                
                                <div class="col-md-4">
                                    <a href="/cart/<%= session.userId %>" class="text-decoration-none">
                                        <div class="card border-0 shadow-sm h-100 text-center hover-lift">
                                            <div class="card-body py-4">
                                                <div class="mb-3">
                                                    <i class="fas fa-shopping-cart fa-2x text-primary"></i>
                                                </div>
                                                <h6 class="mb-1">Корзина</h6>
                                                <p class="text-muted small mb-0">
                                                    <% if (session.cartCount && session.cartCount > 0) { %>
                                                        <%= session.cartCount %> товар(ов)
                                                    <% } else { %>
                                                        Пока пусто
                                                    <% } %>
                                                </p>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                
                                <div class="col-md-4">
                                    <div class="card border-0 shadow-sm h-100 text-center hover-lift">
                                        <div class="card-body py-4">
                                            <div class="mb-3">
                                                <i class="fas fa-history fa-2x text-secondary"></i>
                                            </div>
                                            <h6 class="mb-1">История заказов</h6>
                                            <p class="text-muted small mb-0">В разработке</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Кнопки действий -->
                        <div class="d-flex justify-content-between pt-4 border-top">
                            <button type="submit" 
                                    name="logoutandchange" 
                                    value="update" 
                                    class="btn btn-primary px-4 py-2">
                                <i class="fas fa-save me-2"></i>Сохранить изменения
                            </button>
                            
                            <button type="submit" 
                                    name="logoutandchange" 
                                    value="logout" 
                                    class="btn btn-outline-danger px-4 py-2">
                                <i class="fas fa-sign-out-alt me-2"></i>Выйти из аккаунта
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Уведомления -->
<div id="notificationContainer" class="mt-4"></div>

<script>
    // Валидация формы
    (function () {
        'use strict'
        
        const forms = document.querySelectorAll('.needs-validation')
        
        Array.from(forms).forEach(function (form) {
            form.addEventListener('submit', function (event) {
                if (!form.checkValidity()) {
                    event.preventDefault()
                    event.stopPropagation()
                }
                
                form.classList.add('was-validated')
            }, false)
        })
    })()
</script>