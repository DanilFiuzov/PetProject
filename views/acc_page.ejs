<!-- Хлебные крошки -->
<nav aria-label="breadcrumb" class="breadcrumb-container">
    <div class="container">
        <ol class="breadcrumb bg-light p-3 rounded-3">
            <li class="breadcrumb-item">
                <a href="/" class="text-decoration-none text-primary">
                    <i class="fas fa-home me-1"></i>Главная
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Мой аккаунт</li>
        </ol>
    </div>
</nav>

<div class="container def-bg-settings py-4">
    <div class="row">
        <!-- Основной контент -->
        <div class="col-12">
            <!-- Заголовок и статус -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h2 fw-bold">
                    <i class="fas fa-user-circle text-primary me-2"></i>
                    Мой аккаунт
                </h1>
                <% if (session.userRank === 'admin') { %>
                    <span class="badge admin-badge" style="
                        background: linear-gradient(45deg, #ff6b6b, #ff8e53) !important;
                        color: white !important;
                        font-size: 0.7rem !important;
                        padding: 0.4rem 0.8rem !important;
                        font-weight: 700 !important;
                        border-radius: 20px !important;
                        animation: pulse 2s infinite !important;
                        box-shadow: 0 4px 10px rgba(255, 107, 107, 0.2);
                    ">
                        <i class="fas fa-shield-alt me-1"></i>ADMIN
                    </span>
                <% } %>
            </div>

            <!-- Основная карточка профиля -->
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden mb-4 no-hover">
                <!-- Верхняя панель с градиентом -->
                <div class="profile-header-bg" style="height: 120px; background: linear-gradient(135deg, var(--primary-color), var(--primary-light));"></div>
                
                <!-- Контент профиля -->
                <div class="card-body p-4 " style="margin-top: -60px;">
                    <!-- Аватар и основная информация -->
                    <div class="text-center mb-5">
                        <div class="position-relative d-inline-block mb-3">
                            <a href="/select_thumbnail" class="text-decoration-none d-inline-block position-relative" title="Изменить аватар">
                                <img src="<%= session.userThumbnail %>" 
                                     class="rounded-circle border border-4 border-white shadow-lg profile-pic" 
                                     alt="Аватар пользователя"
                                     style="width: 120px; height: 120px; object-fit: cover;">
                                <div class="position-absolute" style="
                                    bottom: 0;
                                    right: 0;
                                    background: linear-gradient(135deg, var(--primary-color), var(--primary-light));
                                    width: 36px;
                                    height: 36px;
                                    border-radius: 50%;
                                    border: 3px solid white;
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    box-shadow: 0 2px 5px rgba(0,0,0,0.2);
                                ">
                                    <i class="fas fa-camera text-white" style="font-size: 0.9rem;"></i>
                                </div>
                            </a>
                        </div>
                        
                        <h2 class="h3 fw-bold mb-2"><%= session.userName %></h2>
                        <p class="text-muted mb-3">
                            <i class="fas fa-envelope me-1"></i>
                            <%= session.userEmail %>
                        </p>
                        
                        <div class="d-flex justify-content-center gap-2">
                            <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 px-3 py-2">
                                <i class="fas fa-user me-1"></i>Покупатель
                            </span>
                            <% if (session.userRank === 'admin') { %>
                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2">
                                    <i class="fas fa-shield-alt me-1"></i>Администратор
                                </span>
                            <% } %>
                        </div>
                    </div>

                    <!-- Форма редактирования -->
                    <form action="/logoutandchange" method="POST" class="needs-validation" novalidate>
                        <!-- Личная информация -->
                        <div class="mb-5">
                            <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
                                <div class="icon-circle bg-primary bg-opacity-10 text-primary p-2 rounded-circle me-3">
                                    <i class="fas fa-user"></i>
                                </div>
                                <h5 class="h5 fw-bold mb-0">Личная информация</h5>
                            </div>
                            
                            <div class="row g-4">
                                <div class="col-md-6">
                                    <label class="form-label fw-medium">
                                        <i class="fas fa-user me-1 text-primary"></i>Псевдоним
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="fas fa-user text-muted"></i>
                                        </span>
                                        <input type="text" 
                                               class="form-control border-start-0" 
                                               name="acc_label_name" 
                                               value="<%= session.userName %>"
                                               required
                                               maxlength="16"
                                               placeholder="Введите ваш псевдоним">
                                    </div>
                                    <div class="form-text text-muted small">
                                        <i class="fas fa-info-circle me-1"></i>Максимум 16 символов
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <label class="form-label fw-medium">
                                        <i class="fas fa-envelope me-1 text-primary"></i>Электронная почта
                                    </label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0">
                                            <i class="fas fa-envelope text-muted"></i>
                                        </span>
                                        <input type="email" 
                                               class="form-control border-start-0 bg-light" 
                                               value="<%= session.userEmail %>" 
                                               disabled>
                                    </div>
                                    <div class="form-text text-muted small">
                                        <i class="fas fa-lock me-1"></i>Email нельзя изменить
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Информация об аватаре -->
                            <div class="alert alert-info border-0 bg-primary bg-opacity-10 text-primary mt-4" role="alert">
                                <div class="d-flex align-items-center">
                                    <i class="fas fa-info-circle fa-lg me-3"></i>
                                    <div>
                                        <h6 class="alert-heading mb-1">Смена аватара</h6>
                                        <p class="mb-0 small">Нажмите на аватар выше, чтобы изменить его, или 
                                            <a href="/select_thumbnail" class="alert-link fw-medium">перейдите в галерею аватаров</a>.
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Быстрые действия -->
                        <div class="mb-5">
                            <div class="d-flex align-items-center mb-4 pb-2 border-bottom">
                                <div class="icon-circle bg-primary bg-opacity-10 text-primary p-2 rounded-circle me-3">
                                    <i class="fas fa-bolt"></i>
                                </div>
                                <h5 class="h5 fw-bold mb-0">Быстрые действия</h5>
                            </div>
                            
                            <div class="row g-3">
                                <!-- Избранное -->
                                <div class="col-md-4">
                                    <a href="/favorites" class="text-decoration-none">
                                        <div class="card border-0 shadow-sm h-100 text-center hover-lift transition-all">
                                            <div class="card-body p-4">
                                                <div class="icon-wrapper mb-3">
                                                    <div class="icon-circle bg-danger bg-opacity-10 text-danger p-3 rounded-circle d-inline-flex">
                                                        <i class="fas fa-heart fa-2x"></i>
                                                    </div>
                                                </div>
                                                <h6 class="fw-bold mb-2">Избранное</h6>
                                                <p class="text-muted small mb-0">
                                                    <% if (session.favorites && session.favorites.length > 0) { %>
                                                        <span class="badge bg-danger text-white px-2 py-1">
                                                            <%= session.favorites.length %>
                                                        </span> товар(ов)
                                                    <% } else { %>
                                                        <span class="text-muted">Пока пусто</span>
                                                    <% } %>
                                                </p>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                
                                <!-- Корзина -->
                                <div class="col-md-4">
                                    <a href="/cart/<%= session.userId %>" class="text-decoration-none">
                                        <div class="card border-0 shadow-sm h-100 text-center hover-lift transition-all">
                                            <div class="card-body p-4">
                                                <div class="icon-wrapper mb-3">
                                                    <div class="icon-circle bg-primary bg-opacity-10 text-primary p-3 rounded-circle d-inline-flex">
                                                        <i class="fas fa-shopping-cart fa-2x"></i>
                                                    </div>
                                                </div>
                                                <h6 class="fw-bold mb-2">Корзина</h6>
                                                <p class="text-muted small mb-0">
                                                    <% if (session.cartCount && session.cartCount > 0) { %>
                                                        <span class="badge bg-primary text-white px-2 py-1">
                                                            <%= session.cartCount %>
                                                        </span> товар(ов)
                                                    <% } else { %>
                                                        <span class="text-muted">Пока пусто</span>
                                                    <% } %>
                                                </p>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                                
                                <!-- История заказов -->
                                <div class="col-md-4">
                                    <a href="/my-orders" class="text-decoration-none">
                                        <div class="card border-0 shadow-sm h-100 text-center hover-lift transition-all">
                                            <div class="card-body p-4">
                                                <div class="icon-wrapper mb-3">
                                                    <div class="icon-circle bg-success bg-opacity-10 text-success p-3 rounded-circle d-inline-flex">
                                                        <i class="fas fa-shopping-bag fa-2x"></i>
                                                    </div>
                                                </div>
                                                <h6 class="fw-bold mb-2">Мои заказы</h6>
                                                <p class="text-muted small mb-0">
                                                    <% if (orders && orders.length > 0) { %>
                                                        <span class="badge bg-success text-white px-2 py-1">
                                                            <%= orders.length %>
                                                        </span> заказ(ов)
                                                    <% } else { %>
                                                        <span class="text-muted">Пока нет заказов</span>
                                                    <% } %>
                                                </p>
                                            </div>
                                        </div>
                                    </a>
                                </div>
                            </div>
                        </div>

                        <!-- Кнопки действий -->
                        <div class="border-top pt-4">
                            <div class="d-flex justify-content-between">
                                <button type="submit" 
                                        name="logoutandchange" 
                                        value="update" 
                                        class="btn btn-custom px-4 py-3 fw-medium">
                                    <i class="fas fa-save me-2"></i>Сохранить изменения
                                </button>
                                
                                <button type="submit" 
                                        name="logoutandchange" 
                                        value="logout" 
                                        class="btn btn-outline-custom-danger px-4 py-3 fw-medium">
                                    <i class="fas fa-sign-out-alt me-2"></i>Выйти из аккаунта
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>


<script>
// Валидация формы
(function () {
    'use strict'
    
    const forms = document.querySelectorAll('.needs-validation')
    
    Array.from(forms).forEach(function (form) {
        form.addEventListener('submit', function (event) {
            if (!form.checkValidity()) {
                event.preventDefault()
                event.stopPropagation()
            }
            
            form.classList.add('was-validated')
        }, false)
    })
})()
</script>