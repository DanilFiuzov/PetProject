<!-- Хлебные крошки -->
<nav aria-label="breadcrumb" class="breadcrumb-container">
    <div class="container">
        <ol class="breadcrumb bg-light p-3 rounded-3">
            <li class="breadcrumb-item">
                <a href="/" class="text-decoration-none text-primary">
                    <i class="fas fa-home me-1"></i>Главная
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="/products" class="text-decoration-none text-primary">Каталог</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page"><%= product.productTitle %></li>
        </ol>
    </div>
</nav>

<div class="container def-bg-settings">
    <!-- Скрытые поля -->
    <input type="hidden" id="productId" value="<%= product.productID %>">
    <input type="hidden" id="userId" value="<%= session && session.userId ? session.userId : '' %>">
    <input type="hidden" id="hasReviewed" value="<%= hasReviewed %>">

    <!-- Основная информация -->
    <div class="row g-5">
        <!-- Изображение товара -->
        <div class="col-lg-4">
            <div class="position-relative">
                <div class="product-image-container rounded-4 overflow-hidden shadow-lg mb-4">
                    <img src="/images/products/<%= product.productThumbnail %>" 
                         class="img-fluid w-100" 
                         alt="<%= product.productTitle %>"
                         style="max-height: 500px; object-fit: contain;">
                </div>
                
                <!-- Бейдж скидки -->
                <% if (product.isDiscounted) { %>
                    <div class="position-absolute top-0 start-0 m-4">
                        <div class="discount-badge-modern">
                            <i class="fas fa-bolt"></i>
                            <span>-<%= product.discountPercentage %>%</span>
                        </div>
                    </div>
                <% } %>
                
                <!-- Кнопки действий на изображении -->
                <div class="position-absolute top-0 end-0 m-4 d-flex flex-column gap-2">
                    <% if (session && session.userId) { %>
                        <button class="btn btn-light rounded-circle shadow-lg" 
                                onclick="toggleFavorite(event, '<%= product.productID %>')"
                                title="<%= session.favorites && session.favorites.includes(product.productID) ? 'Убрать из избранного' : 'Добавить в избранное' %>">
                            <i class="<%= session.favorites && session.favorites.includes(product.productID) ? 'fas fa-heart text-danger' : 'far fa-heart' %> fa-lg"></i>
                        </button>
                    <% } %>
                    
                    <% if (session && session.userRank === 'admin') { %>
                        <a href="/admin/edit-product/<%= product.productID %>" 
                           class="btn btn-warning rounded-circle shadow-lg"
                           title="Редактировать товар">
                            <i class="fas fa-edit fa-lg"></i>
                        </a>
                    <% } %>
                </div>
            </div>
        </div>

        <!-- Информация о товаре -->
        <div class="col-lg-8">
            <!-- Основная информация -->
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-body p-4">
                    <!-- Заголовок и категории -->
                    <div class="mb-4">
                        <h1 class="h2 fw-bold mb-3"><%= product.productTitle %></h1>
                        
                        <!-- Категории -->
                        <div class="categories-container mb-4">
                            <% if (product.categories && product.categories.length > 0) { %>
                                <% product.categories.forEach((cat) => { %>
                                    <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 me-2 mb-2 px-3 py-2">
                                        <%= cat %>
                                    </span>
                                <% }) %>
                            <% } %>
                        </div>
                        
                        <!-- Рейтинг и производитель -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="rating me-3" style="cursor: pointer;">
                                <% 
                                    const rating = product.productRating || 0;
                                    for (let j = 0; j < 5; j++) { 
                                %>
                                    <span class="star-wrapper position-relative" style="font-size: 1.5rem;">
                                        <i class="far fa-star text-muted"></i>
                                        <% if (rating > j) { %>
                                            <%
                                                let width = 100;
                                                if (rating - j < 1) {
                                                    width = (rating - j) * 100;
                                                }
                                            %>
                                            <span class="position-absolute top-0 start-0 overflow-hidden" style="width: <%= width %>%">
                                                <i class="fas fa-star text-warning"></i>
                                            </span>
                                        <% } %>
                                    </span>
                                <% } %>
                            </div>
                            <span class="fw-bold text-primary me-3"><%= rating.toFixed(1) %></span>
                            <div class="vr"></div>
                            <div class="ms-3">
                                <span class="text-muted">Производитель:</span>
                                <span class="fw-bold ms-1"><%= product.productManufacturer %></span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Цена -->
                    <div class="mb-5">
                        <% if (product.isDiscounted) { %>
                            <div class="d-flex align-items-center mb-3">
                                <span class="original-price-modern me-4">
                                    <%= parseFloat(product.originalPrice).toFixed(2) %>₽
                                </span>
                                <span class="discount-price-modern">
                                    <%= parseFloat(product.discountedPrice).toFixed(2) %>₽
                                </span>
                            </div>
                            <div class="savings-badge-modern">
                                <i class="fas fa-piggy-bank"></i>
                                Экономия <%= (parseFloat(product.originalPrice) - parseFloat(product.discountedPrice)).toFixed(2) %>₽
                            </div>
                            
                            <% if (product.priceInfo.endDate) { %>
                                <div class="mt-3">
                                    <div id="timer-<%= product.productID %>" 
                                        data-end-date="<%= product.priceInfo.endDate %>"
                                        class="text-danger fw-medium">
                                        <i class="fas fa-clock me-1"></i>
                                        <span class="timer-text">
                                            <!-- Текст будет заменен JavaScript -->
                                            Загрузка...
                                        </span>
                                    </div>
                                </div>
                            <% } %>
                        <% } else { %>
                            <div class="mb-3">
                                <span class="discount-price-modern" style="color: #1f1f1f;">
                                    <%= parseFloat(product.productPrice).toFixed(2) %>₽
                                </span>
                            </div>
                        <% } %>
                    </div>
                    
                    <!-- Кнопки покупки -->
                    <div class="d-grid gap-3">
                        <div class="d-flex gap-2">
                        <% if (session && session.userId) { %>
                            <button class="btn btn-primary btn-lg py-3 fw-bold" 
                                    onclick="addToCart('<%= product.productID %>')">
                                <i class="fas fa-shopping-cart me-2"></i>Добавить в корзину
                            </button>
                        <% } else { %>
                            <a href="/login" class="btn btn-primary btn-lg py-3 fw-bold">
                                <i class="fas fa-sign-in-alt me-2"></i>Войти для покупки
                            </a>
                        <% } %>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-primary flex-grow-1 py-3">
                                <i class="fas fa-share-alt me-2"></i>Поделиться
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Описание и характеристики -->
    <div class="row g-5 mt-3">
        <!-- Описание -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h3 class="h4 fw-bold mb-4">
                        <i class="fas fa-align-left text-primary me-2"></i>Описание товара
                    </h3>
                    <div class="product-description" style="line-height: 1.8;">
                        <%= product.productDescription.replace(/\n/g, '<br>') %>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Характеристики -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h3 class="h4 fw-bold mb-4">
                        <i class="fas fa-list text-primary me-2"></i>Характеристики
                    </h3>
                    
                    <% if (features && features.length > 0) { %>
                        <div class="specifications">
                            <% features.forEach((feature) => { %>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted"><%= feature.key %></span>
                                    <span class="fw-bold text-end"><%= feature.value %></span>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="text-center py-4">
                            <i class="fas fa-info-circle fa-2x text-muted mb-3"></i>
                            <p class="text-muted mb-0">Характеристики не указаны</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Отзывы -->
    <div id="reviews-section" class="mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h3 fw-bold">
                <i class="fas fa-comments text-primary me-2"></i>Отзывы покупателей
            </h2>
            <% if (reviews.length > 0) { %>
                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2">
                    <%= reviews.length %> отзывов
                </span>
            <% } %>
        </div>
        
        <div class="row g-4">
            <!-- Статистика -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <div class="display-4 fw-bold text-primary mb-2">
                                <%= (product.productRating || 0).toFixed(1) %>
                            </div>
                            <div class="rating justify-content-center mb-3">
                                <% for (let j = 0; j < 5; j++) { %>
                                    <span class="star-wrapper position-relative" style="font-size: 1.5rem;">
                                        <i class="far fa-star text-muted"></i>
                                        <% if (overallRating > j) { %>
                                            <%
                                                let width = 100;
                                                if (overallRating - j < 1) {
                                                    width = (overallRating - j) * 100;
                                                }
                                            %>
                                            <span class="position-absolute top-0 start-0 overflow-hidden" style="width: <%= width %>%">
                                                <i class="fas fa-star text-warning"></i>
                                            </span>
                                        <% } %>
                                    </span>
                                <% } %>
                            </div>
                            <p class="text-muted">На основе <%= reviews.length %> отзывов</p>
                        </div>
                        
                        <div class="review-stats">
                            <% [5, 4, 3, 2, 1].forEach((star) => { %>
                                <%
                                    const starStat = reviewStats[star];
                                    const percentage = starStat ? starStat.percentage : 0;
                                    const count = starStat ? starStat.count : 0;
                                %>
                                <div class="d-flex align-items-center mb-2">
                                    <small class="text-muted me-2" style="width: 60px;">
                                        <%= star %> <i class="fas fa-star text-warning"></i>
                                    </small>
                                    <div class="progress flex-grow-1" style="height: 8px;">
                                        <div id="progress-<%= star %>" 
                                             class="progress-bar bg-warning" 
                                             style="width: <%= percentage %>%"></div>
                                    </div>
                                    <small id="count-<%= star %>" 
                                           class="text-muted ms-2" 
                                           style="width: 30px;">
                                        <%= count %>
                                    </small>
                                </div>
                            <% }) %>
                        </div>
                        
                        <% if (session && session.userId) { %>
                            <button id="add-review-btn" 
                                    class="btn btn-primary w-100 mt-4 py-3"
                                    onclick="openReviewModal()"
                                    <%= hasReviewed ? 'disabled' : '' %>>
                                <i class="fas fa-plus me-2"></i>
                                <%= hasReviewed ? 'Вы уже оставили отзыв' : 'Оставить отзыв' %>
                            </button>
                        <% } else { %>
                            <a href="/login" class="btn btn-outline-primary w-100 mt-4 py-3">
                                <i class="fas fa-sign-in-alt me-2"></i>Войти, чтобы оставить отзыв
                            </a>
                        <% } %>
                    </div>
                </div>
            </div>
            
            <!-- Список отзывов -->
            <div class="col-lg-8">
                <div id="reviews-container">
                    <% if (reviews.length === 0) { %>
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body text-center py-5">
                                <i class="far fa-comment-alt fa-4x text-muted mb-3"></i>
                                <h5 class="text-muted mb-3">Пока нет отзывов</h5>
                                <p class="text-muted mb-4">Будьте первым, кто поделится своим мнением об этом товаре</p>
                                <% if (session && session.userId && !hasReviewed) { %>
                                    <button class="btn btn-primary px-4 py-2" onclick="openReviewModal()">
                                        <i class="fas fa-plus me-2"></i>Написать отзыв
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="reviews-list">
                            <% reviews.forEach((review) => { %>
                                <div class="card border-0 shadow-sm rounded-4 mb-3">
                                    <div class="card-body p-4">
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <div class="d-flex align-items-center">
                                                <img src="<%= review.customerThumbnail || '/images/Avatars/default-avatar.png' %>" 
                                                     alt="<%= review.customerName %>" 
                                                     class="rounded-circle me-3" 
                                                     style="width: 60px; height: 60px; object-fit: cover;">
                                                <div>
                                                    <h6 class="mb-1 fw-bold"><%= review.customerName %></h6>
                                                    <small class="text-muted">
                                                        <i class="fas fa-calendar me-1"></i>
                                                        <%= new Date(review.created_at).toLocaleDateString('ru-RU') %>
                                                    </small>
                                                </div>
                                            </div>
                                            <div class="review-star-rating">
                                                <% for (let j = 0; j < 5; j++) { %>
                                                    <% if (review.rating > j) { %>
                                                        <i class="fas fa-star text-warning"></i>
                                                    <% } else { %>
                                                        <i class="far fa-star text-muted"></i>
                                                    <% } %>
                                                <% } %>
                                            </div>
                                        </div>
                                        <p class="mb-0" style="line-height: 1.6;"><%= review.comment %></p>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Модальное окно для отзыва (остается без изменений) -->
    <div class="modal fade" id="reviewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Оставить отзыв</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-4">
                        <label class="form-label fw-medium">Оценка</label>
                        <div class="d-flex mb-2" id="starRating">
                            <% for(let i = 1; i <= 5; i++) { %>
                                <i class="fas fa-star fa-2x text-muted me-1" 
                                   style="cursor: pointer; transition: all 0.2s;"
                                   data-rating="<%= i %>"
                                   onmouseover="hoverStars(<%= i %>)"
                                   onmouseout="resetStars()"
                                   onclick="setRating(<%= i %>)"></i>
                            <% } %>
                        </div>
                        <div id="rating-error" class="form-text text-danger d-none">
                            <i class="fas fa-exclamation-circle me-1"></i>Пожалуйста, выберите оценку
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="reviewComment" class="form-label fw-medium">Ваш отзыв</label>
                        <textarea class="form-control border-2" 
                                  id="reviewComment" 
                                  rows="5" 
                                  placeholder="Расскажите о вашем опыте использования товара..."
                                  style="resize: none;"></textarea>
                        <div id="comment-error" class="form-text text-danger d-none">
                            <i class="fas fa-exclamation-circle me-1"></i>
                            Отзыв должен содержать не менее 10 символов
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary px-4" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-primary px-4" onclick="submitReview()">Отправить отзыв</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
function printPage() {
    window.print();
}
</script>
<script>
// Функция для расчета оставшегося времени
function calculateTimeLeft(endDateStr) {
    if (!endDateStr) return '';
    
    const endDate = new Date(endDateStr);
    const now = new Date();
    const diffMs = endDate - now;
    
    // Если акция уже закончилась
    if (diffMs <= 0) {
        return 'Акция закончилась';
    }
    
    // Рассчитываем дни и часы
    const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
    const diffHours = Math.floor((diffMs % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    
    // Форматируем результат
    if (diffDays > 0) {
        if (diffHours > 0) {
            return `Осталось: ${diffDays} дн. ${diffHours} ч.`;
        } else {
            return `Осталось: ${diffDays} дн.`;
        }
    } else if (diffHours > 0) {
        const diffMinutes = Math.floor((diffMs % (1000 * 60 * 60)) / (1000 * 60));
        if (diffMinutes > 0) {
            return `Осталось: ${diffHours} ч. ${diffMinutes} мин.`;
        } else {
            return `Осталось: ${diffHours} ч.`;
        }
    } else {
        const diffMinutes = Math.floor(diffMs / (1000 * 60));
        return `Осталось: ${diffMinutes} мин.`;
    }
}

// Функция для обновления всех таймеров на странице
function updateAllTimers() {
    const timerElements = document.querySelectorAll('[id^="timer-"]');
    timerElements.forEach(element => {
        const endDate = element.getAttribute('data-end-date');
        if (endDate) {
            const timerText = element.querySelector('.timer-text');
            if (timerText) {
                timerText.textContent = calculateTimeLeft(endDate);
            }
        }
    });
}

// Обновляем таймеры сразу при загрузке страницы
document.addEventListener('DOMContentLoaded', function() {
    updateAllTimers();
    
    // Обновляем таймер каждую минуту
    setInterval(updateAllTimers, 60000); // 60000 мс = 1 минута

    const ratingElement = document.querySelector('.rating.me-3');
    if (ratingElement) {
        ratingElement.addEventListener('click', function(event) {
            const reviewsSection = document.getElementById('reviews-section');
            if (reviewsSection) {
                event.preventDefault();
                reviewsSection.scrollIntoView({ behavior: 'smooth' });
            }
        });
    }
});
</script>