<!-- Хлебные крошки -->
<nav aria-label="breadcrumb" class="breadcrumb-container">
    <div class="container">
        <ol class="breadcrumb bg-light p-3 rounded-3">
            <li class="breadcrumb-item">
                <a href="/" class="text-decoration-none text-primary">
                    <i class="fas fa-home me-1"></i>Главная
                </a>
            </li>
            <li class="breadcrumb-item">
                <a href="/products" class="text-decoration-none text-primary">Каталог</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page"><%= product.productTitle %></li>
        </ol>
    </div>
</nav>

<div class="container def-bg-settings">
    <!-- Скрытые поля -->
    <input type="hidden" id="productId" value="<%= product.productID %>">
    <input type="hidden" id="userId" value="<%= session && session.userId ? session.userId : '' %>">
    <input type="hidden" id="hasReviewed" value="<%= hasReviewed %>">

    <!-- Основная информация -->
    <div class="row g-5">
        <!-- Изображение товара -->
        <div class="col-lg-5">
            <div class="d-flex gap-2">
                <!-- Вертикальные миниатюры слева (если изображений > 1) -->
                <% if (product.images && product.images.length > 1) { %>
                <div class="product-thumbnails-vertical d-flex flex-column gap-2 overflow-auto" style="max-height: 500px;">
                    <% product.images.forEach((img, idx) => { %>
                        <div class="product-thumbnail-item <%= idx === 0 ? 'active' : '' %>" data-index="<%= idx %>" onclick="setMainImage(<%= idx %>)">
                            <img src="/images/products/<%= img.imageUrl %>" alt="<%= product.productTitle %>" class="img-fluid rounded-2" style="width: 70px; height: 70px; object-fit: cover; cursor: pointer;">
                        </div>
                    <% }); %>
                </div>
                <% } %>

                <!-- Главное изображение с бейджами -->
                <div class="flex-grow-1 position-relative">
                    <!-- Обертка для зума -->
                    <div class="position-relative" style="cursor: zoom-in;" onclick="openGalleryModal(currentImageIndex)">
                        <img id="mainProductImage" 
                             src="/images/products/<%= product.images && product.images.length > 0 ? product.images[0].imageUrl : product.productThumbnail %>" 
                             class="img-fluid w-100 rounded-4 shadow" 
                             alt="<%= product.productTitle %>" 
                             style="max-height: 500px; object-fit: contain; background: #f8f9fa;">
                        <!-- Иконка лупы -->
                        <div class="image-zoom-icon position-absolute top-50 start-50 translate-middle rounded-circle bg-dark bg-opacity-50 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px; opacity: 0; transition: opacity 0.3s;">
                            <i class="fas fa-search-plus fa-2x text-white"></i>
                        </div>
                    </div>

                    <!-- Бейдж скидки -->
                    <% if (product.isDiscounted) { %>
                        <div class="position-absolute top-0 start-0 m-4" style="z-index:2;">
                            <div class="discount-badge-modern">
                                <i class="fas fa-bolt"></i>
                                <span>-<%= product.discountPercentage %>%</span>
                            </div>
                        </div>
                    <% } %>

                    <!-- Бейдж "Нет в наличии" -->
                    <% if (product.stock_quantity <= 0) { %>
                        <div class="position-absolute top-0 start-0 w-100 h-100 d-flex align-items-center justify-content-center" style="z-index:2;">
                            <div class="out-of-stock-badge">SOLD</div>
                        </div>
                    <% } %>

                    <!-- Кнопки действий -->
                    <div class="position-absolute top-0 end-0 m-4 d-flex flex-column gap-2" style="z-index:2;">
                        <% if (session && session.userId) { %>
                            <button class="btn btn-light rounded-circle shadow-lg" style="height: 48px;"
                                    onclick="toggleFavorite(event, '<%= product.productID %>')"
                                    title="<%= session.favorites && session.favorites.includes(product.productID) ? 'Убрать из избранного' : 'Добавить в избранное' %>">
                                <i class="<%= session.favorites && session.favorites.includes(product.productID) ? 'fas fa-heart text-danger' : 'far fa-heart' %> fa-lg"></i>
                            </button>
                        <% } %>
                        <% if (session && session.userRank === 'admin') { %>
                            <a href="/admin/edit-product/<%= product.productID %>" 
                               class="btn btn-custom-warning rounded-circle shadow-lg"
                               title="Редактировать товар">
                                <i class="fas fa-edit fa-lg"></i>
                            </a>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Информация о товаре -->
        <div class="col-lg-7">
            <!-- Основная информация -->
            <div class="card border-0 shadow-sm rounded-4 mb-4 no-hover">
                <div class="card-body p-4">
                    <!-- Заголовок и категории -->
                    <div class="mb-4">
                        <h1 class="h2 fw-bold mb-3"><%= product.productTitle %></h1>
                        
                        <!-- Категории -->
                        <div class="categories-container mb-4">
                            <% if (product.categories && product.categories.length > 0) { %>
                                <% product.categories.forEach((cat) => { %>
                                    <span class="cat-badge me-2 mb-2">
                                        <% if (cat.icon) { %>
                                            <img src="<%= cat.icon %>" alt="" class="cat-badge-icon">
                                        <% } %>
                                        <span class="cat-badge-text"><%= cat.name %></span>
                                    </span>
                                <% }) %>
                            <% } %>
                        </div>
                        
                        <!-- Рейтинг и производитель -->
                        <div class="d-flex align-items-center mb-4">
                            <div class="rating me-3" style="cursor: pointer;">
                                <% 
                                    const rating = product.productRating || 0;
                                    for (let j = 0; j < 5; j++) { 
                                %>
                                    <span class="star-wrapper position-relative" style="font-size: 1.5rem;">
                                        <i class="far fa-star text-muted"></i>
                                        <% if (rating > j) { %>
                                            <%
                                                let width = 100;
                                                if (rating - j < 1) {
                                                    width = (rating - j) * 100;
                                                }
                                            %>
                                            <span class="position-absolute top-0 start-0 overflow-hidden" style="width: <%= width %>%">
                                                <i class="fas fa-star text-warning"></i>
                                            </span>
                                        <% } %>
                                    </span>
                                <% } %>
                            </div>
                            <span class="fw-bold text-primary me-3"><%= rating.toFixed(1) %></span>
                            <div class="vr"></div>
                            <div class="ms-3">
                                <span class="text-muted">Производитель:</span>
                                <span class="fw-bold ms-1"><%= product.productManufacturer %></span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Цена и наличие -->
                    <div class="mb-5">
                        <!-- Цена -->
                        <% if (product.isDiscounted) { %>
                            <div class="d-flex align-items-center mb-3">
                                <span class="original-price-modern me-4">
                                    <%= parseFloat(product.originalPrice).toFixed(2) %>₽
                                </span>
                                <span class="discount-price-modern">
                                    <%= parseFloat(product.discountedPrice).toFixed(2) %>₽
                                </span>
                            </div>
                            <div class="savings-badge-modern">
                                <i class="fas fa-piggy-bank"></i>
                                Экономия <%= (parseFloat(product.originalPrice) - parseFloat(product.discountedPrice)).toFixed(2) %>₽
                            </div>
                            
                            <% if (product.priceInfo.endDate) { %>
                                <div class="mt-3">
                                    <div id="timer-<%= product.productID %>" 
                                        data-end-date="<%= product.priceInfo.endDate %>"
                                        class="text-danger fw-medium">
                                        <i class="fas fa-clock me-1"></i>
                                        <span class="timer-text">
                                            Загрузка...
                                        </span>
                                    </div>
                                </div>
                            <% } %>
                        <% } else { %>
                            <div class="mb-3">
                                <span class="discount-price-modern" style="color: #1f1f1f;">
                                    <%= parseFloat(product.productPrice).toFixed(2) %>₽
                                </span>
                            </div>
                        <% } %>
                        
                        <!-- Индикатор наличия -->
                        <div class="mt-4">
                            <% if (product.stock_quantity <= 0) { %>
                                <div class="stock-indicator text-danger d-flex align-items-center">
                                    <i class="fas fa-times-circle me-2"></i>
                                    <span class="fw-bold">Нет в наличии</span>
                                </div>
                            <% } else if (product.stock_quantity <= 5) { %>
                                <div class="stock-indicator text-warning d-flex align-items-center">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    <span class="fw-bold">Только <%= product.stock_quantity %> шт. в наличии</span>
                                </div>
                            <% } else { %>
                                <div class="stock-indicator text-success d-flex align-items-center">
                                    <i class="fas fa-check-circle me-2"></i>
                                    <span class="fw-bold">В наличии: <%= product.stock_quantity %> шт.</span>
                                </div>
                            <% } %>
                        </div>
                    </div>
                    
                    <!-- Кнопки покупки -->
                    <div class="d-grid gap-3">
                        <div class="d-flex gap-2">
                            <% if (product.stock_quantity <= 0) { %>
                                <!-- Товара нет в наличии -->
                                <button class="btn btn-outline-secondary btn-lg py-3 fw-bold" disabled>
                                    <i class="fas fa-times me-2"></i>Нет в наличии
                                </button>
                            <% } else if (session && session.userId) { %>
                                <!-- Товар в наличии, пользователь авторизован -->
                                <button class="btn btn-custom btn-lg py-3 fw-bold" 
                                        onclick="addToCart('<%= product.productID %>')"
                                        data-product-id="<%= product.productID %>"
                                        data-stock-quantity="<%= product.stock_quantity %>">
                                    <i class="fas fa-shopping-cart me-2"></i>Добавить в корзину
                                </button>
                            <% } else { %>
                                <!-- Товар в наличии, пользователь не авторизован -->
                                <a href="/login" class="btn btn-custom btn-lg py-3 fw-bold">
                                    <i class="fas fa-sign-in-alt me-2"></i>Войти для покупки
                                </a>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Описание и характеристики -->
    <div class="row g-5 mt-3">
        <!-- Описание -->
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h3 class="h4 fw-bold mb-4">
                        <i class="fas fa-align-left text-primary me-2"></i>Описание товара
                    </h3>
                    <div class="product-description" style="line-height: 1.8;">
                        <%= product.productDescription %>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Характеристики -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-body p-4">
                    <h3 class="h4 fw-bold mb-4">
                        <i class="fas fa-list text-primary me-2"></i>Характеристики
                    </h3>
                    
                    <% if (features && features.length > 0) { %>
                        <div class="specifications">
                            <% features.forEach((feature) => { %>
                                <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                                    <span class="text-muted"><%= feature.key %></span>
                                    <span class="fw-bold text-end"><%= feature.value %></span>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="text-center py-4">
                            <i class="fas fa-info-circle fa-2x text-muted mb-3"></i>
                            <p class="text-muted mb-0">Характеристики не указаны</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Модальное окно галереи изображений -->
    <div class="modal fade" id="imageGalleryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-xl modal-dialog-centered">
            <div class="modal-content border-0 bg-dark rounded-4 overflow-hidden">
                <div class="modal-header border-0 p-3">
                    <h5 class="modal-title text-white"><%= product.productTitle %></h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body p-0 position-relative">
                    <!-- Карусель Bootstrap -->
                    <div id="galleryCarousel" class="carousel slide">
                        <div class="carousel-inner">
                            <% product.images.forEach((img, idx) => { %>
                                <div class="carousel-item <%= idx === 0 ? 'active' : '' %>">
                                    <img src="/images/products/<%= img.imageUrl %>" class="d-block w-100" alt="<%= product.productTitle %>" style="max-height: 70vh; object-fit: contain; background: #f4f4f4;">
                                </div>
                            <% }); %>
                        </div>
                        <!-- Кнопки навигации -->
                        <button class="carousel-control-prev" type="button" data-bs-target="#galleryCarousel" data-bs-slide="prev">
                            <span class="carousel-control-prev-icon bg-dark bg-opacity-50 rounded-circle p-4" aria-hidden="true"></span>
                            <span class="visually-hidden">Предыдущее</span>
                        </button>
                        <button class="carousel-control-next" type="button" data-bs-target="#galleryCarousel" data-bs-slide="next">
                            <span class="carousel-control-next-icon bg-dark bg-opacity-50 rounded-circle p-4" aria-hidden="true"></span>
                            <span class="visually-hidden">Следующее</span>
                        </button>
                    </div>

                    <!-- Миниатюры-индикаторы снизу -->
                    <% if (product.images && product.images.length > 1) { %>
                    <div class="d-flex justify-content-center gap-2 p-3 bg-dark bg-opacity-75">
                        <% product.images.forEach((img, idx) => { %>
                            <div class="gallery-thumbnail <%= idx === 0 ? 'active' : '' %>" data-slide-to="<%= idx %>" onclick="goToSlide(<%= idx %>)">
                                <img src="/images/products/<%= img.imageUrl %>" class="rounded-2" style="width: 60px; height: 60px; object-fit: cover; border: 2px solid <%= idx === 0 ? '#fff' : 'transparent' %>; cursor: pointer;">
                            </div>
                        <% }); %>
                    </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Отзывы -->
    <div id="reviews-section" class="mt-5">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="h3 fw-bold">
                <i class="fas fa-comments text-primary me-2"></i>Отзывы покупателей
            </h2>
            <% if (reviews.length > 0) { %>
                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2">
                    <%= reviews.length %> отзывов
                </span>
            <% } %>
        </div>
        
        <div class="row g-4">
            <!-- Статистика -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 h-100">
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <div class="display-4 fw-bold text-primary mb-2">
                                <%= (product.productRating || 0).toFixed(1) %>
                            </div>
                            <div class="rating justify-content-center mb-3">
                                <% for (let j = 0; j < 5; j++) { %>
                                    <span class="star-wrapper position-relative" style="font-size: 1.5rem;">
                                        <i class="far fa-star text-muted"></i>
                                        <% if (overallRating > j) { %>
                                            <%
                                                let width = 100;
                                                if (overallRating - j < 1) {
                                                    width = (overallRating - j) * 100;
                                                }
                                            %>
                                            <span class="position-absolute top-0 start-0 overflow-hidden" style="width: <%= width %>%">
                                                <i class="fas fa-star text-warning"></i>
                                            </span>
                                        <% } %>
                                    </span>
                                <% } %>
                            </div>
                            <p class="text-muted">На основе <%= reviews.length %> отзывов</p>
                        </div>
                        
                        <div class="review-stats">
                            <% [5, 4, 3, 2, 1].forEach((star) => { %>
                                <%
                                    const starStat = reviewStats[star];
                                    const percentage = starStat ? starStat.percentage : 0;
                                    const count = starStat ? starStat.count : 0;
                                %>
                                <div class="d-flex align-items-center mb-2">
                                    <small class="text-muted me-2" style="width: 60px;">
                                        <%= star %> <i class="fas fa-star text-warning"></i>
                                    </small>
                                    <div class="progress flex-grow-1" style="height: 8px;">
                                        <div id="progress-<%= star %>" 
                                             class="progress-bar bg-warning" 
                                             style="width: <%= percentage %>%"></div>
                                    </div>
                                    <small id="count-<%= star %>" 
                                           class="text-muted ms-2" 
                                           style="width: 30px;">
                                        <%= count %>
                                    </small>
                                </div>
                            <% }) %>
                        </div>
                        
                    <!-- Кнопка отзыва -->
                    <% if (session && session.userId) { %>
                        <button id="add-review-btn" 
                                class="btn btn-custom w-100 mt-4 py-3"
                                onclick="openReviewModal()"
                                <%= hasReviewed ? 'disabled' : '' %>>
                            <i class="fas fa-plus me-2"></i>
                            <%= hasReviewed ? 'Вы уже оставили отзыв' : 'Оставить отзыв' %>
                        </button>
                    <% } else { %>
                        <a href="/login" class="btn btn-outline-custom w-100 mt-4 py-3">
                            <i class="fas fa-sign-in-alt me-2"></i>Войти, чтобы оставить отзыв
                        </a>
                    <% } %>
                    </div>
                </div>
            </div>
            
            <!-- Список отзывов -->
            <div class="col-lg-8">
                <div id="reviews-container">
                    <% if (reviews.length === 0) { %>
                        <div class="card border-0 shadow-sm rounded-4">
                            <div class="card-body text-center py-5">
                                <i class="far fa-comment-alt fa-4x text-muted mb-3"></i>
                                <h5 class="text-muted mb-3">Пока нет отзывов</h5>
                                <p class="text-muted mb-4">Будьте первым, кто поделится своим мнением об этом товаре</p>
                                <!-- Кнопка "Написать отзыв" в пустом блоке отзывов -->
                                <% if (session && session.userId && !hasReviewed) { %>
                                    <button class="btn btn-custom px-4 py-2" onclick="openReviewModal()">
                                        <i class="fas fa-plus me-2"></i>Написать отзыв
                                    </button>
                                <% } %>
                            </div>
                        </div>
                    <% } else { %>
                        <div class="reviews-list">
                            <% reviews.forEach((review) => { %>
                                <div class="card border-0 shadow-sm rounded-4 mb-3">
                                    <div class="card-body p-4">
                                        <div class="d-flex justify-content-between align-items-start mb-3">
                                            <div class="d-flex align-items-center">
                                                <img src="<%= review.customerThumbnail || '/images/Avatars/default-avatar.png' %>" 
                                                     alt="<%= review.customerName %>" 
                                                     class="rounded-circle me-3" 
                                                     style="width: 60px; height: 60px; object-fit: cover;">
                                                <div>
                                                    <h6 class="mb-1 fw-bold"><%= review.customerName %></h6>
                                                    <small class="text-muted">
                                                        <i class="fas fa-calendar me-1"></i>
                                                        <%= new Date(review.created_at).toLocaleDateString('ru-RU') %>
                                                    </small>
                                                </div>
                                            </div>
                                            <div class="review-star-rating">
                                                <% for (let j = 0; j < 5; j++) { %>
                                                    <% if (review.rating > j) { %>
                                                        <i class="fas fa-star text-warning"></i>
                                                    <% } else { %>
                                                        <i class="far fa-star text-muted"></i>
                                                    <% } %>
                                                <% } %>
                                            </div>
                                        </div>
                                        <p class="mb-0" style="line-height: 1.6;"><%= review.comment %></p>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <!-- Модальное окно для отзыва -->
    <div class="modal fade" id="reviewModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Оставить отзыв</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-4">
                        <label class="form-label fw-medium">Оценка</label>
                        <div class="d-flex mb-2" id="starRating">
                            <% for(let i = 1; i <= 5; i++) { %>
                                <i class="fas fa-star fa-2x text-muted me-1" 
                                   style="cursor: pointer; transition: all 0.2s;"
                                   data-rating="<%= i %>"
                                   onmouseover="hoverStars(<%= i %>)"
                                   onmouseout="resetStars()"
                                   onclick="setRating(<%= i %>)"></i>
                            <% } %>
                        </div>
                        <div id="rating-error" class="form-text text-danger d-none">
                            <i class="fas fa-exclamation-circle me-1"></i>Пожалуйста, выберите оценку
                        </div>
                    </div>
                    
                    <div class="mb-3">
                        <label for="reviewComment" class="form-label fw-medium">Ваш отзыв</label>
                        <textarea class="form-control border-2" 
                                  id="reviewComment" 
                                  rows="5" 
                                  placeholder="Расскажите о вашем опыте использования товара..."
                                  style="resize: none;"></textarea>
                        <div id="comment-error" class="form-text text-danger d-none">
                            <i class="fas fa-exclamation-circle me-1"></i>
                            Отзыв должен содержать не менее 10 символов
                        </div>
                    </div>
                </div>
                <!-- Кнопки в модальном окне -->
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-custom px-4" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn btn-custom px-4" onclick="submitReview()">Отправить отзыв</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
// ========================================
// ФУНКЦИИ ДЛЯ СТРАНИЦЫ ТОВАРА
// ========================================

let currentRating = 0;
let currentImageIndex = 0;
const productImages = <%- JSON.stringify(product.images) %>;

// ------------------------- Звёзды рейтинга -------------------------
function hoverStars(rating) {
    document.querySelectorAll('#starRating .fa-star').forEach((star, index) => {
        star.classList.toggle('text-warning', index < rating);
        star.classList.toggle('text-muted', index >= rating);
    });
}

function resetStars() {
    document.querySelectorAll('#starRating .fa-star').forEach((star, index) => {
        star.classList.toggle('text-warning', index < currentRating);
        star.classList.toggle('text-muted', index >= currentRating);
    });
}

function setRating(rating) {
    currentRating = rating;
    resetStars();
}

// ------------------------- Модальное окно отзыва -------------------------
function openReviewModal() {
    currentRating = 0;
    document.getElementById('reviewComment').value = '';
    document.querySelectorAll('#starRating .fa-star').forEach(s => { s.classList.remove('text-warning'); s.classList.add('text-muted'); });
    document.getElementById('rating-error').classList.add('d-none');
    document.getElementById('comment-error').classList.add('d-none');
    bootstrap.Modal.getOrCreateInstance(document.getElementById('reviewModal')).show();
}

function submitReview() {
    const comment = document.getElementById('reviewComment').value.trim();
    let isValid = true;
    if (currentRating === 0) { document.getElementById('rating-error').classList.remove('d-none'); isValid = false; }
    else document.getElementById('rating-error').classList.add('d-none');
    if (comment.length < 10) { document.getElementById('comment-error').classList.remove('d-none'); isValid = false; }
    else document.getElementById('comment-error').classList.add('d-none');
    if (!isValid) return;

    const productId = document.getElementById('productId').value;
    fetch('/api/reviews', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productID: productId, rating: currentRating, comment: comment })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            bootstrap.Modal.getInstance(document.getElementById('reviewModal')).hide();
            showNotification('Отзыв успешно добавлен!', 'success');
            setTimeout(() => location.reload(), 1500);
        } else showNotification(data.error || 'Ошибка', 'error');
    })
    .catch(err => { console.error(err); showNotification('Ошибка при отправке', 'error'); });
}

// ------------------------- Таймер скидки -------------------------
function calculateTimeLeft(endDateStr) {
    if (!endDateStr) return '';
    const diff = new Date(endDateStr) - new Date();
    if (diff <= 0) return 'Акция закончилась';
    const days = Math.floor(diff / 86400000);
    const hours = Math.floor((diff % 86400000) / 3600000);
    const minutes = Math.floor((diff % 3600000) / 60000);
    if (days > 0) return `Осталось: ${days} дн. ${hours} ч.`;
    if (hours > 0) return `Осталось: ${hours} ч. ${minutes} мин.`;
    return `Осталось: ${minutes} мин.`;
}

function updateAllTimers() {
    document.querySelectorAll('[id^="timer-"]').forEach(el => {
        const end = el.getAttribute('data-end-date');
        if (end) { const span = el.querySelector('.timer-text'); if (span) span.textContent = calculateTimeLeft(end); }
    });
}

// ------------------------- Миниатюры и главное изображение -------------------------
function setMainImage(index) {
    if (!productImages || index >= productImages.length) return;
    document.getElementById('mainProductImage').src = `/images/products/${productImages[index].imageUrl}`;
    currentImageIndex = index;
    document.querySelectorAll('.product-thumbnail-item').forEach(item => item.classList.remove('active'));
    const active = document.querySelector(`.product-thumbnail-item[data-index="${index}"]`);
    if (active) active.classList.add('active');
}

// ------------------------- Модальная галерея -------------------------
function openGalleryModal(startIndex) {
    const modalEl = document.getElementById('imageGalleryModal');
    if (!modalEl) return;
    const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
    modal.show();

    modalEl.addEventListener('shown.bs.modal', function handler() {
        modalEl.removeEventListener('shown.bs.modal', handler);
        const carouselEl = document.getElementById('galleryCarousel');
        if (carouselEl) {
            let carousel = bootstrap.Carousel.getInstance(carouselEl);
            if (!carousel) {
                carousel = new bootstrap.Carousel(carouselEl, { interval: false, wrap: true });
                carouselEl.addEventListener('slid.bs.carousel', () => updateGalleryThumbnails());
            }
            carousel.to(startIndex);
        }
        updateGalleryThumbnails(startIndex);
    }, { once: true });
}

function updateGalleryThumbnails(index) {
    const thumbs = document.querySelectorAll('.gallery-thumbnail');
    const activeIndex = index !== undefined ? index :
        (document.querySelector('#galleryCarousel .carousel-item.active') ?
            Array.from(document.querySelectorAll('#galleryCarousel .carousel-item')).indexOf(document.querySelector('#galleryCarousel .carousel-item.active')) : 0);
    thumbs.forEach((thumb, idx) => thumb.classList.toggle('active', idx === activeIndex));
}

function goToSlide(index) {
    const carousel = bootstrap.Carousel.getInstance(document.getElementById('galleryCarousel'));
    if (carousel) carousel.to(index);
}

// ------------------------- Инициализация при загрузке -------------------------
document.addEventListener('DOMContentLoaded', function() {
    // Рейтинг
    document.querySelectorAll('#starRating .fa-star').forEach(star => {
        star.addEventListener('mouseover', () => hoverStars(parseInt(star.dataset.rating)));
        star.addEventListener('mouseout', resetStars);
        star.addEventListener('click', () => setRating(parseInt(star.dataset.rating)));
    });

    updateAllTimers();
    setInterval(updateAllTimers, 60000);

    const ratingElement = document.querySelector('.rating.me-3');
    if (ratingElement) {
        ratingElement.addEventListener('click', function(e) {
            e.preventDefault();
            document.getElementById('reviews-section')?.scrollIntoView({ behavior: 'smooth' });
        });
    }

    document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(el => new bootstrap.Tooltip(el));
});
</script>