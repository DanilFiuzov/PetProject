<div class="container def-bg-settings">
    <div class="row justify-content-center">
        <div class="col-lg-10">
            <!-- Хлебные крошки -->
            <nav aria-label="breadcrumb" class="mb-4 mt-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Главная</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Корзина</li>
                </ol>
            </nav>

            <!-- Заголовок -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h2 fw-bold">
                    <i class="fas fa-shopping-cart text-primary me-2"></i>
                    Корзина покупок
                </h1>
                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-3 py-2">
                    <i class="fas fa-box me-1"></i>
                    <%= products.length %> товар(ов)
                </span>
            </div>

            <% if (products.length === 0) { %>
                <!-- Пустая корзина -->
                <div class="card border-0 shadow-lg rounded-3">
                    <div class="card-body text-center py-5">
                        <div class="empty-cart-icon mb-4">
                            <i class="fas fa-shopping-cart fa-4x text-muted opacity-50"></i>
                        </div>
                        <h4 class="text-muted mb-3">Ваша корзина пуста</h4>
                        <p class="text-muted mb-4">Добавьте товары в корзину, чтобы оформить заказ</p>
                        <a href="/" class="btn btn-primary px-4 py-2">
                            <i class="fas fa-shopping-bag me-2"></i>Перейти в каталог
                        </a>
                    </div>
                </div>
            <% } else { %>
                <!-- Список товаров -->
                <div class="card border-0 shadow-lg rounded-3 mb-4">
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th style="width: 45%;">Товар</th>
                                        <th class="text-center">Цена</th>
                                        <th class="text-center">Количество</th>
                                        <th class="text-center">Итого</th>
                                        <th class="text-center">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% let totalPrice = 0; %>
                                    <% products.forEach(product => { %>
                                        <% const itemTotal = product.productPrice * product.sc_count; %>
                                        <tr class="product-row">
                                            <td>
                                                <div class="d-flex align-items-center">
                                                    <div class="position-relative me-3">
                                                        <img src="/images/products/<%= product.productThumbnail %>" 
                                                             alt="<%= product.productTitle %>" 
                                                             class="rounded" 
                                                             style="width: 80px; height: 80px; object-fit: cover;">
                                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-primary">
                                                            <%= product.sc_count %>
                                                        </span>
                                                    </div>
                                                    <div>
                                                        <h6 class="mb-1 fw-semibold">
                                                            <a href="/product/<%= product.productID %>" 
                                                               class="text-decoration-none text-dark">
                                                                <%= product.productTitle %>
                                                            </a>
                                                        </h6>
                                                        <p class="text-muted small mb-0">
                                                            <%= product.productManufacturer %>
                                                        </p>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="fw-bold text-primary">
                                                    <%= typeof product.productPrice === 'number' ? product.productPrice.toFixed(2) : '0.00' %>₽
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <div class="d-flex justify-content-center align-items-center">
                                                    <form action="/cart/update" method="post" class="d-inline">
                                                        <input type="hidden" name="productID" value="<%= product.productID %>">
                                                        <button type="submit" 
                                                                name="action" 
                                                                value="decrease" 
                                                                class="btn btn-sm btn-outline-secondary rounded-circle"
                                                                style="width: 32px; height: 32px; padding: 0;">
                                                            <i class="fas fa-minus"></i>
                                                        </button>
                                                    </form>
                                                    <span class="mx-3 fw-bold" style="min-width: 30px;">
                                                        <%= product.sc_count %>
                                                    </span>
                                                    <form action="/cart/update" method="post" class="d-inline">
                                                        <input type="hidden" name="productID" value="<%= product.productID %>">
                                                        <button type="submit" 
                                                                name="action" 
                                                                value="increase" 
                                                                class="btn btn-sm btn-outline-secondary rounded-circle"
                                                                style="width: 32px; height: 32px; padding: 0;">
                                                            <i class="fas fa-plus"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                            <td class="text-center">
                                                <span class="fw-bold">
                                                    <%= itemTotal.toFixed(2) %>₽
                                                </span>
                                            </td>
                                            <td class="text-center">
                                                <form action="/cart/remove" method="post" class="d-inline">
                                                    <input type="hidden" name="productID" value="<%= product.productID %>">
                                                    <button type="submit" 
                                                            class="btn btn-sm btn-outline-danger rounded-circle"
                                                            style="width: 36px; height: 36px; padding: 0;"
                                                            title="Удалить из корзины">
                                                        <i class="fas fa-times"></i>
                                                    </button>
                                                </form>
                                            </td>
                                        </tr>
                                        <% totalPrice += itemTotal; %>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Итоговая информация -->
                <div class="row">
                    <div class="col-lg-8">
                        <div class="d-grid gap-2 d-md-block">
                            <a href="/" class="btn btn-outline-primary">
                                <i class="fas fa-arrow-left me-2"></i>Продолжить покупки
                            </a>
                            <a href="#" class="btn btn-outline-secondary">
                                <i class="fas fa-sync-alt me-2"></i>Обновить корзину
                            </a>
                        </div>
                    </div>
                    <div class="col-lg-4">
                        <div class="card border-0 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title mb-3">Итог заказа</h5>
                                <div class="d-flex justify-content-between mb-2">
                                    <span class="text-muted">Стоимость товаров:</span>
                                    <span class="fw-semibold"><%= totalPrice.toFixed(2) %>₽</span>
                                </div>
                                <div class="d-flex justify-content-between mb-3">
                                    <span class="text-muted">Доставка:</span>
                                    <span class="fw-semibold text-success">Бесплатно</span>
                                </div>
                                <hr>
                                <div class="d-flex justify-content-between align-items-center mb-4">
                                    <span class="h5 mb-0">Итого:</span>
                                    <span class="h4 fw-bold text-primary"><%= totalPrice.toFixed(2) %>₽</span>
                                </div>
                                <button class="btn btn-primary w-100 py-3" 
                                        onclick="showNotification('Функция оформления заказа в разработке', 'info')">
                                    <i class="fas fa-lock me-2"></i>Оформить заказ
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>