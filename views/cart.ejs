<!-- Хлебные крошки -->
<nav aria-label="breadcrumb" class="breadcrumb-container">
    <div class="container">
        <ol class="breadcrumb bg-light p-3 rounded-3">
            <li class="breadcrumb-item">
                <a href="/" class="text-decoration-none text-primary">
                    <i class="fas fa-home me-1"></i>Главная
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                <i class="fas fa-shopping-cart me-1"></i>Корзина
            </li>
        </ol>
    </div>
</nav>

<div class="container def-bg-settings py-4">
    <!-- Заголовок -->
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h1 class="h2 fw-bold">
            <i class="fas fa-shopping-cart text-primary me-2"></i>
            Корзина покупок
        </h1>
        <% if (products.length > 0) { %>
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 px-4 py-3">
                <i class="fas fa-box me-1"></i>
                <%= products.length %> товар(ов)
            </span>
        <% } %>
    </div>

    <% if (products.length === 0) { %>
        <!-- Пустая корзина -->
        <div class="card border-0 shadow-lg rounded-4">
            <div class="card-body text-center py-5 px-4">
                <div class="empty-cart-icon mb-4">
                    <i class="fas fa-shopping-cart fa-4x text-muted opacity-50"></i>
                </div>
                <h3 class="text-muted mb-3 fw-bold">Ваша корзина пуста</h3>
                <p class="text-muted mb-4 lead">Добавьте товары в корзину, чтобы оформить заказ</p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="/" class="btn btn-primary px-4 py-3">
                        <i class="fas fa-home me-2"></i>На главную
                    </a>
                    <a href="/products" class="btn btn-outline-primary px-4 py-3">
                        <i class="fas fa-shopping-bag me-2"></i>В каталог
                    </a>
                </div>
            </div>
        </div>
    <% } else { %>
        <div class="row g-5">
            <!-- Список товаров -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-transparent border-0 py-4">
                        <h3 class="h4 fw-bold mb-0">
                            <i class="fas fa-boxes me-2"></i>Товары в корзине
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <% let totalPrice = 0; %>
                            <% products.forEach(product => { %>
                                <% 
                                    const itemPrice = product.isDiscounted ? parseFloat(product.discountedPrice) : parseFloat(product.productPrice);
                                    const itemTotal = itemPrice * product.sc_count; 
                                %>
                                <% totalPrice += itemTotal; %>
                                
                                <div class="list-group-item border-0 p-4">
                                    <div class="row g-4 align-items-center">
                                        <!-- Изображение -->
                                        <div class="col-md-3 col-lg-2">
                                            <a href="/product/<%= product.productID %>" class="text-decoration-none">
                                                <div class="image-container rounded-3 overflow-hidden bg-light" style="height: 120px;">
                                                    <img src="/images/products/<%= product.productThumbnail %>" 
                                                         class="img-fluid w-100 h-100 object-fit-cover"
                                                         alt="<%= product.productTitle %>">
                                                </div>
                                            </a>
                                        </div>

                                        <!-- Информация -->
                                        <div class="col-md-5 col-lg-6">
                                            <div>
                                                <h6 class="fw-bold mb-2">
                                                    <a href="/product/<%= product.productID %>" 
                                                       class="text-decoration-none text-dark">
                                                        <%= product.productTitle %>
                                                    </a>
                                                </h6>
                                                <div class="d-flex align-items-center mb-2">
                                                    <span class="text-muted me-2">Производитель:</span>
                                                    <span class="fw-medium"><%= product.productManufacturer %></span>
                                                </div>
                                                <div class="d-flex align-items-center price-display">
                                                    <% if (product.isDiscounted) { %>
                                                        <span class="text-muted text-decoration-line-through me-2">
                                                            <%= parseFloat(product.productPrice).toFixed(2) %>₽
                                                        </span>
                                                        <span class="text-primary fw-bold">
                                                            <%= itemPrice.toFixed(2) %>₽
                                                        </span>
                                                    <% } else { %>
                                                        <span class="text-primary fw-bold">
                                                            <%= itemPrice.toFixed(2) %>₽
                                                        </span>
                                                    <% } %>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Количество -->
                                        <div class="col-md-2 col-lg-2">
                                            <div class="d-flex align-items-center justify-content-center">
                                                <form action="/cart/update" method="post" class="d-inline">
                                                    <input type="hidden" name="productID" value="<%= product.productID %>">
                                                    <button type="submit" 
                                                            name="action" 
                                                            value="decrease" 
                                                            class="btn btn-outline-secondary rounded-circle p-0"
                                                            style="width: 36px; height: 36px;"
                                                            <%= product.sc_count <= 1 ? 'disabled' : '' %>>
                                                        <i class="fas fa-minus"></i>
                                                    </button>
                                                </form>
                                                <span class="mx-3 fw-bold fs-5" style="min-width: 40px;">
                                                    <%= product.sc_count %>
                                                </span>
                                                <form action="/cart/update" method="post" class="d-inline">
                                                    <input type="hidden" name="productID" value="<%= product.productID %>">
                                                    <button type="submit" 
                                                            name="action" 
                                                            value="increase" 
                                                            class="btn btn-outline-secondary rounded-circle p-0"
                                                            style="width: 36px; height: 36px;">
                                                        <i class="fas fa-plus"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>

                                        <!-- Итого и удаление -->
                                        <div class="col-md-2 col-lg-2">
                                            <div class="d-flex flex-column align-items-end">
                                                <span class="fw-bold fs-5 text-primary mb-3">
                                                    <%= itemTotal.toFixed(2) %>₽
                                                </span>
                                                <form action="/cart/remove" method="post" class="d-inline">
                                                    <input type="hidden" name="productID" value="<%= product.productID %>">
                                                    <button type="submit" 
                                                            class="btn btn-outline-danger rounded-pill px-3"
                                                            title="Удалить из корзины">
                                                        <i class="fas fa-trash-alt me-1"></i>Удалить
                                                    </button>
                                                </form>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    </div>
                </div>

                <!-- Продолжить покупки -->
                <div class="d-flex justify-content-between align-items-center mt-4">
                    <a href="/products" class="btn btn-outline-primary px-4 py-3">
                        <i class="fas fa-arrow-left me-2"></i>Продолжить покупки
                    </a>
                    <form action="/cart/clear" method="post" class="d-inline">
                        <button type="submit" 
                                class="btn btn-outline-danger px-4 py-3"
                                onclick="return confirm('Вы уверены, что хотите очистить всю корзину?')">
                            <i class="fas fa-trash-alt me-2"></i>Очистить корзину
                        </button>
                    </form>
                </div>
            </div>

            <!-- Итоги заказа -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm rounded-4 sticky-order-summary">
                    <div class="card-body p-4">
                        <h3 class="h4 fw-bold mb-4">
                            <i class="fas fa-receipt text-primary me-2"></i>Итог заказа
                        </h3>
                        
                        <!-- Детали -->
                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted">Товары (<%= products.length %>)</span>
                                <span class="fw-bold"><%= totalPrice.toFixed(2) %>₽</span>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted">Доставка</span>
                                <span class="fw-bold text-success">Бесплатно</span>
                            </div>
                            
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-muted">Скидка</span>
                                <span class="fw-bold text-danger">0.00₽</span>
                            </div>
                            
                            <hr class="my-4">
                            
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <span class="h5 fw-bold mb-0">Итого к оплате:</span>
                                <span class="h3 fw-bold text-primary"><%= totalPrice.toFixed(2) %>₽</span>
                            </div>
                        </div>
                        
                        <!-- Кнопка оформления -->
                        <button class="btn btn-primary btn-lg w-100 py-3 mb-3 fw-bold" 
                                onclick="showNotification('Функция оформления заказа в разработке', 'info')">
                            <i class="fas fa-lock me-2"></i>Перейти к оформлению
                        </button>
                        
                        <!-- Дополнительная информация -->
                        <div class="text-center">
                            <small class="text-muted">
                                <i class="fas fa-shield-alt me-1"></i>
                                Безопасная оплата • Гарантия возврата
                            </small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    <% } %>
</div>