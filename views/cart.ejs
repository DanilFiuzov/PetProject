<!-- Хлебные крошки -->
<nav aria-label="breadcrumb" class="breadcrumb-container">
    <div class="container">
        <ol class="breadcrumb bg-light p-3 rounded-3">
            <li class="breadcrumb-item">
                <a href="/" class="text-decoration-none text-primary">
                    <i class="fas fa-home me-1"></i>Главная
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                <i class="fas fa-shopping-cart me-1"></i>Корзина
            </li>
        </ol>
    </div>
</nav>

<div class="container def-bg-settings py-4 cart-page">
    <!-- Заголовок -->
    <div class="cart-header">
        <h1>
            <i class="fas fa-shopping-cart"></i>
            Корзина покупок
        </h1>
        <% if (products.length > 0) { %>
            <span class="cart-badge">
                <i class="fas fa-box"></i>
                <%= products.length %> товар(ов)
            </span>
        <% } %>
    </div>

    <% if (products.length === 0) { %>
        <!-- Пустая корзина -->
        <div class="card empty-cart-card">
            <div class="card-body text-center py-5 px-4" style="min-height: 50vh;">
                <div class="empty-cart-icon mb-4">
                    <i class="fas fa-shopping-cart fa-4x"></i>
                </div>
                <h3 class="text-muted mb-3 fw-bold">Ваша корзина пуста</h3>
                <p class="text-muted mb-4 lead">Добавьте товары в корзину, чтобы оформить заказ</p>
                <div class="d-flex justify-content-center gap-3">
                    <a href="/" class="btn btn-custom px-4 py-3">
                        <i class="fas fa-home me-2"></i>На главную
                    </a>
                    <a href="/products" class="btn btn-outline-custom px-4 py-3">
                        <i class="fas fa-shopping-bag me-2"></i>В каталог
                    </a>
                </div>
            </div>
        </div>
    <% } else { %>
        <!-- Проверка наличия товаров -->
        <%
            let hasOutOfStock = false;
            let lowStockItems = [];
            products.forEach(product => {
                if (product.stock_quantity <= 0) {
                    hasOutOfStock = true;
                } else if (product.sc_count > product.stock_quantity) {
                    lowStockItems.push({
                        productTitle: product.productTitle,
                        requested: product.sc_count,
                        available: product.stock_quantity
                    });
                }
            });
        %>
        
        <% if (hasOutOfStock) { %>
        <div class="alert alert-danger border-0 bg-danger bg-opacity-10 mb-4">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Внимание!</strong> Некоторые товары в вашей корзине отсутствуют на складе. Пожалуйста, удалите их из корзины.
        </div>
        <% } else if (lowStockItems.length > 0) { %>
        <div class="alert alert-warning border-0 bg-warning bg-opacity-10 mb-4">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Внимание!</strong> Недостаточное количество товара на складе:
            <ul class="mb-0 mt-2">
                <% lowStockItems.forEach(item => { %>
                <li>
                    <strong><%= item.productTitle %></strong> - 
                    запрошено <%= item.requested %> шт., 
                    доступно <%= item.available %> шт.
                </li>
                <% }) %>
            </ul>
        </div>
        <% } %>
        
        <div class="row g-4">
            <!-- Список товаров -->
            <div class="col-lg-8">
                <div class="card cart-products-card no-hover" style="min-height: 50vh;">
                    <div class="cart-products-header">
                        <h3>
                            <i class="fas fa-boxes"></i>Товары в корзине
                        </h3>
                    </div>
                    <div class="card-body p-0">
                        <div class="list-group list-group-flush">
                            <% let totalPrice = 0; %>
                            <% let originalTotal = 0; %>
                            <% products.forEach(product => { %>
                                <%
                                    // Вычисление цен
                                    const productPriceFull = parseFloat(product.productPrice) || 0;
                                    const discountedPrice = parseFloat(product.discountedPrice) || 0;
                                    const itemPrice = product.isDiscounted && discountedPrice > 0 ? discountedPrice : productPriceFull;
                                    const itemTotal = itemPrice * product.sc_count;
                                    const itemOriginal = productPriceFull * product.sc_count;

                                    // Состояния наличия
                                    const isOutOfStock = product.stock_quantity <= 0;
                                    const isLowStock = product.sc_count > product.stock_quantity;
                                    const canIncrease = product.sc_count < product.stock_quantity;
                                %>
                                <% totalPrice += itemTotal; %>
                                <% originalTotal += itemOriginal; %>
                                <div class="cart-item <%= isOutOfStock ? 'out-of-stock' : '' %>">
                                    <div class="cart-item-row">
                                        <!-- Изображение -->
                                        <div class="cart-item-image">
                                            <a href="/product/<%= product.productID %>" class="text-decoration-none d-block h-100">
                                                <img src="/images/products/<%= product.productThumbnail %>" 
                                                     alt="<%= product.productTitle %>">
                                            </a>
                                            <% if (isOutOfStock) { %>
                                                <div class="cart-item-sold-overlay">
                                                    <div class="cart-item-sold-badge">SOLD</div>
                                                </div>
                                            <% } %>
                                        </div>

                                        <!-- Информация -->
                                        <div class="cart-item-info">
                                            <h6 class="cart-item-title mb-0">
                                                <a href="/product/<%= product.productID %>" 
                                                   class="text-decoration-none <%= isOutOfStock || isLowStock ? 'text-muted' : '' %>">
                                                    <%= product.productTitle %>
                                                </a>
                                            </h6>
                                            <div class="cart-item-manufacturer">
                                                <i class="fas fa-industry"></i>
                                                <span><%= product.productManufacturer %></span>
                                            </div>
                                            <div class="cart-item-price">
                                                <% if (product.isDiscounted) { %>
                                                    <span class="cart-item-price-original">
                                                        <%= parseFloat(product.productPrice).toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') %>₽
                                                    </span>
                                                    <span class="cart-item-price-discounted <%= isOutOfStock || isLowStock ? 'text-muted' : '' %>">
                                                        <%= itemPrice.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') %>₽
                                                    </span>
                                                <% } else { %>
                                                    <span class="cart-item-price-regular <%= isOutOfStock || isLowStock ? 'text-muted' : '' %>">
                                                        <%= itemPrice.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') %>₽
                                                    </span>
                                                <% } %>
                                                <span class="text-muted" style="font-size: 0.9rem;">
                                                    за 1 шт.
                                                </span>
                                            </div>
                                            
                                            <!-- Индикатор наличия -->
                                            <div class="mt-2">
                                                <% if (isOutOfStock) { %>
                                                    <span class="badge bg-danger">
                                                        <i class="fas fa-times-circle me-1"></i>Нет в наличии
                                                    </span>
                                                <% } else if (isLowStock) { %>
                                                    <span class="badge bg-warning text-dark">
                                                        <i class="fas fa-exclamation-triangle me-1"></i>Только <%= product.stock_quantity %> шт.
                                                    </span>
                                                <% } else if (product.stock_quantity <= 5) { %>
                                                    <span class="badge bg-warning text-dark">
                                                        <i class="fas fa-exclamation-triangle me-1"></i>Мало на складе
                                                    </span>
                                                <% } else { %>
                                                    <span class="badge bg-success">
                                                        <i class="fas fa-check-circle me-1"></i>В наличии
                                                    </span>
                                                <% } %>
                                            </div>
                                        </div>

                                        <!-- Количество -->
                                        <div class="cart-item-quantity">
                                            <div class="quantity-control">
                                                <form action="/cart/update" method="post" class="d-inline">
                                                    <input type="hidden" name="productID" value="<%= product.productID %>">
                                                    <button type="submit" 
                                                            name="action" 
                                                            value="decrease" 
                                                            class="quantity-btn"
                                                            <%= product.sc_count <= 1 ? 'disabled' : '' %>
                                                            <%= isOutOfStock ? 'disabled' : '' %>>
                                                        <i class="fas fa-minus"></i>
                                                    </button>
                                                </form>
                                                <span class="quantity-display <%= isOutOfStock ? 'text-muted' : '' %>">
                                                    <%= product.sc_count %>
                                                </span>
                                                <form action="/cart/update" method="post" class="d-inline">
                                                    <input type="hidden" name="productID" value="<%= product.productID %>">
                                                    <button type="submit" 
                                                            name="action" 
                                                            value="increase" 
                                                            class="quantity-btn"
                                                            <%= !canIncrease || isOutOfStock ? 'disabled' : '' %>>
                                                        <i class="fas fa-plus"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </div>

                                        <!-- Итого и удаление -->
                                        <div class="cart-item-actions">
                                            <span class="cart-item-total <%= isOutOfStock || isLowStock ? 'text-muted' : '' %>">
                                                <%= itemTotal.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') %>₽
                                            </span>
                                            <form action="/cart/remove" method="post" class="d-inline">
                                                <input type="hidden" name="productID" value="<%= product.productID %>">
                                                <button type="submit" 
                                                        class="cart-item-remove"
                                                        title="Удалить из корзины">
                                                    <i class="fas fa-trash-alt"></i>
                                                </button>
                                            </form>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                            <% const discountAmount = originalTotal - totalPrice; %>  <!-- считаем после цикла -->
                        </div>
                    </div>
                </div>

                <!-- Продолжить покупки -->
                <div class="cart-continue-actions">
                    <a href="/products" class="cart-continue-btn">
                        <i class="fas fa-arrow-left"></i>Продолжить покупки
                    </a>
                    <form action="/cart/clear" method="post" class="d-inline">
                        <button type="submit" 
                                class="cart-clear-btn"
                                onclick="return confirm('Вы уверены, что хотите очистить всю корзину?')">
                            <i class="fas fa-trash-alt"></i>Очистить корзину
                        </button>
                    </form>
                </div>

            </div>

            <!-- Итоги заказа -->
            <div class="col-lg-4">
                <div class="order-summary-card no-hover sticky-order-summary">
                    <h3 class="order-summary-header">
                        <i class="fas fa-receipt text-primary"></i>Итог заказа
                    </h3>
                    
                    <!-- Детали -->
                    <div>
                        <div class="order-summary-item">
                            <span>Товары (<%= products.length %>)</span>
                            <span><%= totalPrice.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') %>₽</span>
                        </div>
                        
                        <div class="order-summary-item">
                            <span>Доставка</span>
                            <span class="text-success">Бесплатно</span>
                        </div>
                        
                        <div class="order-summary-item">
                            <span>Скидка</span>
                            <span class="text-danger">
                                <% if (discountAmount > 0) { %>
                                    -<%= discountAmount.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') %>₽
                                <% } else { %>
                                    0₽
                                <% } %>
                            </span>
                        </div>
                        
                        <div class="order-summary-total">
                            <span>Итого к оплате:</span>
                            <span><%= totalPrice.toFixed(0).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') %>₽</span>
                        </div>
                    </div>
                    
                    <!-- Кнопка оформления -->
                    <% if (!hasOutOfStock && lowStockItems.length === 0) { %>
                    <a href="/checkout" class="order-summary-checkout text-decoration-none">
                        <i class="fas fa-check-circle"></i>&nbspОформить заказ
                    </a>
                    <% } else { %>
                    <button class="order-summary-checkout-disabled" disabled>
                        <i class="fas fa-times-circle"></i>&nbspНевозможно оформить заказ
                    </button>
                    <% } %>
                    
                    <!-- Дополнительная информация -->
                    <div class="order-summary-info">
                        <small>
                            <i class="fas fa-shield-alt"></i>
                            Безопасная оплата • Гарантия возврата
                        </small>
                    </div>
                </div>
            </div>
        </div>
    <% } %>
    <% if (products.length > 0) { %>
<script>
    document.addEventListener('DOMContentLoaded', function() {
        // Проверка корзины при клике на кнопку оформления
        const checkoutBtn = document.querySelector('.order-summary-checkout');
        if (checkoutBtn) {
            checkoutBtn.addEventListener('click', function(e) {
                const cartItems = <%= JSON.stringify(products) %>;
                if (!cartItems || cartItems.length === 0) {
                    e.preventDefault();
                    showNotification('Ваша корзина пуста', 'danger');
                    return false;
                }
            });
        }
        
        // Функция показа уведомлений (если еще не определена)
        if (typeof showNotification === 'undefined') {
            window.showNotification = function(message, type = 'info') {
                const types = {
                    'success': { icon: 'fa-check-circle', color: 'success' },
                    'danger': { icon: 'fa-exclamation-circle', color: 'danger' },
                    'info': { icon: 'fa-info-circle', color: 'primary' }
                };
                
                const config = types[type] || types.info;
                
                const notification = document.createElement('div');
                notification.className = `alert alert-${config.color} alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow-lg`;
                notification.style.zIndex = '9999';
                notification.style.minWidth = '300px';
                notification.innerHTML = `
                    <div class="d-flex align-items-center">
                        <i class="fas ${config.icon} fa-2x me-3 text-${config.color}"></i>
                        <div>
                            <h6 class="mb-0 fw-bold">${message}</h6>
                        </div>
                    </div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                `;
                
                document.body.appendChild(notification);
                
                setTimeout(() => {
                    notification.remove();
                }, 5000);
            };
        }
    });
    </script>
    <% } %>
</div>
