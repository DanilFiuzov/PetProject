<div class="container def-bg-settings long-form-page py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Главная</a></li>
                    <li class="breadcrumb-item"><a href="/admin/products" class="text-decoration-none">Админ-панель</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Редактировать товар</li>
                </ol>
            </nav>

            <div class="card border-0 shadow-lg rounded-3">
                <div class="card-header CanvaHeader py-3 border-0">
                    <h3 class="mb-0 text-white"><i class="fas fa-edit me-2"></i>Редактирование товара</h3>
                </div>
                <div class="card-body p-4">
                    <form id="editProductForm" enctype="multipart/form-data">
                        <input type="hidden" name="productID" value="<%= product.productID %>">

                        <h5 class="text-primary mb-3 pb-2 border-bottom"><i class="fas fa-info-circle me-2"></i>Основная информация</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Название товара *</label>
                                <input type="text" class="form-control" name="productTitle" value="<%= product.productTitle %>" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Производитель *</label>
                                <input type="text" class="form-control" name="productManufacturer" value="<%= product.productManufacturer %>" required>
                            </div>
                            <div class="col-12 mb-3">
                                <label class="form-label fw-semibold">Описание товара *</label>
                                <textarea class="form-control" name="productDescription" rows="4" required><%= product.productDescription %></textarea>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Цена (руб) *</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" name="productPrice" min="1" step="0.01" value="<%= product.productPrice %>" required>
                                    <span class="input-group-text">₽</span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-semibold">Количество на складе *</label>
                                <div class="input-group">
                                    <input type="number" class="form-control" name="stock_quantity" min="0" required value="<%= product.stock_quantity || 0 %>">
                                    <span class="input-group-text">шт.</span>
                                </div>
                                <div class="form-text text-success">
                                    <i class="fas fa-info-circle me-1"></i> Текущее: <strong><%= product.stock_quantity || 0 %></strong> шт.
                                    <% if (product.stock_quantity <= 0) { %><span class="text-danger ms-2">Товар отсутствует!</span><% } %>
                                </div>
                            </div>
                        </div>

                        <h5 class="text-primary mb-3 pb-2 border-bottom"><i class="fas fa-percentage me-2"></i>Скидка и акции</h5>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-check form-switch mb-3">
                                    <input class="form-check-input" type="checkbox" name="is_on_sale" id="is_on_sale" value="1"
                                        <%= product.is_on_sale ? 'checked' : '' %> onchange="toggleDiscountFields()">
                                    <label class="form-check-label fw-semibold" for="is_on_sale">Включить скидку</label>
                                </div>
                            </div>
                        </div>
                        <div id="discountFields" style="<%= product.is_on_sale ? '' : 'display: none;' %>">
                            <div class="row">
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-semibold">Процент скидки</label>
                                    <div class="input-group">
                                        <input type="number" class="form-control" name="discount_percentage" min="1" max="99" step="1"
                                            value="<%= product.discount_percentage || '' %>">
                                        <span class="input-group-text">%</span>
                                    </div>
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-semibold">Дата начала</label>
                                    <input type="datetime-local" class="form-control" name="discount_start_date"
                                        value="<%= product.discount_start_date ? new Date(product.discount_start_date).toISOString().slice(0,16) : '' %>">
                                </div>
                                <div class="col-md-4 mb-3">
                                    <label class="form-label fw-semibold">Дата окончания</label>
                                    <input type="datetime-local" class="form-control" name="discount_end_date"
                                        value="<%= product.discount_end_date ? new Date(product.discount_end_date).toISOString().slice(0,16) : '' %>">
                                </div>
                            </div>
                        </div>

                        <h5 class="text-primary mb-3 pb-2 border-bottom"><i class="fas fa-image me-2"></i>Изображения</h5>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Текущие изображения</label>
                            <div class="d-flex flex-wrap gap-2">
                                <% if (product.images && product.images.length > 0) {
                                    product.images.forEach(img => { %>
                                        <img src="/images/products/<%= img.imageUrl %>" class="img-thumbnail" style="max-height: 120px;">
                                <%  }); } else if (product.productThumbnail) { %>
                                    <img src="/images/products/<%= product.productThumbnail %>" class="img-thumbnail" style="max-height: 120px;">
                                <% } %>
                            </div>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" name="keepCurrentImage" id="keepCurrentImage" checked
                                onchange="toggleNewImageField()">
                            <label class="form-check-label" for="keepCurrentImage">Оставить текущие изображения</label>
                        </div>
                        <div class="mb-3" id="newImageField" style="display: none;">
                            <label class="form-label fw-semibold">Заменить изображения (можно выбрать несколько)</label>
                            <input type="file" class="form-control" name="productImage" accept="image/jpeg,image/png,image/webp" multiple
                                onchange="previewMultipleImages(this)">
                            <div class="form-text">Выбранные изображения заменят текущие</div>
                            <div id="imagePreviews" class="d-flex flex-wrap gap-2 mt-2"></div>
                        </div>

                        <h5 class="text-primary mb-3 pb-2 border-bottom"><i class="fas fa-tags me-2"></i>Категории</h5>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Выберите категории *</label>
                            <div class="categories-checkbox">
                                <% if (typeof categories !== 'undefined' && categories.length > 0) {
                                    const productCategories = currentCategories || [];
                                    categories.forEach(category => { %>
                                        <div class="form-check form-check-inline me-4 mb-2">
                                            <input class="form-check-input" type="checkbox" name="categories[]" value="<%= category.categorieName %>"
                                                id="category<%= category.categorieID %>"
                                                <%= productCategories.includes(category.categorieName) ? 'checked' : '' %>>
                                            <label class="form-check-label" for="category<%= category.categorieID %>"><%= category.categorieName %></label>
                                        </div>
                                <% }); } %>
                            </div>
                        </div>

                        <h5 class="text-primary mb-3 pb-2 border-bottom d-flex justify-content-between align-items-center">
                            <span><i class="fas fa-list-alt me-2"></i>Характеристики</span>
                            <button type="button" class="btn btn-sm btn-outline-primary" id="addFeatureBtn"><i class="fas fa-plus me-1"></i>Добавить</button>
                        </h5>
                        <div id="featuresContainer">
                            <% if (features && features.length > 0) {
                                features.forEach(feature => { %>
                                    <div class="feature-item mb-3 border rounded p-3 bg-light">
                                        <div class="row g-2">
                                            <div class="col-md-5"><input type="text" class="form-control" name="feature_keys[]" value="<%= feature.key %>" required></div>
                                            <div class="col-md-5"><input type="text" class="form-control" name="feature_values[]" value="<%= feature.value %>" required></div>
                                            <div class="col-md-2"><button type="button" class="btn btn-outline-danger w-100 remove-feature-btn"><i class="fas fa-times"></i></button></div>
                                        </div>
                                    </div>
                            <% }); } else { %>
                                <div class="feature-item mb-3 border rounded p-3 bg-light">
                                    <div class="row g-2">
                                        <div class="col-md-5"><input type="text" class="form-control" name="feature_keys[]" placeholder="Характеристика" required></div>
                                        <div class="col-md-5"><input type="text" class="form-control" name="feature_values[]" placeholder="Значение" required></div>
                                        <div class="col-md-2"><button type="button" class="btn btn-outline-danger w-100 remove-feature-btn" disabled><i class="fas fa-times"></i></button></div>
                                    </div>
                                </div>
                            <% } %>
                        </div>

                        <div class="d-flex justify-content-between pt-3 border-top">
                            <a href="/admin/products" class="btn btn-secondary"><i class="fas fa-arrow-left me-2"></i>Назад</a>
                            <div>
                                <button type="button" class="btn btn-danger me-2" id="deleteProductBtn" data-product-id="<%= product.productID %>"><i class="fas fa-trash me-2"></i>Удалить</button>
                                <button type="submit" class="btn btn-primary px-4" id="submitBtn"><i class="fas fa-save me-2"></i>Сохранить</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            <div id="notificationContainer" class="mt-4"></div>
        </div>
    </div>
</div>

<script>
    // Функции такие же, как в add_product.ejs (переключение скидки, предпросмотр, добавление/удаление характеристик)
    function toggleDiscountFields() {
        const discountFields = document.getElementById('discountFields');
        const isOnSale = document.getElementById('is_on_sale').checked;
        discountFields.style.display = isOnSale ? 'block' : 'none';
        const percentInput = document.querySelector('[name="discount_percentage"]');
        const startDate = document.querySelector('[name="discount_start_date"]');
        const endDate = document.querySelector('[name="discount_end_date"]');
        if (isOnSale) {
            if (percentInput) percentInput.disabled = false;
            if (startDate) startDate.disabled = false;
            if (endDate) endDate.disabled = false;
            if (startDate && !startDate.value) {
                const now = new Date();
                now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
                startDate.value = now.toISOString().slice(0, 16);
            }
        } else {
            if (percentInput) percentInput.disabled = true;
            if (startDate) startDate.disabled = true;
            if (endDate) endDate.disabled = true;
        }
    }

    function toggleNewImageField() {
        const field = document.getElementById('newImageField');
        field.style.display = document.getElementById('keepCurrentImage').checked ? 'none' : 'block';
    }

    function previewMultipleImages(input) {
        const container = document.getElementById('imagePreviews');
        container.innerHTML = '';
        if (input.files) {
            Array.from(input.files).forEach(file => {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.className = 'img-thumbnail';
                    img.style.maxHeight = '150px';
                    container.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        }
    }

    document.getElementById('addFeatureBtn').addEventListener('click', function() {
        const container = document.getElementById('featuresContainer');
        const newItem = document.createElement('div');
        newItem.className = 'feature-item mb-3 border rounded p-3 bg-light';
        newItem.innerHTML = `
            <div class="row g-2">
                <div class="col-md-5"><input type="text" class="form-control" name="feature_keys[]" placeholder="Характеристика" required></div>
                <div class="col-md-5"><input type="text" class="form-control" name="feature_values[]" placeholder="Значение" required></div>
                <div class="col-md-2"><button type="button" class="btn btn-outline-danger w-100 remove-feature-btn"><i class="fas fa-times"></i></button></div>
            </div>`;
        container.appendChild(newItem);
        updateRemoveButtons();
    });

    document.addEventListener('click', function(e) {
        if (e.target.closest('.remove-feature-btn') || e.target.classList.contains('fa-times')) {
            const item = e.target.closest('.feature-item');
            if (item) { item.remove(); updateRemoveButtons(); }
        }
    });

    function updateRemoveButtons() {
        const items = document.querySelectorAll('.feature-item');
        items.forEach(item => {
            const btn = item.querySelector('.remove-feature-btn');
            if (items.length === 1) { btn.disabled = true; btn.classList.add('disabled'); }
            else { btn.disabled = false; btn.classList.remove('disabled'); }
        });
    }

    document.getElementById('editProductForm').addEventListener('submit', function(e) {
        e.preventDefault();
        const stock = parseInt(document.querySelector('[name="stock_quantity"]').value);
        if (isNaN(stock) || stock < 0) { showNotification('Количество должно быть неотрицательным', 'error'); return; }
        const categories = document.querySelectorAll('[name="categories[]"]:checked');
        if (categories.length === 0) { showNotification('Выберите категорию', 'error'); return; }
        const keys = document.querySelectorAll('[name="feature_keys[]"]');
        const values = document.querySelectorAll('[name="feature_values[]"]');
        for (let i = 0; i < keys.length; i++) {
            if (!keys[i].value.trim() || !values[i].value.trim()) { showNotification('Заполните характеристики', 'error'); return; }
        }
        const formData = new FormData(this);
        if (!document.getElementById('is_on_sale').checked) formData.set('is_on_sale', '0');
        document.getElementById('submitBtn').disabled = true;
        document.getElementById('submitBtn').innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Сохранение...';
        fetch('/admin/update-product', { method: 'POST', body: formData })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    showNotification('Товар обновлён!', 'success');
                    setTimeout(() => { window.location.href = '/admin/products'; }, 1500);
                } else {
                    showNotification(data.message || 'Ошибка', 'error');
                    document.getElementById('submitBtn').disabled = false;
                    document.getElementById('submitBtn').innerHTML = '<i class="fas fa-save me-2"></i>Сохранить';
                }
            })
            .catch(() => {
                showNotification('Ошибка сети', 'error');
                document.getElementById('submitBtn').disabled = false;
                document.getElementById('submitBtn').innerHTML = '<i class="fas fa-save me-2"></i>Сохранить';
            });
    });

    document.getElementById('deleteProductBtn').addEventListener('click', function() {
        if (confirm('Удалить товар безвозвратно?')) {
            fetch(`/admin/delete-product/${this.dataset.productId}`, { method: 'DELETE' })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        showNotification('Товар удалён', 'success');
                        setTimeout(() => { window.location.href = '/admin/products'; }, 1500);
                    } else showNotification(data.message || 'Ошибка', 'error');
                });
        }
    });

    function showNotification(message, type) {
        const container = document.getElementById('notificationContainer');
        const cls = type === 'success' ? 'alert-success' : 'alert-danger';
        const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
        container.innerHTML = `<div class="alert ${cls} alert-dismissible fade show"><i class="fas ${icon} me-2"></i>${message}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>`;
        setTimeout(() => { container.innerHTML = ''; }, 5000);
    }

    document.addEventListener('DOMContentLoaded', function() {
        const endDate = document.querySelector('[name="discount_end_date"]');
        if (endDate) {
            const now = new Date();
            now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
            endDate.min = now.toISOString().slice(0, 16);
        }
        toggleNewImageField();
        updateRemoveButtons();
    });
</script>