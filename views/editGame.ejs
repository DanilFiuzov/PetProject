
<div class="container def-bg-settings">
    <form action="/edit/<%= games[0].gameID %>" method="post" enctype="multipart/form-data">
        <div class="border-b">
            <h1>Редактор Изменения игры</h1>
        </div>
        <div class="row">
            <div class="col-4 border-r">
                <div class="p-3">
                    <div style="height: 70px; padding-top: 10px; padding-top: 0 !important;">
                        <h3>Название игры (18)</h3>
                        <input type="text" name="title" placeholder="Сейчас: <%- games[0].gameTitle %>" class="w-100" maxlength="18"> 
                    </div>
                    <hr>
                    <div style="height: 145px; padding-top: 10px; padding-top: 0 !important;">
                        <h3>Описание игры (100)</h3>
                        <textarea name="description" placeholder="Сейчас: <%- games[0].gameDescription %>" maxlength="100" style="height: 100px; resize: none;" class="w-100"></textarea>
                    </div>
                    <hr>
                    <div style="height: 370px; padding-top: 10px; padding-top: 0 !important;">
                        <h3>Изображения для вашей игры</h3>
                        <input type="file" id="gameImage" name="image" accept="image/*" style="display: none;" multiple>
                        <div class="p-0" id="gameImage2">
                            <% if (games[0].gameImage) { %>
                                <h4>Ваши изображения:</h4>
                                <ul class="list-group list-group-flush" style="margin-bottom: 7px;">
                                    <%
                                    const gameImages = games[0].gameImage.split(',');
                                    const displayCount = 4; 
                                    const totalImages = gameImages.length;
                                    
                                    // Цикл для отображения первых 5 изображений
                                    for (let i = 0; i < Math.min(displayCount, totalImages); i++) { %>
                                        <li class="list-group-item"><%- gameImages[i].split('/').pop() %></li>
                                    <% } %>
                            
                                    <% if (totalImages > displayCount) { %>
                                        <li class="list-group-item">И другие (<%= totalImages - displayCount %>)</li>
                                    <% } %>
                                </ul>
                            <% } else { %>
                                <p>Нет изображений</p>
                            <% } %>                      
                        </div>
                        <button class="btn ButtonMdBG" type="button" onclick="clearInput('gameImage', this)" style="padding-left: 20px; padding-right: 20px;">Удалить текущие</button>
                    </div>
                    <hr>
                    <div style="height: 240px; padding-top: 10px; padding-top: 0 !important;">
                        <h3>Java Scripts</h3>
                        <input type="file" id="jsFile" name="script" accept="script/*" style="display: none;" multiple> 
                        <div class="p-0" id="jsFile2">
                            <% if (games[0].jsFile) { %>
                                <h4>Ваши Скрипты:</h4>
                                <ul class="list-group list-group-flush" style="margin-bottom: 7px;">
                                    <% 
                                    const gameScripts = games[0].jsFile.split(',');
                                    const displayCount = 2; 
                                    const totalScripts = gameScripts.length;
                                    
                                    // Цикл для отображения первых 5 изображений
                                    for (let i = 0; i < Math.min(displayCount, totalScripts); i++) { %>
                                        <li class="list-group-item"><%- gameScripts[i].split('/').pop() %></li>
                                    <% } %>
                            
                                    <% if (totalScripts > displayCount) { %>
                                        <li class="list-group-item">И другие (<%= totalScripts - displayCount %>)</li>
                                    <% } %>
                                </ul>
                            <% } else { %>
                                <p>Нет скриптов</p>
                            <% } %>                              
                        </div>
                        <button class="btn ButtonMdBG" type="button" onclick="clearInput('jsFile', this)" style="padding-left: 20px; padding-right: 20px;">Удалить текущие</button>
                    </div>
                    <hr>
                    <div style="height: 240px; padding-top: 10px; padding-top: 0 !important;">
                        <h3>CSS Styles</h3>
                        <input type="file" id="cssFile" name="style" accept="style/*" style="display: none;" multiple>
                        <div class="p-0" id="cssFile2">
                            <% if (games[0].cssFile) { %>
                                <h4>Ваши стили:</h4>
                                <ul class="list-group list-group-flush" style="margin-bottom: 7px;">
                                    <% 
                                    const gameCss = games[0].cssFile.split(',');
                                    const displayCount = 2; 
                                    const totalCss = gameCss.length;
                                    
                                    // Цикл для отображения первых 5 изображений
                                    for (let i = 0; i < Math.min(displayCount, totalCss); i++) { %>
                                        <li class="list-group-item"><%- gameCss[i].split('/').pop() %></li>
                                    <% } %>
                            
                                    <% if (totalCss > displayCount) { %>
                                        <li class="list-group-item">И другие (<%= totalCss - displayCount %>)</li>
                                    <% } %>
                                </ul>
                            <% } else { %>
                                <p>Нет стилей</p>
                            <% } %>                          
                        </div>
                        <button class="btn ButtonMdBG" type="button" onclick="clearInput('cssFile', this)" style="padding-left: 20px; padding-right: 20px;">Удалить текущие</button>
                    </div>
                    <hr>
                    <div style="height: 290px; padding-top: 10px; padding-top: 0 !important;">
                        <h3>Route file</h3>
                        <input type="file" id="routeFile" name="route" accept="route/*" style="display: none;">
                        <div class="p-0" id="routeFile2">
                            <% if (games[0].viewFile) { %>
                            <h4>Ваш файл маршрутизации:</h4>
                            <ul class="list-group list-group-flush" style="margin-bottom: 7px;">
                                <li class="list-group-item">
                                    <%- games[0].routeFile %>
                                </li>
                            </ul> 
                            <% } else { %>
                                <p>Нет файла маршрутизации</p>
                            <% } %>          
                        </div>
                        <button class="btn ButtonMdBG" type="button" onclick="clearInput('routeFile', this)" style="padding-left: 20px; padding-right: 20px;">Удалить текущий</button>                     
                    </div>
                    <hr>
                    <div style="height: 500px; padding-top: 10px; padding-top: 0 !important;">
                        <h3>EJS Views</h3>
                        <input type="file" id="viewFile" name="view" accept="view/*" style="display: none;" multiple>
                        <div class="p-0" id="viewFile2">
                            <% if (games[0].viewFile) { %>
                                <h4>Ваши изображения:</h4>
                                <ul class="list-group list-group-flush" style="margin-bottom: 7px;">
                                    <% 
                                    const gameViews = games[0].viewFile.split(',');
                                    gameViews.forEach(imagePath => {
                                        const fileName = imagePath.split('/').pop();
                                    %>
                                        <li class="list-group-item"><%- fileName %></li>
                                    <% }); %>
                                </ul>
                            <% } else { %>
                                <p>Нет ejs представлений</p>
                            <% } %>                         
                        </div>
                            <button class="btn ButtonMdBG" type="button" onclick="clearInput('viewFile', this)" style="padding-left: 20px; padding-right: 20px;">Удалить текущие</button>
                    </div>
                </div>  
            </div>
            <div class="col-8 p-3">
                <div class="d-flex" style="height: 70px; padding-top: 10px;">
                    <div class="col-5">
                        <img width="90%" src="/images/AddGame/game_title.png" alt="">
                    </div>
                    <div class="col-7">
                        <h5>Название игры - это название игры!</h5> 
                    </div>  
                </div>
                <hr>
                <div class="row" style="height: 145px; padding-top: 10px;">
                    <div class="col-5">
                        <img width="90%" src="/images/AddGame/game_description.png" alt="">
                    </div>
                    <div class="col-7">
                        <h5>Описание </h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <p>Описание игры должно быть написано кратко, но должно быть информативным.</p>
                            </li>
                        </ul> 
                    </div>    
                </div>
                <hr>
                <div class="row" style="height: 370px; padding-top: 10px;">
                    <div class="col-5">
                        <img width="90%" src="/images/AddGame/game_image.png" alt="">
                    </div>
                    <div class="col-7">
                        <h5>Изображения (до 25 и весом не более 10МБ) </h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <h5>Основное изображение игры</h5>
                                <p>Изображение формата '.png', обязательно квадратная!<br>(желательно 500x500px) <br> Главное изображениие <b>должно!</b> называться "Logo.png"</p>
                            </li>
                            <li class="list-group-item"> 
                                <h5>Другие изображения</h5>
                                <p>Вы можете загрузить до 24 изображений, которые будут располагаться по пути: <br>src = '/(Ваш ID = <b><%- session.userId %></b>)/images/' <br>(Пример: /1/images/img.png) <br>Либо вы можете использовать web ссылки.
                                </p>
                            </li>
                        </ul>
                    </div>       
                </div>
                <hr>
                <div class="row" style="height: 240px; padding-top: 10px;">
                    <div class="col-5">
                        <img width="90%" src="/images/AddGame/script_image.png" alt="">
                    </div>
                    <div class="col-7">
                        <h5>Скрипты (до 5 и весом не более 2МБ) </h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <p>Вы можете загрузить до 5 скриптов, которые будут располагаться по пути: <br>
                                    src = '/(Ваш ID = <b><%- session.userId %></b>)/scripts/' <br>
                                    (Пример: /1/scripts/script.js) <br>
                                    Либо вы можете использовать web ссылки.
                                </p>
                            </li>
                        </ul>
                    </div>  
                </div>
                <hr>
                <div class="row" style="height: 240px; padding-top: 10px;">
                    <div class="col-5">
                        <img width="90%" src="/images/AddGame/css_image.png" alt="">
                    </div>
                    <div class="col-7">
                        <h5>Стили (Не более 5 и весом не более 2МБ)</h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <p>
                                    Вы можете загрузить до 5 стилей, которые будут располагаться по пути: <br>
                                    src = '/(Ваш ID = <b><%- session.userId %></b>)/styles/' <br>
                                    (Пример: /1/styles/style.css) <br>
                                    Либо вы можете использовать web ссылки(Такие как Bootstrap). 
                                </p>
                            </li>
                        </ul> 
                    </div> 
                </div>
                <hr>
                <div class="row" style="height: 290px; padding-top: 10px;">
                    <div class="col-5">
                        <img width="90%" src="/images/AddGame/game_route.png" alt="">
                        <hr>
                        <img width="90%" src="/images/AddGame/game_route2.png" alt="">
                    </div>
                    <div class="col-7">
                        <h5>Маршрутизация (Не более 1)</h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <h5>Файл</h5>
                                <p>Файл маршрутизации <b>должен!</b> называться: "route.js"</p>
                            </li>
                            <li class="list-group-item">
                                <h5>Маршруты</h5>
                                <p>
                                    Путь в route файле: <br>
                                    ('<b>/test</b>) <br>
                                    Путь в ejs представлении: <br>
                                    ('/game/&lt;%= session.activeGameID %&gt;<b>/test</b>') 
                                </p>
                            </li>
                        </ul> 
                    </div> 
                </div>
                <hr>
                <div class="row" style="height: 500px; padding-top: 10px;">
                    <div class="col-5">
                        <img width="90%" src="/images/AddGame/game_view.png" alt="">
                        <hr>
                        <img width="90%" src="/images/AddGame/game_view2.png" alt="">
                        <hr>
                        <img width="90%" src="/images/AddGame/game_view3.png" alt="">
                    </div>
                    <div class="col-7">
                        <h5>Представления (до 5 и весом не более 2МБ) </h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">
                                <h5>Основное ejs представление</h5>
                                <p>Главное представление <b>должно!</b> называться "index.ejs"</p>
                            </li>
                            <li class="list-group-item">
                                <h5>Остальные представления</h5>
                                <p>Вы можете загрузить до 4 представлений, которые будут располагаться по пути: <br>
                                    '(Ваш ID = <b><%- session.userId %></b>)/views/' <br>
                                    (Пример: 1/views/view.ejs) <br>
                                    Предствления вставляются между основными header и footer на сайте, <u>поэтому никаких тегов head или body</u>. <br>
                                     Соответственно при ренднре страницы необходимо указать необходимое представление в переменную body, а основным представлением указать 'layout' <br>
                                    <b>Пример:</b> <br>
                                    res.render('layout', { <br>
                                    body: `1/views/view.ejs`,<br>
                                    });
                            </li>
                        </ul>
                    </div>  
                </div>
            </div>
        </div> 
        <div class="row p-4 border-t">
            <div class="col">
                <h2>Основные маршруты на сайте</h2>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <p>('/') -> Главная страница</p>
                    </li>
                    <li class="list-group-item">
                        <p>('/login') -> Страница авторизации</p>
                    </li>
                    <li class="list-group-item">
                        <p>('/register') -> Страница регистрации</p>
                    </li>
                    <li class="list-group-item">
                        <p>('/acc_page') -> Страница аккаунта</p>
                    </li>
                </ul>
            </div>
            <div class="col"> 
                <h2>Данные сохраненные в сессии</h2>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <p>(req.session.userId) -> ID пользователя</p>
                    </li>
                    <li class="list-group-item">
                        <p>(req.session.userName) -> Имя пользователя</p>
                    </li>
                    <li class="list-group-item">
                        <p>(req.session.userRank) -> Ранг пользователя</p>
                    </li>
                    <li class="list-group-item">
                        <p>(req.session.userThumbnail) -> Аватарка пользователя</p>
                    </li>
                    <li class="list-group-item">
                        <p>(req.session.SelectGameLosses) -> Кол-во поражений в активной игре</p>
                    </li>
                    <li class="list-group-item">
                        <p>(req.session.SelectGameWins) -> Кол-во побед в активной игре</p>
                    </li>
                    <li class="list-group-item">
                        <p>(req.session.SelectGameLosses) -> Кол-во ничьих в активной игре</p>
                    </li>
                    <li class="list-group-item">
                        <p>(req.session.SelectGameWins) -> Общий счет в активной игре</p>
                    </li>
                </ul>
            </div>
        </div>
        <div class="row p-4 border-t">
            <div class="col">
                <h2>База Данных MySql Server</h2>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <p>Если вы хотите использовать фунуции Базы данных необходимо сделать подключение в файле маршрутизации добавив строчку <u> "const connection = require('../../../database');"</u></p>
                    </li>
                    <li class="list-group-item">
                        <img width="90%" src="/images/AddGame/database_image.png" alt="">
                    </li>
                </ul>
            </div>
            <div class="col"> 
                <h2>Функции Базы данных</h2>
                <ul class="list-group list-group-flush">
                    <li class="list-group-item">
                        <H3>Function UpdateWinRate()</H3>
                        <p>Эта функция может быть использована для добавления очков побед, поражений, счета, и ничьих. Передавать добавляемые значения необходимо в числовом формате. <br>
                            Принимает значения, которые необходимо добавить, в следующем порядке: Победы, Поражения, Счет, Ничьи, req.session.activeGameID,req.session.userId <br>
                            Пример: <br>
                            connection.UpdateWinRate(0,1,0,0, req.session.activeGameID,req.session.userId) <br>
                            Этот код добавит активному пользователю 1 поражение
                        </p>
                        <img width="90%" src="/images/AddGame/update_function.png" alt="">
                    </li>
                    <li class="list-group-item">
                        <p>(req.session.userName) -> Имя пользователя</p>
                    </li>
                </ul>
            </div>
        </div>
        <div class='d-flex justify-content-end border-t'>
            <div class="p-3" style="height: 70px;">
                <button class="btn ButtonSmBG" type="submit" style="float: right;">Изменить</button>
            </div>
        </form>
        <form id="deleteForm" action="/delete/<%- games[0].gameID %>" method="post">
            <div class="p-3" style="height: 70px;">
                <button class="btn ButtonSmBG" type="button" data-bs-toggle="modal" data-bs-target="#confirmationModal" style="float: right;">
                    Удалить
                </button>
            </div>
        </form>
    </div>
    <div class="modal fade" id="confirmationModal" tabindex="-1" aria-labelledby="confirmationModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content" style="background-color: bisque;">
                <div class="modal-header" style="border-bottom: 0 !important;">
                    <h5 class="modal-title" id="confirmationModalLabel">Подтверждение удаления</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Закрыть"></button>
                </div>
                <div class="modal-body">
                    Вы уверены, что хотите удалить игру <%- games[0].gameTitle %>?
                </div>
                <div class="modal-footer" style="border-top: 0 !important;">
                    <button type="button" class="btn ButtonXsBG" data-bs-dismiss="modal">Отмена</button>
                    <button type="button" class="btn ButtonXsBG" id="confirmDelete">Удалить</button>
                </div>
            </div>
        </div>
    </div>
</div>