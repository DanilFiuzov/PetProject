<form action="/games/edit/<%= game.id %>" method="post" enctype="multipart/form-data">
    <input type="text" name="title" value="<%= game.title %>" required>
    <textarea name="description" required><%= game.description %></textarea>
    <input type="file" name="image" accept="image/*">
    <button type="submit">Обновить игру</button>
</form>