<div class="container def-bg-settings" style="width: 600px;">
    <div style="width: 100%; height: 800px;padding:50px; padding-top: 5vw;">
        <h3>Регистрация</h3>
        <form action="/register" method="POST">
            <div class="form-group mb-3">
                <label>Имя</label>
                <input type="text" class="form-control" placeholder="Имя" name="username">
            </div>
            <div class="form-group mb-3">
                <label>Email</label>
                <input type="text" class="form-control" placeholder="Введите email" name="email">
            </div>
            <div class="form-group mb-3">
                <label>Пароль</label>
                <input type="password" class="form-control" placeholder="Придумайте пароль" name="password">
            </div>
            <div class="form-group mb-3">
                <label>Подтверждение пароля</label>
                <input type="password" class="form-control" placeholder="Повторите пароль" name="confirmpassword">
            </div>
            <div class="d-grid mt-3">
                <button type="submit" class="btn btn-primary form-control">Регистрация</button>
            </div>
        </form>
        <p class="mt-3 text-center">
            Уже есть аккаунт? <a href="/login">Войти</a>
        </p>
        <% if (typeof error !== 'undefined') { %>
            <div class="alert alert-danger mt-3"><%= error %></div>
        <% } %>
    </div>
</div>