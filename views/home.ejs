<!-- Карусель с акционными товарами - ВЕРТИКАЛЬНАЯ ВЕРСИЯ -->
<section class="vertical-carousel-section mb-5">
    <div class="container">
        <div class="row align-items-center mb-4">
            <div class="col-md-8">
                <h2 class="mb-0" style="color: var(--danger-color); font-weight: 700;">
                    <i class="fas fa-fire me-2"></i>
                    Горящие акции
                </h2>
                <p class="text-muted mb-0 mt-2">Специальные предложения на популярные товары</p>
            </div>
            <div class="col-md-4 text-end">
                <a href="/products?sort=discount" class="btn btn-outline-danger">
                    <i class="fas fa-arrow-right me-2"></i>
                    Все акции
                </a>
            </div>
        </div>
        
        <% if (carouselItems.length === 0) { %>
            <!-- Заглушка если нет акционных товаров -->
            <div class="text-center py-5" style="background: linear-gradient(135deg, #fff5f5 0%, #ffe6e6 100%); border-radius: 15px;">
                <i class="fas fa-fire fa-3x text-muted mb-3"></i>
                <h4 class="text-muted">Скоро новые акции!</h4>
                <p class="text-muted">Следите за нашими специальными предложениями</p>
                <a href="/products" class="btn btn-danger">
                    <i class="fas fa-shopping-bag me-2"></i>
                    Перейти в каталог
                </a>
            </div>
        <% } else { %>
            <div class="vertical-carousel-container position-relative">
                <!-- Кнопка назад -->
                <button class="vertical-carousel-btn vertical-carousel-prev">
                    <i class="fas fa-chevron-left"></i>
                </button>
                
                <!-- Контейнер для карточек -->
                <div class="vertical-carousel-track">
                    <% 
                        // Берем максимум 6 товаров для карусели
                        const carouselProducts = carouselItems.slice(0, 6);
                    %>
                    
                    <% carouselProducts.forEach((item, index) => { %>
                        <% 
                            const originalPrice = parseFloat(item.productPrice) || 0;
                            let finalPrice = originalPrice;
                            let discountApplied = false;
                            let discountPercentage = 0;
                            
                            if (item.is_on_sale && item.discount_percentage > 0) {
                                const now = new Date();
                                const startDate = item.discount_start_date ? new Date(item.discount_start_date) : null;
                                const endDate = item.discount_end_date ? new Date(item.discount_end_date) : null;
                                
                                let isDiscountActive = true;
                                if (startDate && now < startDate) isDiscountActive = false;
                                if (endDate && now > endDate) isDiscountActive = false;
                                
                                if (isDiscountActive) {
                                    discountApplied = true;
                                    discountPercentage = parseFloat(item.discount_percentage) || 0;
                                    finalPrice = originalPrice * (1 - discountPercentage / 100);
                                }
                            }
                        %>
                        
                        <div class="vertical-carousel-card" data-index="<%= index %>">
                            <a href="/product/<%= item.productID %>" class="text-decoration-none">
                                <div class="card h-100 border-0 shadow-sm">
                                    <!-- Бейдж скидки -->
                                    <% if (discountApplied) { %>
                                        <div class="position-absolute top-0 start-0 m-2 z-2">
                                            <span class="badge bg-danger" style="font-size: 0.9rem; padding: 0.5rem 0.8rem;">
                                                -<%= discountPercentage %>%
                                            </span>
                                        </div>
                                    <% } %>
                                    
                                    <!-- Изображение товара -->
                                    <div class="vertical-card-image-container" style="height: 200px; overflow: hidden;">
                                        <img src="/images/products/<%= item.productThumbnail %>" 
                                             class="w-100 h-100 object-fit-contain"
                                             alt="<%= item.productTitle %>"
                                             style="padding: 15px; background-color: white;">
                                    </div>
                                    
                                    <div class="card-body p-3">
                                        <!-- Производитель -->
                                        <small class="text-muted d-block mb-1">
                                            <%= item.productManufacturer %>
                                        </small>
                                        
                                        <!-- Название товара (укороченное) -->
                                        <h6 class="card-title mb-2" style="color: var(--text-dark); font-size: 0.9rem; line-height: 1.3;">
                                            <%= item.productTitle.length > 40 ? 
                                                item.productTitle.substring(0, 40) + '...' : 
                                                item.productTitle %>
                                        </h6>
                                        
                                        <!-- Цены -->
                                        <div class="mt-auto">
                                            <% if (discountApplied) { %>
                                                <div class="d-flex align-items-center justify-content-between">
                                                    <div>
                                                        <span class="text-muted text-decoration-line-through" style="font-size: 0.8rem;">
                                                            <%= originalPrice.toFixed(2) %>₽
                                                        </span>
                                                        <div class="text-danger fw-bold" style="font-size: 1.2rem;">
                                                            <%= finalPrice.toFixed(2) %>₽
                                                        </div>
                                                    </div>
                                                    <% if (session.userId) { %>
                                                        <button class="btn btn-link p-0" 
                                                                type="button"
                                                                onclick="event.preventDefault(); toggleFavorite(event, '<%= item.productID %>')"
                                                                title="<%= session.favorites && session.favorites.includes(item.productID) ? 'Убрать из избранного' : 'Добавить в избранное' %>">
                                                            <i class="fa-heart <%= session.favorites && session.favorites.includes(item.productID) ? 'fas text-danger' : 'far text-muted' %>"></i>
                                                        </button>
                                                    <% } %>
                                                </div>
                                            <% } else { %>
                                                <div class="d-flex align-items-center justify-content-between">
                                                    <div class="text-primary fw-bold" style="font-size: 1.2rem;">
                                                        <%= originalPrice.toFixed(2) %>₽
                                                    </div>
                                                    <% if (session.userId) { %>
                                                        <button class="btn btn-link p-0" 
                                                                type="button"
                                                                onclick="event.preventDefault(); toggleFavorite(event, '<%= item.productID %>')"
                                                                title="<%= session.favorites && session.favorites.includes(item.productID) ? 'Убрать из избранного' : 'Добавить в избранное' %>">
                                                            <i class="fa-heart <%= session.favorites && session.favorites.includes(item.productID) ? 'fas text-danger' : 'far text-muted' %>"></i>
                                                        </button>
                                                    <% } %>
                                                </div>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </a>
                        </div>
                    <% }) %>
                </div>
                
                <!-- Кнопка вперед -->
                <button class="vertical-carousel-btn vertical-carousel-next">
                    <i class="fas fa-chevron-right"></i>
                </button>
                
                <!-- Индикаторы -->
                <div class="vertical-carousel-indicators mt-4">
                    <% for (let i = 0; i < Math.ceil(carouselProducts.length / 3); i++) { %>
                        <button class="vertical-carousel-indicator <%= i === 0 ? 'active' : '' %>" 
                                data-page="<%= i %>"></button>
                    <% } %>
                </div>
            </div>
        <% } %>
    </div>
</section>

<!-- Основной контент -->
<div class="container def-bg-settings">

    <!-- Раздел "Категории" -->
    <section class="categories-section mb-5">
        <h2 class="text-center mb-4" style="color: var(--primary-color); font-weight: 700;">Категории товаров</h2>
        <div class="row g-4">
            <% mainCategories.forEach((category, index) => { %>
                <div class="col-md-3">
                    <a href="/products?search=<%= encodeURIComponent(category.categorieName) %>" 
                    class="text-decoration-none">
                        <div class="card category-card h-100 border-0 shadow-sm hover-lift">
                            <div class="card-body text-center p-4">
                                <div class="category-icon mb-3">
                                    <i class="fas fa-<%= index === 0 ? 'dumbbell' : index === 1 ? 'weight-hanging' : 'weight' %> fa-2x text-white"></i>
                                </div>
                                <h4 class="card-title mb-2" style="color: var(--text-dark);">
                                    <%= category.categorieName %>
                                </h4>
                                <!-- Вернул описания категорий -->
                                <p class="category-description">
                                    <% const descriptions = [
                                        'Диски и блины для штанг всех типов и весов',
                                        'Профессиональные гантели и аксессуары',
                                        'Качественные гири для силовых тренировок'
                                    ]; %>
                                    <%= descriptions[index] || 'Спортивные товары для профессиональных тренировок' %>
                                </p>
                            </div>
                        </div>
                    </a>
                </div>
            <% }) %>
            
            <!-- Карточка "Другие категории" -->
            <div class="col-md-3">
                <a href="/products" class="text-decoration-none">
                    <div class="card other-categories-card h-100">
                        <div class="card-body text-center p-4 d-flex flex-column justify-content-center">
                            <div class="category-icon mb-3">
                                <i class="fas fa-ellipsis-h fa-2x text-white"></i>
                            </div>
                            <h4 class="card-title mb-2" style="color: var(--text-dark);">
                                Другие категории
                            </h4>
                            <p class="category-description">
                                Ещё <%= otherCategoriesCount %> категорий спортивных товаров
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        </div>
    </section>

    <!-- Раздел "Весь каталог" -->
    <section class="catalog-section py-5 mb-4">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-8">
                    <h3 style="color: var(--primary-color); font-weight: 700;">
                        <i class="fas fa-shopping-bag me-2"></i>
                        Весь каталог товаров
                    </h3>
                    <p class="text-muted mb-0">
                        Гантели, гири, диски и аксессуары от проверенных производителей.
                    </p>
                </div>
                <div class="col-md-4 text-end">
                    <a href="/products" class="btn btn-catalog btn-lg px-5 py-3">
                        <i class="fas fa-arrow-right me-2"></i>
                        Перейти в каталог
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Раздел "Товары со скидкой" -->
    <% if (discountedProducts && discountedProducts.length > 0) { %>
    <section class="discounted-catalog-section mb-5">
        <div class="container">
            <a href="/products?sort=discount" class="text-decoration-none">
                <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap">
                    <h2 class="mb-0" style="color: var(--danger-color); font-weight: 700; cursor: pointer;">
                        <i class="fas fa-fire me-2"></i>
                        Горящие скидки
                        <span class="text-muted" style="font-size: 0.9rem; margin-left: 0.5rem;">
                            <i class="fas fa-arrow-right"></i>
                        </span>
                    </h2>
                </div>
            </a>
            
            <div class="row g-4">
                <% discountedProducts.forEach((product) => { %>
                <div class="col-lg-3 col-md-6">
                    <a href="/product/<%= product.productID %>" class="text-decoration-none">
                        <div class="card discounted-card card-clickable">
                            <!-- Бейдж скидки -->
                            <% if (product.isDiscounted) { %>
                            <div class="badge-discount">
                                <i class="fas fa-percentage me-1"></i>
                                -<%= product.discountPercentage %>%
                            </div>
                            <% } %>
                            
                            <!-- Изображение товара -->
                            <img src="/images/products/<%= product.productThumbnail %>" 
                                class="card-img-top" 
                                alt="<%= product.productTitle %>">
                            
                            <div class="card-body">
                                <!-- Категории -->
                                <div class="categories-container mb-2">
                                    <% if (product.categories && product.categories.length > 0) { %>
                                        <% product.categories.forEach((cat, index) => { %>
                                            <% if (index < 3) { %>
                                                <span class="category-badge">
                                                    <%= cat %>
                                                </span>
                                            <% } %>
                                        <% }) %>
                                        <% if (product.categories.length > 3) { %>
                                            <span class="category-badge category-badge-more">
                                                +<%= product.categories.length - 3 %>
                                            </span>
                                        <% } %>
                                    <% } else { %>
                                        <span class="category-badge category-badge-empty">
                                            Без категории
                                        </span>
                                    <% } %>
                                </div>
                                
                                <!-- Название товара -->
                                <h5 class="card-title" style="font-size: 1rem; line-height: 1.4; color: var(--text-dark);">
                                    <%= product.productTitle.length > 60 ? 
                                        product.productTitle.substring(0, 60) + '...' : 
                                        product.productTitle %>
                                </h5>
                                
                                <!-- Рейтинг -->
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rating me-2">
                                        <% for (let j = 0; j < 5; j++) { %>
                                            <span class="star-wrapper" style="font-size: 0.8rem;">
                                                <i class="far fa-star empty-star"></i>
                                                <% if (product.productRating > j) { %>
                                                    <%
                                                        let width = 100;
                                                        if (product.productRating - j < 1) {
                                                            width = (product.productRating - j) * 100;
                                                        }
                                                    %>
                                                    <span class="filled-star" style="width: <%= width %>%">
                                                        <i class="fas fa-star"></i>
                                                    </span>
                                                <% } %>
                                            </span>
                                        <% } %>
                                    </div>
                                    <small class="text-muted">
                                        <%= product.productRating ? product.productRating.toFixed(1) : '0.0' %>
                                    </small>
                                </div>
                                
                                <!-- Цены -->
                                <div class="price-section">
                                    <div class="d-flex align-items-center justify-content-between">
                                        <div class="price-display">
                                            <% if (product.isDiscounted) { %>
                                                <span class="original-price text-muted me-2" style="font-size: 0.9rem;">
                                                    <%= product.originalPrice %>₽
                                                </span>
                                                <h5 class="text-danger mb-0 d-inline">
                                                    <%= product.discountedPrice %>₽  <!-- Используем discountedPrice вместо displayPrice -->
                                                </h5>
                                            <% } else { %>
                                                <h5 class="text-primary mb-0 d-inline"><%= parseFloat(product.productPrice).toFixed(2) %>₽</h5>
                                            <% } %>
                                        </div>
                                        
                                        <!-- Кнопка избранного -->
                                        <% if (session.userId) { %>
                                            <button class="btn btn-link p-0" 
                                                    type="button" 
                                                    title="<%= session.favorites && session.favorites.includes(product.productID) ? 'Убрать из избранного' : 'Добавить в избранное' %>"
                                                    onclick="toggleFavorite(event, '<%= product.productID %>')">
                                                <i class="fa-heart <%= session.favorites && session.favorites.includes(product.productID) ? 'fas text-danger' : 'far text-muted' %>" 
                                                style="font-size: 1.2rem;"></i>
                                            </button>
                                        <% } %>
                                    </div>
                                    <% if (product.isDiscounted) { %>
                                    <div class="mt-2">
                                        <small class="text-success">
                                            <i class="fas fa-piggy-bank me-1"></i>
                                            Экономия <%= (parseFloat(product.originalPrice) - parseFloat(product.discountedPrice)).toFixed(2) %>₽
                                        </small>
                                    </div>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </a>
                </div>
                <% }) %>
            </div>
        </div>
    </section>
    <% } %>

    <!-- Раздел "Товары с лучшими отзывами" -->
    <section class="reviews-section mb-5">
        <div class="container">
            <a href="/products?sort=rating" class="text-decoration-none">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h2 class="mb-0" style="color: #333; font-weight: 700; cursor: pointer;">
                        <i class="fas fa-star text-warning me-2"></i>
                        Товары с лучшими отзывами
                        <span class="text-muted" style="font-size: 0.9rem; margin-left: 0.5rem;">
                            <i class="fas fa-arrow-right"></i>
                        </span>
                    </h2>
                </div>
            </a>
            
            <% if (popularProducts.length === 0) { %>
                <div class="text-center py-5">
                    <i class="fas fa-star fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">Товары с отзывами появятся скоро</h4>
                    <p class="text-muted">Будьте первым, кто оставит отзыв!</p>
                    <a href="/products" class="btn btn-warning">Перейти в каталог</a>
                </div>
            <% } else { %>
                <div class="row g-4">
                    <% 
                        // Ограничиваем до 6 товаров
                        const limitedPopularProducts = popularProducts.slice(0, 8);
                    %>
                    <% limitedPopularProducts.forEach((product) => { %>
                    <div class="col-lg-3 col-md-6">
                        <a href="/product/<%= product.productID %>" class="text-decoration-none">
                            <div class="card review-product-card card-clickable">
                                <!-- Бейдж "Лучшие отзывы" -->
                                <div class="badge-review position-absolute" 
                                     style="top: 10px; left: 10px; z-index: 10;">
                                    <i class="fas fa-star me-1"></i>
                                    Рейтинг: <%= product.productRating ? product.productRating.toFixed(1) : '0.0' %>
                                </div>
                                
                                <!-- Бейдж скидки (если есть) - позиционируем справа вверху -->
                                <% if (product.isDiscounted) { %>
                                <div class="badge-discount position-absolute" 
                                     style="top: 10px; right: 10px; z-index: 10;">
                                    <i class="fas fa-percentage me-1"></i>
                                    -<%= product.discountPercentage %>%
                                </div>
                                <% } %>
                                
                                <!-- Изображение товара -->
                                <img src="/images/products/<%= product.productThumbnail %>" 
                                    class="card-img-top" 
                                    alt="<%= product.productTitle %>">
                                
                                <div class="card-body">
                                    <!-- Категории -->
                                    <div class="categories-container mb-2">
                                        <% if (product.categories && product.categories.length > 0) { %>
                                            <% product.categories.forEach((cat, index) => { %>
                                                <% if (index < 3) { %>
                                                    <span class="category-badge">
                                                        <%= cat %>
                                                    </span>
                                                <% } %>
                                            <% }) %>
                                            <% if (product.categories.length > 3) { %>
                                                <span class="category-badge category-badge-more">
                                                    +<%= product.categories.length - 3 %>
                                                </span>
                                            <% } %>
                                        <% } else { %>
                                            <span class="category-badge category-badge-empty">
                                                Без категории
                                            </span>
                                        <% } %>
                                    </div>
                                    
                                    <!-- Название товара -->
                                    <h5 class="card-title" style="font-size: 1rem; line-height: 1.4; color: var(--text-dark);">
                                        <%= product.productTitle.length > 60 ? 
                                            product.productTitle.substring(0, 60) + '...' : 
                                            product.productTitle %>
                                    </h5>
                                    
                                    <!-- Рейтинг -->
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="rating me-2">
                                            <% for (let j = 0; j < 5; j++) { %>
                                                <span class="star-wrapper" style="font-size: 0.8rem;">
                                                    <i class="far fa-star empty-star"></i>
                                                    <% if (product.productRating > j) { %>
                                                        <%
                                                            let width = 100;
                                                            if (product.productRating - j < 1) {
                                                                width = (product.productRating - j) * 100;
                                                            }
                                                        %>
                                                        <span class="filled-star" style="width: <%= width %>%">
                                                            <i class="fas fa-star"></i>
                                                        </span>
                                                    <% } %>
                                                </span>
                                            <% } %>
                                        </div>
                                        <small class="text-muted">
                                            <%= product.productRating ? product.productRating.toFixed(1) : '0.0' %>
                                        </small>
                                    </div>
                                    
                                    <!-- Производитель -->
                                    <div class="mb-3">
                                        <small class="text-muted">Производитель:</small>
                                        <span class="ms-1 fw-medium"><%= product.productManufacturer %></span>
                                    </div>
                                    
                                    <!-- Цена -->
                                    <div class="price-section">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div class="price-display">
                                                <% if (product.isDiscounted) { %>
                                                    <div class="d-flex flex-column">
                                                        <span class="original-price text-muted text-decoration-line-through mb-1">
                                                            <%= product.originalPrice %>₽
                                                        </span>
                                                        <h5 class="text-danger mb-0">
                                                            <%= product.discountedPrice %>₽
                                                        </h5>
                                                    </div>
                                                <% } else { %>
                                                    <h5 class="text-primary mb-0"><%= parseFloat(product.productPrice).toFixed(2) %>₽</h5>
                                                <% } %>
                                            </div>
                                            
                                            <!-- Кнопка избранного -->
                                            <% if (session.userId) { %>
                                                <button class="btn btn-link p-0" 
                                                        type="button" 
                                                        title="<%= session.favorites && session.favorites.includes(product.productID) ? 'Убрать из избранного' : 'Добавить в избранное' %>"
                                                        onclick="toggleFavorite(event, '<%= product.productID %>')">
                                                    <i class="fa-heart <%= session.favorites && session.favorites.includes(product.productID) ? 'fas text-danger' : 'far text-muted' %>" 
                                                    id="heart-<%= product.productID %>"
                                                    style="font-size: 1.2rem;"></i>
                                                </button>
                                            <% } %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </a>
                    </div>
                    <% }) %>
                </div>
            <% } %>
        </div>
    </section>
</div>


<style>
/* Стили для вертикальной карусели */
.vertical-carousel-container {
    position: relative;
    padding: 0 50px;
}

.vertical-carousel-track {
    display: flex;
    transition: transform 0.5s ease-in-out;
    gap: 20px;
    overflow: hidden;
}

.vertical-carousel-card {
    flex: 0 0 calc(33.333% - 14px); /* 3 карточки минус gap */
    max-width: calc(33.333% - 14px);
    opacity: 1;
    transition: opacity 0.3s ease, transform 0.3s ease;
}

/* Кнопки навигации */
.vertical-carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: white;
    border: 2px solid var(--primary-color);
    color: var(--primary-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.2rem;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 10;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
}

.vertical-carousel-btn:hover {
    background: var(--primary-color);
    color: white;
    transform: translateY(-50%) scale(1.1);
}

.vertical-carousel-prev {
    left: 0;
}

.vertical-carousel-next {
    right: 0;
}

/* Индикаторы */
.vertical-carousel-indicators {
    display: flex;
    justify-content: center;
    gap: 10px;
}

.vertical-carousel-indicator {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #dee2e6;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
}

.vertical-carousel-indicator.active {
    background: var(--primary-color);
    transform: scale(1.2);
}

/* Карточки товаров */
.vertical-card-image-container {
    background: #f8f9fa;
}

/* Адаптивность */
@media (max-width: 992px) {
    .vertical-carousel-card {
        flex: 0 0 calc(50% - 10px);
        max-width: calc(50% - 10px);
    }
    
    .vertical-carousel-container {
        padding: 0 40px;
    }
}

@media (max-width: 768px) {
    .vertical-carousel-card {
        flex: 0 0 calc(100% - 10px);
        max-width: calc(100% - 10px);
    }
    
    .vertical-carousel-container {
        padding: 0 35px;
    }
    
    .vertical-carousel-btn {
        width: 35px;
        height: 35px;
        font-size: 1rem;
    }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const verticalCarousel = document.querySelector('.vertical-carousel-container');
    if (!verticalCarousel) return;
    
    const track = verticalCarousel.querySelector('.vertical-carousel-track');
    const cards = verticalCarousel.querySelectorAll('.vertical-carousel-card');
    const prevBtn = verticalCarousel.querySelector('.vertical-carousel-prev');
    const nextBtn = verticalCarousel.querySelector('.vertical-carousel-next');
    const indicators = verticalCarousel.querySelectorAll('.vertical-carousel-indicator');
    
    // Если карточек меньше 3, скрываем карусель
    if (cards.length <= 3) {
        verticalCarousel.style.display = 'none';
        return;
    }
    
    let currentPosition = 0;
    const cardsPerView = 3;
    const totalCards = cards.length;
    const totalPages = Math.ceil(totalCards / cardsPerView);
    
    // Функция обновления позиции
    function updatePosition() {
        // Скрываем все карточки
        cards.forEach(card => {
            card.style.opacity = '0.5';
            card.style.transform = 'scale(0.95)';
        });
        
        // Показываем только видимые карточки
        for (let i = 0; i < cardsPerView; i++) {
            const cardIndex = (currentPosition + i) % totalCards;
            cards[cardIndex].style.opacity = '1';
            cards[cardIndex].style.transform = 'scale(1)';
        }
        
        // Обновляем индикаторы
        const currentPage = Math.floor(currentPosition / cardsPerView);
        indicators.forEach((indicator, index) => {
            indicator.classList.toggle('active', index === currentPage);
        });
    }
    
    // Следующий слайд
    function nextSlide() {
        currentPosition = (currentPosition + 1) % totalCards;
        updatePosition();
    }
    
    // Предыдущий слайд
    function prevSlide() {
        currentPosition = (currentPosition - 1 + totalCards) % totalCards;
        updatePosition();
    }
    
    // Переход к конкретной странице
    function goToPage(page) {
        currentPosition = page * cardsPerView;
        updatePosition();
    }
    
    // Инициализация
    function initVerticalCarousel() {
        // Показываем первые 3 карточки
        updatePosition();
        
        // Обработчики кнопок
        if (prevBtn) {
            prevBtn.addEventListener('click', prevSlide);
        }
        
        if (nextBtn) {
            nextBtn.addEventListener('click', nextSlide);
        }
        
        // Обработчики индикаторов
        indicators.forEach((indicator, index) => {
            indicator.addEventListener('click', () => {
                goToPage(index);
            });
        });
        
        // Автоматическое переключение
        let autoSlideInterval = setInterval(nextSlide, 5000);
        
        // Пауза при наведении
        verticalCarousel.addEventListener('mouseenter', () => {
            clearInterval(autoSlideInterval);
        });
        
        verticalCarousel.addEventListener('mouseleave', () => {
            autoSlideInterval = setInterval(nextSlide, 5000);
        });
        
        // Клавиатурная навигация
        document.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowLeft') {
                prevSlide();
                clearInterval(autoSlideInterval);
            } else if (e.key === 'ArrowRight') {
                nextSlide();
                clearInterval(autoSlideInterval);
            }
        });
    }
    
    // Запускаем карусель
    initVerticalCarousel();
    
    // Предзагрузка изображений для предотвращения прыжков
    function preloadImages() {
        const images = verticalCarousel.querySelectorAll('img');
        images.forEach(img => {
            const image = new Image();
            image.src = img.src;
        });
    }
    
    // Ресайз для одинаковой высоты изображений
    function resizeImages() {
        const imageContainers = verticalCarousel.querySelectorAll('.vertical-card-image-container');
        if (imageContainers.length === 0) return;
        
        // Находим максимальную высоту
        let maxHeight = 0;
        imageContainers.forEach(container => {
            const img = container.querySelector('img');
            if (img && img.naturalHeight) {
                // Рассчитываем высоту с учетом пропорций
                const containerWidth = container.offsetWidth;
                const aspectRatio = img.naturalWidth / img.naturalHeight;
                const calculatedHeight = containerWidth / aspectRatio;
                
                if (calculatedHeight > maxHeight) {
                    maxHeight = calculatedHeight;
                }
            }
        });
        
        // Устанавливаем высоту
        if (maxHeight > 0) {
            imageContainers.forEach(container => {
                container.style.height = Math.min(maxHeight, 250) + 'px';
            });
        }
    }
    
    // Предзагружаем и ресайзим
    setTimeout(() => {
        preloadImages();
        resizeImages();
    }, 100);
    
    window.addEventListener('resize', resizeImages);
});
</script>