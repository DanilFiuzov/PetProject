
<div class="container bg-light"> 
    <div class="row">
        <% i=0 %>
        <% games.forEach(game => { %>
        <div class="col-3">
            <div class="card cards w-60 mt-4 shadow-sm bordered_1" style="height: 550px;">
                <img src="<%= games[i].gameImage %>" alt="<%= games[i].gameTitle %>" class="card-img-top">
                <div class="card-body" style="padding-bottom: 0 !important;">
                <div class="d-flex justify-content-between align-items-center">
                    <h4 class="mb-0"><%= games[i].gameTitle %></h4>
                </div>
                    <div class="d-flex justify-content-between align-items-center">
                        
                    </div>
                    <div class="text-truncate-container">
                    <p>
                        <%= games[i].gameDescription %>       
                    </p>
                    </div>                      
                </div> 
                <div class="card-footer">
                    <form action="/game/<%= games[i].gameID %>" method="get">
                        <button class="btn btn-primary" type="submit">
                            Играть
                        </button>
                    </form>
                    <form action="/delete/<%= games[i].gameID %>" method="post">
                        <button type="submit">
                            Удалить
                        </button>
                    </form>
                </div>           
            </div>
            </div>
            <% i++ %>
        <% }) %>
        <% if (typeof session.userId !== 'undefined') { %>
            <form action="/add" method="get">
                <button type="submit">Добавить</button>
            </form>
        <% } %>
    </div>
</div>