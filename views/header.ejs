<nav class="navbar navbar-expand-lg sticky-top header-navbar">
    <div class="container-fluid">
        <!-- Логотип и название сайта -->
        <a class="navbar-brand site-logo" href="/">
            <h3><b>SportI</b></h3>
        </a>
        
        <!-- Кнопка меню для мобильных устройств -->
        <button class="navbar-toggler custom-toggler" type="button" data-bs-toggle="collapse" 
                data-bs-target="#mainNavbarContent" aria-controls="mainNavbarContent" 
                aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Основное меню -->
        <div class="collapse navbar-collapse" id="mainNavbarContent">
            <ul class="navbar-nav me-auto">
                <!-- Каталог -->
                <li class="nav-item">
                    <a class="nav-link" style="font-size: 20px;" href="/products">
                        <i class="fas fa-store me-1"></i>
                        Каталог
                    </a>
                </li>
                <!-- Категории -->
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle" style="font-size: 20px;" href="#" id="categoriesDropdown" 
                    role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        <i class="fas fa-list me-2"></i>
                        Категории
                    </a>
                    <ul class="dropdown-menu dropdown-menu-custom" aria-labelledby="categoriesDropdown">
                        <% if (categoriesMenu && categoriesMenu.length) { %>
                            <% categoriesMenu.forEach(cat => { %>
                                <li>
                                    <a class="dropdown-item" href="/products?category=<%= cat.categorieID %>">
                                        <% if (cat.categorieThumbnail) { %>
                                            <img src="/images/categories/<%= cat.categorieThumbnail %>" 
                                                alt="<%= cat.categorieName %>" class="cat-dropdown-icon">
                                        <% } else { %>
                                            <i class="fas fa-folder-open me-2"></i>
                                        <% } %>
                                        <%= cat.categorieName %>
                                        <span class="badge bg-secondary float-end"><%= cat.productCount || 0 %></span>
                                    </a>
                                </li>
                            <% }) %>
                        <% } else { %>
                            <li><span class="dropdown-item disabled">Нет категорий</span></li>
                        <% } %>
                    </ul>
                </li>
            </ul>
            
            <!-- Правая часть навигации -->
            <div class="d-flex align-items-center">
                <% if (session.userId) { %>
                    <!-- Иконка корзины для десктопа -->
                    <div class="nav-cart-desktop me-3 d-none d-lg-block">
                        <a href="/cart/<%= session.userId %>" class="nav-icon-link position-relative">
                            <i class="fas fa-shopping-cart fa-lg"></i>
                            <% if (session.cartCount && session.cartCount > 0) { %>
                                <span class="nav-badge"><%= session.cartCount %></span>
                            <% } %>
                        </a>
                    </div>
                    
                    <!-- Иконка избранного для десктопа -->
                    <div class="nav-favorites-desktop me-3 d-none d-lg-block">
                        <a href="/favorites" class="nav-icon-link position-relative">
                            <i class="fas fa-heart fa-lg"></i>
                            <% if (session.favorites && session.favorites.length > 0) { %>
                                <span class="nav-badge"><%= session.favorites.length %></span>
                            <% } %>
                        </a>
                    </div>
                    
                    <!-- Выпадающее меню пользователя -->
                    <div class="dropdown user-dropdown">
                        <button class="btn dropdown-toggle user-dropdown-toggle" type="button" 
                                id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="<%= session.userThumbnail || '/images/Avatars/default-avatar.png' %>" 
                                 alt="Аватар" class="user-avatar-sm rounded-circle me-2">
                            <span class="d-none d-md-inline"><%= session.userName %></span>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end user-dropdown-menu" 
                            aria-labelledby="userDropdown">
                            <!-- Информация о пользователе -->
                            <li class="dropdown-header user-info">
                                <img src="<%= session.userThumbnail || '/images/Avatars/default-avatar.png' %>" 
                                     alt="Аватар" class="user-avatar-lg rounded-circle mb-2">
                                <h6 class="mb-0"><%= session.userName %></h6>
                                <small class="text-muted"><%= session.userEmail %></small>
                                <% if (session.userRank === 'admin') { %>
                                    <span class="user-badge-admin">ADMIN</span>
                                <% } %>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            
                            <!-- Аккаунт -->
                            <li>
                                <a class="dropdown-item" href="/acc_page">
                                    <i class="fas fa-user-circle me-2"></i>
                                    Мой аккаунт
                                </a>
                            </li>

                            <!-- Мои заказы -->
                            <li>
                                <a class="dropdown-item" href="/my-orders">
                                    <i class="fas fa-shopping-bag me-2"></i>
                                    Мои заказы
                                </a>
                            </li>
                            
                            <!-- Корзина (для мобильных) -->
                            <li class="d-lg-none">
                                <a class="dropdown-item" href="/cart/<%= session.userId %>">
                                    <i class="fas fa-shopping-cart me-2"></i>
                                    Корзина
                                    <% if (session.cartCount && session.cartCount > 0) { %>
                                        <span class="badge bg-primary float-end"><%= session.cartCount %></span>
                                    <% } %>
                                </a>
                            </li>
                            
                            <!-- Избранное (для мобильных) -->
                            <li class="d-lg-none">
                                <a class="dropdown-item" href="/favorites">
                                    <i class="fas fa-heart me-2"></i>
                                    Избранное
                                    <% if (session.favorites && session.favorites.length > 0) { %>
                                        <span class="badge bg-danger float-end"><%= session.favorites.length %></span>
                                    <% } %>
                                </a>
                            </li>
                            
                            <!-- Админ-панель -->
                            <% if (session.userRank === 'admin') { %>
                                <li><hr class="dropdown-divider"></li>
                                <li class="dropdown-header" style="padding: 0.75rem;">
                                    <h5>Администрирование</h5>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/admin/add-product">
                                        <i class="fas fa-plus-circle me-2"></i>
                                        Добавить товар
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" href="/admin/products">
                                        <i class="fas fa-boxes me-2"></i>
                                        Управление товарами
                                    </a>
                                </li>
                            <% } %>
                            
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" href="/logout">
                                    <i class="fas fa-sign-out-alt me-2"></i>
                                    Выйти
                                </a>
                            </li>
                        </ul>
                    </div>
                <% } else { %>
                    <!-- Кнопки для неавторизованных пользователей -->
                    <div class="auth-buttons">
                        <a class="btn btn-outline-light btn-sm me-2" href="/login">
                            <i class="fas fa-sign-in-alt me-1"></i>
                            Войти
                        </a>
                        <a class="btn btn-light btn-sm" href="/register">
                            <i class="fas fa-user-plus me-1"></i>
                            Регистрация
                        </a>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</nav>