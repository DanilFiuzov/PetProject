<!-- Хлебные крошки -->
<nav aria-label="breadcrumb" class="breadcrumb-container">
	<div class="container">
		<ol class="breadcrumb bg-light p-3 rounded-3">
			<li class="breadcrumb-item">
				<a href="/" class="text-decoration-none text-primary">
					<i class="fas fa-home me-1"></i>Главная
				</a>
			</li>
			<li class="breadcrumb-item active" aria-current="page">Каталог товаров</li>
		</ol>
	</div>
</nav>

<!-- ЦЕНТРАЛЬНЫЙ КОМПАКТНЫЙ ПОИСК -->
<div class="central-search-wrapper">
	<div class="central-search-inner">
		<form method="GET" action="/products" id="centralSearchForm" class="central-search-form">
			<div class="input-group">
				<span class="input-group-text">
					<i class="fas fa-search"></i>
				</span>
				<input type="text"
					class="form-control"
					name="search"
					id="centralSearchInput"
					placeholder="Поиск товаров..."
					value="<%= searchQuery || '' %>"
					autocomplete="off">
				<button class="btn btn-search" type="submit">
					<i class="fas fa-search"></i>
				</button>
			</div>
		</form>
		<div id="centralSearchSuggestions" class="search-suggestions-container"></div>
	</div>
</div>

<!-- Оверлей для мобильного меню -->
<div class="mobile-overlay" onclick="closeFilters()"></div>

<!-- Оборачиваем весь контент в центральный контейнер -->
<div class="container-fluid def-bg-settings py-4">
	<div class="row">
		<button class="mobile-filters-btn" onclick="toggleFilters()">
			<i class="fas fa-filter"></i>
			<span>Фильтры</span>
		</button>

		<!-- Боковая панель с фильтрами -->
		<div class="col-lg-3 col-lg-3-search col-md-4 filters-sidebar">
			<div class="card border-0 shadow-sm rounded-3 sticky-sidebar no-hover">
				<div class="card-body p-4">
					<!-- Сортировка - КАСТОМНЫЙ ВЫПАДАЮЩИЙ СПИСОК -->
					<h5 class="fw-bold mb-3 text-primary">
						<i class="fas fa-sort me-2"></i>Сортировка
					</h5>
					<div class="custom-select-wrapper mb-3">
						<div class="custom-select" id="sortDropdown" tabindex="0">
							<div class="custom-select-selected" id="sortSelected">
								<%
								const sortOptions = {
									'newest': 'Сначала новые',
									'name_asc': 'По названию (А-Я)',
									'name_desc': 'По названию (Я-А)',
									'price_asc': 'По цене (дешевле)',
									'price_desc': 'По цене (дороже)',
									'rating': 'По рейтингу',
									'discount': 'По скидке',
									'stock_asc': 'По наличию (меньше)',
									'stock_desc': 'По наличию (больше)'
								};
								// Выбираем текст для текущего значения
								const selectedText = sortOptions[sort] || 'Сначала новые';
								%>
								<%= selectedText %>
							</div>
							<div class="custom-select-arrow">
								<i class="fas fa-chevron-down"></i>
							</div>
							<div class="custom-select-options" id="sortOptions">
								<div class="custom-select-option <%= sort === 'newest' ? 'active' : '' %>" data-value="newest">
									Сначала новые
								</div>
								<div class="custom-select-option <%= sort === 'name_asc' ? 'active' : '' %>" data-value="name_asc">
									По названию (А-Я)
								</div>
								<div class="custom-select-option <%= sort === 'name_desc' ? 'active' : '' %>" data-value="name_desc">
									По названию (Я-А)
								</div>
								<div class="custom-select-option <%= sort === 'price_asc' ? 'active' : '' %>" data-value="price_asc">
									По цене (дешевле)
								</div>
								<div class="custom-select-option <%= sort === 'price_desc' ? 'active' : '' %>" data-value="price_desc">
									По цене (дороже)
								</div>
								<div class="custom-select-option <%= sort === 'rating' ? 'active' : '' %>" data-value="rating">
									По рейтингу
								</div>
								<div class="custom-select-option <%= sort === 'discount' ? 'active' : '' %>" data-value="discount">
									По скидке
								</div>
								<div class="custom-select-option <%= sort === 'stock_asc' ? 'active' : '' %>" data-value="stock_asc">
									По наличию (меньше)
								</div>
								<div class="custom-select-option <%= sort === 'stock_desc' ? 'active' : '' %>" data-value="stock_desc">
									По наличию (больше)
								</div>
							</div>
						</div>
						<input type="hidden" name="sort" id="sortHidden" value="<%= sort || 'newest' %>">
					</div>

					<!-- Фильтр по цене -->
					<h5 class="fw-bold mb-3 text-primary mt-4">
						<i class="fas fa-tag me-2"></i>Цена
					</h5>
					<div class="price-range-container">
						<!-- Слайдер будет инициализирован через JavaScript -->
					</div>

					<!-- Категории -->
					<h5 class="fw-bold mb-3 text-primary mt-4">
						<i class="fas fa-list me-2"></i>Категории
						<button class="btn btn-sm btn-link text-primary p-0 ms-2"
							type="button"
							onclick="toggleCategories()"
							id="toggleCategoriesBtn"
							aria-expanded="true">
							<i class="fas fa-chevron-down ms-1" id="categoriesToggleIcon" style="font-size: 2vh;"></i>
						</button>
					</h5>
					<div class="categories-filter mb-3 d-none" id="categoriesFilterContainer">
						<div class="categories-list" id="categoriesList">
							<%
							// Парсим строку категорий в массив для правильной проверки
							const selectedCategories = category ? category.toString().split(',').filter(id => id.trim() !== '') : [];
							%>
							<% allCategories.forEach(cat => { %>
							<div class="form-check category-item" data-category-id="<%= cat.categorieID %>">
								<input class="form-check-input"
									type="checkbox"
									id="category_<%= cat.categorieID %>"
									value="<%= cat.categorieID %>"
									<%= selectedCategories.includes(cat.categorieID.toString()) ? 'checked' : '' %>
									onchange="updateCategoryFilter()">
								<label class="form-check-label" for="category_<%= cat.categorieID %>">
									<%= cat.categorieName %>
								</label>
							</div>
							<% }) %>
						</div>
						<div class="categories-footer d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
							<button class="btn btn-sm btn-outline-primary"
								type="button"
								onclick="clearCategories()">
								<i class="fas fa-times me-1"></i>
							</button>
							<span class="text-muted small" id="selectedCategoriesCount">
								Выбрано: <span class="fw-bold"><%= selectedCategories.length %></span>
							</span>
						</div>
					</div>
					<input type="hidden" name="category" id="categoriesHidden" value="<%= category || '' %>">

					<!-- Акционные товары -->
					<div class="form-check mb-3">
						<input class="form-check-input"
							type="checkbox"
							name="onSale"
							id="onSale"
							value="true"
							<%= onSale ? 'checked' : '' %>>
						<label class="form-check-label" for="onSale">
							<i class="fas fa-fire text-danger me-1"></i>Только акционные товары
						</label>
					</div>

                    <!-- Фильтр по наличию -->
                    <div class="form-check mb-3">
                        <input class="form-check-input"
                            type="checkbox"
                            name="inStock"
                            id="inStock"
                            value="true"
                            <%= inStock ? 'checked' : '' %>>
                        <label class="form-check-label" for="inStock">
                            <i class="fas fa-check-circle text-success me-1"></i>Только в наличии
                        </label>
                    </div>

					<!-- Кнопка "Применить фильтры" -->
					<button class="btn apply-filters-btn" onclick="applyFiltersLocal()">
						<i class="fas fa-check-circle me-2"></i>Применить фильтры
					</button>

					<!-- Информация о результатах -->
					<div class="mt-4 pt-3 border-top">
						<div class="d-flex justify-content-between align-items-center mb-2">
							<span class="text-muted">Найдено:</span>
							<span class="fw-bold"><%= totalProducts || 0 %> товаров</span>
						</div>
						<% if (searchQuery || category || onSale || inStock) { %>
						<div class="alert alert-info border-0 bg-primary bg-opacity-10 text-primary small p-2 rounded-2">
							<i class="fas fa-filter me-1"></i>
							Применены фильтры
							<a href="/products" class="text-primary fw-bold ms-2">
								<i class="fas fa-times"></i> Сбросить
							</a>
						</div>
						<% } %>
					</div>
				</div>
			</div>
		</div>

		<!-- Основной контент каталога -->
		<div class="col-lg-9 col-lg-9-products col-md-8 catalog-main-content">
			<div class="d-flex justify-content-between align-items-center mb-4">
				<h1 class="h3 fw-bold mb-0">
					<i class="fas fa-shopping-bag text-primary me-2"></i>
					Каталог товаров
					<% if (category && allCategories.find(c => c.categorieID == category)) { %>
					<span class="text-muted fs-5 ms-2">
						/ <%= allCategories.find(c => c.categorieID == category).categorieName %>
					</span>
					<% } %>
				</h1>
				<div class="text-muted small">
					Страница <%= currentPage %> из <%= totalPages %>
				</div>
			</div>

			<% if (products.length === 0) { %>
			<div class="card border-0 shadow-sm rounded-3">
				<div class="card-body text-center py-5">
					<div class="empty-icon mb-4">
						<i class="fas fa-search fa-4x text-muted opacity-50"></i>
					</div>
					<h4 class="text-muted mb-3">Товары не найдены</h4>
					<p class="text-muted mb-4">Попробуйте изменить поисковый запрос или параметры фильтрации</p>
					<a href="/products" class="btn btn-primary px-4 py-2">
						<i class="fas fa-times me-2"></i>Сбросить фильтры
					</a>
				</div>
			</div>
			<% } else { %>
			<!-- Список товаров в горизонтальных карточках -->
			<div class="products-list">
				<% products.forEach((product) => { %>
				<div class="horizontal-product-card <%= product.stock_quantity <= 0 ? 'out-of-stock' : '' %>"
					data-product-id="<%= product.productID %>"
					data-stock-quantity="<%= product.stock_quantity %>">

					<!-- Изображение -->
					<div class="product-image position-relative">
						<a href="/product/<%= product.productID %>" class="text-decoration-none">
							<img src="/images/products/<%= product.productThumbnail %>"
								alt="<%= product.productTitle %>">
						</a>

						<!-- Бейджи на изображении -->
						<div class="image-badges">
							<% if (product.isDiscounted) { %>
							<div class="badge-discount-horizontal">
								<i class="fas fa-percentage me-1"></i>
								-<%= product.discountPercentage %>%
							</div>
							<% } %>

							<!-- Бейдж "Нет в наличии" -->
							<% if (product.stock_quantity <= 0) { %>
							<div class="out-of-stock-overlay">
								<div class="out-of-stock-badge">
									SOLD
								</div>
							</div>
							<% } %>
						</div>

						<!-- Кнопка избранного -->
						<% if (session.userId) { %>
							<%
							const productIdNum = parseInt(product.productID);
							const isFavorited = session.favorites && session.favorites.some(favId => parseInt(favId) === productIdNum);
							%>
							<button class="btn btn-light btn-sm favorite-btn rounded-circle"
								onclick="toggleFavorite(event, <%= product.productID %>)"
								title="<%= isFavorited ? 'Убрать из избранного' : 'Добавить в избранное' %>"
								style="position: absolute; right: 10px; z-index: 2;">
								<i class="<%= isFavorited ? 'fas fa-heart text-danger' : 'far fa-heart' %>"></i>
							</button>
						<% } %>
					</div>

					<!-- Заголовок и мета-информация -->
					<div style="padding: 1vh;">
						<h5 class="product-title">
							<a href="/product/<%= product.productID %>">
								<%= product.productTitle %>
							</a>
						</h5>

						<!-- Категории - НОВАЯ СТРОКА -->
						<% if (product.categories && product.categories.length > 0) { %>
						<div class="categories-container">
							<% product.categories.slice(0, 3).forEach((cat) => { %>
							<span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
								<%= cat %>
							</span>
							<% }) %>
							<% if (product.categories.length > 3) { %>
							<span class="badge bg-light text-muted border">
								+<%= product.categories.length - 3 %>
							</span>
							<% } %>
						</div>
						<% } %>

						<!-- Производитель -->
						<div class="manufacturer">
							<i class="fas fa-industry me-1"></i><%= product.productManufacturer %>
						</div>

						<!-- Рейтинг -->
						<div class="product-rating">
							<div class="rating">
								<% for (let j = 0; j < 5; j++) { %>
								<span class="star-wrapper position-relative">
									<i class="far fa-star text-muted"></i>
									<% if (product.productRating > j) { %>
										<%
										let width = 100;
										if (product.productRating - j < 1) {
											width = (product.productRating - j) * 100;
										}
										%>
										<span class="position-absolute top-0 start-0 overflow-hidden" style="width: <%= width %>%">
											<i class="fas fa-star text-warning"></i>
										</span>
									<% } %>
								</span>
								<% } %>
							</div>
							<span class="text-muted small">
								<%= product.productRating ? product.productRating.toFixed(1) : '0.0' %>
							</span>
						</div>

						<!-- Описание -->
						<p class="product-description">
							<%
							const description = product.productDescription || '';
							const maxLength = 120;
							if (description.length > maxLength) {
							%>
								<%= description.substring(0, maxLength) %>...
							<% } else { %>
								<%= description %>
							<% } %>
						</p>
					</div>

					<!-- Правая часть с ценой и кнопками -->
					<div class="product-actions">
						<div class="price-container">
							<% if (product.isDiscounted) { %>
							<div class="current-price discount-price-new">
								<%= parseFloat(product.discountedPrice || product.displayPrice).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') %>₽
							</div>
							<div class="original-price">
								<%= parseFloat(product.originalPrice || product.productPrice).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') %>₽
							</div>
							<% } else { %>
							<div class="current-price">
								<%= parseFloat(product.displayPrice || product.productPrice).toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ' ') %>₽
							</div>
							<% } %>

							<!-- Индикатор наличия -->
							<% if (product.stock_quantity <= 0) { %>
							<div class="stock-indicator text-danger mt-2">
								<i class="fas fa-times-circle me-1"></i>Нет в наличии
							</div>
							<% } else if (product.stock_quantity <= 5) { %>
							<div class="stock-indicator text-warning mt-2">
								<i class="fas fa-exclamation-triangle me-1"></i>Осталось <%= product.stock_quantity %> шт.
							</div>
							<% } else { %>
							<div class="stock-indicator text-success mt-2">
								<i class="fas fa-check-circle me-1"></i>В наличии
							</div>
							<% } %>
						</div>

						<div class="action-buttons">
							<% if (product.stock_quantity <= 0) { %>
							<!-- Товара нет в наличии -->
							<button class="btn btn-outline-secondary btn-sm" disabled>
								<i class="fas fa-times me-1"></i>Нет в наличии
							</button>
							<% } else if (session.userId) { %>
							<!-- Товар в наличии, пользователь авторизован -->
							<button class="btn btn-custom btn-sm"
								onclick="addToCart('<%= product.productID %>')">
								<i class="fas fa-shopping-cart me-1"></i>Купить
							</button>
							<% } else { %>
							<!-- Товар в наличии, пользователь не авторизован -->
							<a href="/login" class="btn btn-custom btn-sm">
								<i class="fas fa-sign-in-alt me-1"></i>Войти
							</a>
							<% } %>

							<a href="/product/<%= product.productID %>"
								class="btn btn-outline-custom btn-sm">
								<i class="fas fa-eye me-1"></i>Подробнее
							</a>
						</div>
					</div>
				</div>
				<% }) %>
			</div>

			<!-- Пагинация -->
			<% if (totalPages > 1) { %>
			<nav aria-label="Навигация по страницам" class="mt-4">
				<ul class="pagination justify-content-center">
					<!-- Назад -->
					<li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
						<a class="page-link border-0 rounded-circle mx-1"
							href="?<%= new URLSearchParams({
								search: searchQuery || '',
								category: category || '',
								minPrice: minPrice || '',
								maxPrice: maxPrice || '',
								onSale: onSale ? 'true' : '',
								inStock: inStock ? 'true' : '',
								sort: sort || '',
								page: currentPage - 1
							}) %>">
							<i class="fas fa-chevron-left"></i>
						</a>
					</li>

					<!-- Страницы -->
					<% for (let i = 1; i <= totalPages; i++) { %>
						<% if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
						<li class="page-item <%= i === currentPage ? 'active' : '' %>">
							<a class="page-link border-0 rounded-circle mx-1"
								href="?<%= new URLSearchParams({
									search: searchQuery || '',
									category: category || '',
									minPrice: minPrice || '',
									maxPrice: maxPrice || '',
									onSale: onSale ? 'true' : '',
									inStock: inStock ? 'true' : '',
									sort: sort || '',
									page: i
								}) %>">
								<%= i %>
							</a>
						</li>
						<% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
						<li class="page-item disabled">
							<span class="page-link border-0 rounded-circle mx-1">...</span>
						</li>
						<% } %>
					<% } %>

					<!-- Вперед -->
					<li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
						<a class="page-link border-0 rounded-circle mx-1"
							href="?<%= new URLSearchParams({
								search: searchQuery || '',
								category: category || '',
								minPrice: minPrice || '',
								maxPrice: maxPrice || '',
								onSale: onSale ? 'true' : '',
								inStock: inStock ? 'true' : '',
								sort: sort || '',
								page: currentPage + 1
							}) %>">
							<i class="fas fa-chevron-right"></i>
						</a>
					</li>
				</ul>
			</nav>
			<% } %>
			<% } %>
		</div>
	</div>
</div>

<script>
    // ========== ЛОКАЛЬНЫЕ ПЕРЕМЕННЫЕ ==========
    var localMinPrice = <%= minPrice %>;
    var localMaxPrice = <%= maxPrice %>;
    var localSliderMin = <%= sliderMin %>;
    var localSliderMax = <%= sliderMax %>;
    var localStep = 100;                     // <-- переименовано, чтобы не конфликтовать с script.js

    // ========== ЛОКАЛЬНАЯ ФУНКЦИЯ ПРИМЕНЕНИЯ ФИЛЬТРОВ ==========
    function applyFiltersLocal() {
        var search = document.querySelector('#centralSearchInput')?.value || '';
        var category = document.getElementById('categoriesHidden')?.value || '';
        var minPrice = document.getElementById('minPriceHidden')?.value || localSliderMin.toString();
        var maxPrice = document.getElementById('maxPriceHidden')?.value || localSliderMax.toString();
        var onSale = document.getElementById('onSale')?.checked ? 'true' : '';
        var inStock = document.getElementById('inStock')?.checked ? 'true' : '';
        var sort = document.getElementById('sortHidden')?.value || '';

        var params = new URLSearchParams();
        if (search) params.set('search', search);
        if (category) params.set('category', category);
        if (minPrice !== localSliderMin.toString()) params.set('minPrice', minPrice);
        if (maxPrice !== localSliderMax.toString()) params.set('maxPrice', maxPrice);
        if (onSale) params.set('onSale', onSale);
        if (inStock) params.set('inStock', inStock);
        if (sort) params.set('sort', sort);

        window.location.href = '/products?' + params.toString();
    }

    // ========== ЛОКАЛЬНЫЙ СЛАЙДЕР (полная копия, но на локальных переменных) ==========
    function initPriceSliderLocal() {
        var container = document.querySelector('.price-range-container');
        if (!container) return;

        // Генерируем HTML слайдера
        var html = `<div class="price-range-values">
            <span id="minValueDisplay">${localMinPrice.toLocaleString()}₽</span>
            <span id="maxValueDisplay">${localMaxPrice.toLocaleString()}₽</span>
        </div>
        <div class="price-slider" id="priceSlider">
            <div class="slider-thumb min" id="minThumb"></div>
            <div class="slider-thumb max" id="maxThumb"></div>
        </div>
        <div class="price-inputs">
            <div class="price-input-wrapper">
                <span class="price-input-badge">От</span>
                <input type="number" class="price-input" id="minPriceInput" value="${localMinPrice}" min="${localSliderMin}" max="${localSliderMax}" step="${localStep}">
            </div>
            <div class="price-input-wrapper">
                <span class="price-input-badge">До</span>
                <input type="number" class="price-input" id="maxPriceInput" value="${localMaxPrice}" min="${localSliderMin}" max="${localSliderMax}" step="${localStep}">
            </div>
        </div>
        <input type="hidden" id="minPriceHidden" value="${localMinPrice}">
        <input type="hidden" id="maxPriceHidden" value="${localMaxPrice}">`;

        container.innerHTML = html;

        var minThumb = document.getElementById('minThumb');
        var maxThumb = document.getElementById('maxThumb');
        var minInput = document.getElementById('minPriceInput');
        var maxInput = document.getElementById('maxPriceInput');
        var slider = document.getElementById('priceSlider');
        var minHidden = document.getElementById('minPriceHidden');
        var maxHidden = document.getElementById('maxPriceHidden');

        function updateSlider() {
            // Расчёт процентов с защитой от выхода за границы
            var minPerc = ((localMinPrice - localSliderMin) / (localSliderMax - localSliderMin)) * 100;
            var maxPerc = ((localMaxPrice - localSliderMin) / (localSliderMax - localSliderMin)) * 100;
            // Обрезаем от 0 до 100
            minPerc = Math.min(100, Math.max(0, minPerc));
            maxPerc = Math.min(100, Math.max(0, maxPerc));

            if (slider) {
                slider.style.setProperty('--min-percentage', minPerc + '%');
                slider.style.setProperty('--max-percentage', maxPerc + '%');
            }
            // Позиционируем ползунки с центрированием (transform для точного попадания)
            if (minThumb) {
                minThumb.style.left = minPerc + '%';
                minThumb.style.transform = 'translate(-50%, -50%)';  // центрируем
            }
            if (maxThumb) {
                maxThumb.style.right = (100 - maxPerc) + '%';
                maxThumb.style.transform = 'translate(50%, -50%)';   // центрируем для right
            }
        }
        updateSlider();

        function startDrag(e, type) {
            e.preventDefault();
            var isTouch = e.type === 'touchstart';
            var startX = isTouch ? e.touches[0].clientX : e.clientX;
            var startValue = type === 'min' ? localMinPrice : localMaxPrice;
            var thumb = e.target.closest('.slider-thumb');
            if (thumb) thumb.classList.add('active');
            if (slider) slider.style.transition = 'none';

            function handleMove(e) {
                e.preventDefault();
                var currentX = isTouch ? e.touches[0].clientX : e.clientX;
                var deltaX = currentX - startX;
                var sliderWidth = slider.offsetWidth;
                var pixelsPerStep = (sliderWidth / (localSliderMax - localSliderMin)) * localStep;
                var newValue = startValue + Math.round(deltaX / pixelsPerStep) * localStep;

                if (type === 'min') {
                    newValue = Math.max(localSliderMin, Math.min(newValue, localMaxPrice - localStep));
                    localMinPrice = newValue;
                    if (minInput) minInput.value = newValue;
                    if (minHidden) minHidden.value = newValue;
                } else {
                    newValue = Math.min(localSliderMax, Math.max(newValue, localMinPrice + localStep));
                    localMaxPrice = newValue;
                    if (maxInput) maxInput.value = newValue;
                    if (maxHidden) maxHidden.value = newValue;
                }
                updateSlider();
            }

            function handleEnd() {
                document.removeEventListener('mousemove', handleMove);
                document.removeEventListener('mouseup', handleEnd);
                document.removeEventListener('touchmove', handleMove, { passive: false });
                document.removeEventListener('touchend', handleEnd);
                document.removeEventListener('touchcancel', handleEnd);
                if (thumb) thumb.classList.remove('active');
                if (slider) slider.style.transition = 'background 0.1s ease';
            }

            document.addEventListener('mousemove', handleMove);
            document.addEventListener('mouseup', handleEnd);
            document.addEventListener('touchmove', handleMove, { passive: false });
            document.addEventListener('touchend', handleEnd);
            document.addEventListener('touchcancel', handleEnd);
        }

        minThumb.addEventListener('mousedown', function(e) { startDrag(e, 'min'); });
        minThumb.addEventListener('touchstart', function(e) { startDrag(e, 'min'); });
        maxThumb.addEventListener('mousedown', function(e) { startDrag(e, 'max'); });
        maxThumb.addEventListener('touchstart', function(e) { startDrag(e, 'max'); });

        minInput.addEventListener('input', function(e) {
            var val = Math.floor(parseInt(e.target.value) / localStep) * localStep;
            val = Math.max(localSliderMin, Math.min(val, localMaxPrice - localStep));
            localMinPrice = val;
            e.target.value = val;
            if (minHidden) minHidden.value = val;
            updateSlider();
        });
        maxInput.addEventListener('input', function(e) {
            var val = Math.ceil(parseInt(e.target.value) / localStep) * localStep;
            val = Math.min(localSliderMax, Math.max(val, localMinPrice + localStep));
            localMaxPrice = val;
            e.target.value = val;
            if (maxHidden) maxHidden.value = val;
            updateSlider();
        });

        minInput.addEventListener('focus', function() {
            document.querySelector('.price-input-wrapper:nth-child(1)')?.classList.add('active');
        });
        minInput.addEventListener('blur', function() {
            document.querySelector('.price-input-wrapper:nth-child(1)')?.classList.remove('active');
        });
        maxInput.addEventListener('focus', function() {
            document.querySelector('.price-input-wrapper:nth-child(2)')?.classList.add('active');
        });
        maxInput.addEventListener('blur', function() {
            document.querySelector('.price-input-wrapper:nth-child(2)')?.classList.remove('active');
        });
    }

    // ========== ИНИЦИАЛИЗАЦИЯ ПРИ ЗАГРУЗКЕ ==========
    document.addEventListener('DOMContentLoaded', function() {
        // ----- Кастомная сортировка -----
        var sortDropdown = document.getElementById('sortDropdown');
        var sortSelected = document.getElementById('sortSelected');
        var sortHidden = document.getElementById('sortHidden');

        if (sortDropdown) {
            sortDropdown.addEventListener('click', function(e) {
                e.stopPropagation();
                this.classList.toggle('open');
            });

            document.querySelectorAll('.custom-select-option').forEach(function(option) {
                option.addEventListener('click', function(e) {
                    e.stopPropagation();
                    var value = this.getAttribute('data-value');
                    var text = this.textContent.trim();
                    sortSelected.textContent = text;
                    sortHidden.value = value;
                    document.querySelectorAll('.custom-select-option').forEach(function(opt) {
                        opt.classList.remove('active');
                    });
                    this.classList.add('active');
                    sortDropdown.classList.remove('open');
                });
            });

            document.addEventListener('click', function(e) {
                if (!sortDropdown.contains(e.target)) {
                    sortDropdown.classList.remove('open');
                }
            });

            document.addEventListener('keydown', function(e) {
                if (e.key === 'Escape') {
                    sortDropdown.classList.remove('open');
                }
            });
        }

        // ----- Запуск локального слайдера -----
        initPriceSliderLocal();

        // ----- Общие функции из script.js (без конфликтов) -----
        if (typeof initCategoryFilters === 'function') initCategoryFilters();
        if (typeof initSearchForm === 'function') initSearchForm();
    });
</script>