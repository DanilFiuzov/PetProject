<!-- Хлебные крошки -->
<nav aria-label="breadcrumb" class="breadcrumb-container">
    <div class="container">
        <ol class="breadcrumb bg-light p-3 rounded-3">
            <li class="breadcrumb-item">
                <a href="/" class="text-decoration-none text-primary">
                    <i class="fas fa-home me-1"></i>Главная
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Каталог товаров</li>
        </ol>
    </div>
</nav>

<!-- Оборачиваем весь контент в центральный контейнер -->
<div class="container-fluid def-bg-settings py-4">
    <div class="row">
        <!-- Боковая панель с фильтрами -->
        <div class="col-lg-3 col-md-4 filters-sidebar">
            <div class="card border-0 shadow-sm rounded-3 sticky-sidebar">
                <div class="card-body p-4">
                    <!-- Поиск -->
                    <h5 class="fw-bold mb-3 text-primary">
                        <i class="fas fa-search me-2"></i>Поиск
                    </h5>
                    <form method="GET" action="/products" id="searchForm" class="mb-4">
                        <div class="input-group">
                            <input type="text" 
                                   class="form-control border-primary border-opacity-25" 
                                   name="search" 
                                   placeholder="Поиск товаров..." 
                                   value="<%= searchQuery || '' %>">
                            <button class="btn btn-primary" type="submit">
                                <i class="fas fa-search"></i>
                            </button>
                        </div>
                    </form>

                    <!-- Сортировка -->
                    <h5 class="fw-bold mb-3 text-primary">
                        <i class="fas fa-sort me-2"></i>Сортировка
                    </h5>
                    <select class="form-select border-primary border-opacity-25 mb-3" 
                            name="sort" 
                            onchange="updateSearch()">
                        <option value="newest" <%= sort === 'newest' ? 'selected' : '' %>>Сначала новые</option>
                        <option value="name_asc" <%= sort === 'name_asc' ? 'selected' : '' %>>По названию (А-Я)</option>
                        <option value="name_desc" <%= sort === 'name_desc' ? 'selected' : '' %>>По названию (Я-А)</option>
                        <option value="price_asc" <%= sort === 'price_asc' ? 'selected' : '' %>>По цене (дешевле)</option>
                        <option value="price_desc" <%= sort === 'price_desc' ? 'selected' : '' %>>По цене (дороже)</option>
                        <option value="rating" <%= sort === 'rating' ? 'selected' : '' %>>По рейтингу</option>
                        <option value="discount" <%= sort === 'discount' ? 'selected' : '' %>>По скидке</option>
                    </select>

                    <!-- Фильтр по цене -->
                    <h5 class="fw-bold mb-3 text-primary mt-4">
                        <i class="fas fa-tag me-2"></i>Цена
                    </h5>
                    <div class="row g-2 mb-3">
                        <div class="col-6">
                            <input type="number" 
                                   class="form-control border-primary border-opacity-25" 
                                   name="minPrice" 
                                   placeholder="От" 
                                   min="0" 
                                   value="<%= minPrice || '' %>"
                                   onchange="updateSearch()">
                        </div>
                        <div class="col-6">
                            <input type="number" 
                                   class="form-control border-primary border-opacity-25" 
                                   name="maxPrice" 
                                   placeholder="До" 
                                   min="0" 
                                   value="<%= maxPrice || '' %>"
                                   onchange="updateSearch()">
                        </div>
                    </div>

                    <!-- Категории -->
                    <h5 class="fw-bold mb-3 text-primary mt-4">
                        <i class="fas fa-list me-2"></i>Категории
                    </h5>
                    <div class="categories-filter mb-3">
                        <select class="form-select border-primary border-opacity-25" 
                                name="category" 
                                onchange="updateSearch()">
                            <option value="">Все категории</option>
                            <% allCategories.forEach(cat => { %>
                                <option value="<%= cat.categorieID %>" 
                                        <%= category == cat.categorieID ? 'selected' : '' %>>
                                    <%= cat.categorieName %>
                                </option>
                            <% }) %>
                        </select>
                    </div>

                    <!-- Акционные товары -->
                    <div class="form-check mb-3">
                        <input class="form-check-input" 
                               type="checkbox" 
                               name="onSale" 
                               id="onSale" 
                               value="true"
                               <%= onSale ? 'checked' : '' %>
                               onchange="updateSearch()">
                        <label class="form-check-label" for="onSale">
                            <i class="fas fa-fire text-danger me-1"></i>Только акционные товары
                        </label>
                    </div>

                    <!-- Информация о результатах -->
                    <div class="mt-4 pt-3 border-top">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Найдено:</span>
                            <span class="fw-bold"><%= totalProducts || 0 %> товаров</span>
                        </div>
                        <% if (searchQuery || category || minPrice > 0 || maxPrice > 0 || onSale) { %>
                            <div class="alert alert-info border-0 bg-primary bg-opacity-10 text-primary small p-2 rounded-2">
                                <i class="fas fa-filter me-1"></i>
                                Применены фильтры
                                <a href="/products" class="text-primary fw-bold ms-2">
                                    <i class="fas fa-times"></i> Сбросить
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>

        <!-- Основной контент каталога -->
        <div class="col-lg-9 col-md-8 catalog-main-content">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 fw-bold mb-0">
                    <i class="fas fa-shopping-bag text-primary me-2"></i>
                    Каталог товаров
                    <% if (category && allCategories.find(c => c.categorieID == category)) { %>
                        <span class="text-muted fs-5 ms-2">
                            / <%= allCategories.find(c => c.categorieID == category).categorieName %>
                        </span>
                    <% } %>
                </h1>
                <div class="text-muted small">
                    Страница <%= currentPage %> из <%= totalPages %>
                </div>
            </div>

            <% if (products.length === 0) { %>
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body text-center py-5">
                        <div class="empty-icon mb-4">
                            <i class="fas fa-search fa-4x text-muted opacity-50"></i>
                        </div>
                        <h4 class="text-muted mb-3">Товары не найдены</h4>
                        <p class="text-muted mb-4">Попробуйте изменить поисковый запрос или параметры фильтрации</p>
                        <a href="/products" class="btn btn-primary px-4 py-2">
                            <i class="fas fa-times me-2"></i>Сбросить фильтры
                        </a>
                    </div>
                </div>
            <% } else { %>
                <!-- Список товаров в горизонтальных карточках -->
                <div class="products-list">
                    <% products.forEach((product) => { %>
                    <div class="horizontal-product-card">
                        <!-- Изображение -->
                        <div class="product-image">
                            <a href="/product/<%= product.productID %>" class="text-decoration-none">
                                <img src="/images/products/<%= product.productThumbnail %>" 
                                     alt="<%= product.productTitle %>">
                            </a>
                            
                            <!-- Бейджи на изображении -->
                            <div class="image-badges">
                                <% if (product.isDiscounted) { %>
                                    <div class="badge badge-discount">
                                        -<%= product.discountPercentage %>%
                                    </div>
                                <% } %>
                                <% if (product.productRating >= 4.5) { %>
                                    <div class="badge badge-review">
                                        <i class="fas fa-star me-1"></i><%= product.productRating.toFixed(1) %>
                                    </div>
                                <% } %>
                            </div>
                            
                            <!-- Кнопка избранного -->
                            <% if (session.userId) { %>
                                <% 
                                    const productIdNum = parseInt(product.productID);
                                    const isFavorited = session.favorites && session.favorites.some(favId => parseInt(favId) === productIdNum);
                                %>
                                <button class="btn btn-light btn-sm favorite-btn rounded-circle" 
                                        onclick="toggleFavorite(event, <%= product.productID %>)"
                                        title="<%= isFavorited ? 'Убрать из избранного' : 'Добавить в избранное' %>">
                                    <i class="<%= isFavorited ? 'fas fa-heart text-danger' : 'far fa-heart' %>"></i>
                                </button>
                            <% } %>
                        </div>

                        <!-- Основной контент -->
                        <div class="product-content">
                            <!-- Заголовок и мета-информация -->
                            <div>
                                <h5 class="product-title">
                                    <a href="/product/<%= product.productID %>">
                                        <%= product.productTitle %>
                                    </a>
                                </h5>
                                
                                <div class="product-meta">
                                    <span class="manufacturer">
                                        <i class="fas fa-industry me-1"></i><%= product.productManufacturer %>
                                    </span>
                                    
                                    <!-- Категории -->
                                    <% if (product.categories && product.categories.length > 0) { %>
                                        <div class="categories-container">
                                            <% product.categories.slice(0, 2).forEach((cat) => { %>
                                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                                                    <%= cat %>
                                                </span>
                                            <% }) %>
                                            <% if (product.categories.length > 2) { %>
                                                <span class="badge bg-light text-muted border">
                                                    +<%= product.categories.length - 2 %>
                                                </span>
                                            <% } %>
                                        </div>
                                    <% } %>
                                </div>
                                
                                <!-- Рейтинг -->
                                <div class="product-rating">
                                    <div class="rating">
                                        <% for (let j = 0; j < 5; j++) { %>
                                            <span class="star-wrapper position-relative">
                                                <i class="far fa-star text-muted"></i>
                                                <% if (product.productRating > j) { %>
                                                    <%
                                                        let width = 100;
                                                        if (product.productRating - j < 1) {
                                                            width = (product.productRating - j) * 100;
                                                        }
                                                    %>
                                                    <span class="position-absolute top-0 start-0 overflow-hidden" style="width: <%= width %>%">
                                                        <i class="fas fa-star text-warning"></i>
                                                    </span>
                                                <% } %>
                                            </span>
                                        <% } %>
                                    </div>
                                    <span class="text-muted small">
                                        <%= product.productRating ? product.productRating.toFixed(1) : '0.0' %>
                                    </span>
                                </div>
                                
                                <!-- Описание -->
                                <p class="product-description">
                                    <% 
                                        const description = product.productDescription || '';
                                        const maxLength = 120;
                                        if (description.length > maxLength) {
                                    %>
                                        <%= description.substring(0, maxLength) %>...
                                    <% } else { %>
                                        <%= description %>
                                    <% } %>
                                </p>
                            </div>
                        </div>

                        <!-- Правая часть с ценой и кнопками -->
                        <div class="product-actions">
                            <div class="price-container">
                                <% if (product.isDiscounted) { %>
                                    <div class="current-price discount-price-new">
                                        <%= parseFloat(product.discountedPrice || product.displayPrice).toFixed(2) %>₽
                                    </div>
                                    <div class="original-price">
                                        <%= parseFloat(product.originalPrice || product.productPrice).toFixed(2) %>₽
                                    </div>
                                <% } else { %>
                                    <div class="current-price">
                                        <%= parseFloat(product.displayPrice || product.productPrice).toFixed(2) %>₽
                                    </div>
                                <% } %>
                            </div>
                            
                            <div class="action-buttons">
                                <% if (session.userId) { %>
                                    <button class="btn btn-primary btn-sm" 
                                            onclick="addToCart('<%= product.productID %>')">
                                        <i class="fas fa-shopping-cart me-1"></i>Купить
                                    </button>
                                <% } else { %>
                                    <a href="/login" class="btn btn-primary btn-sm">
                                        <i class="fas fa-sign-in-alt me-1"></i>Войти
                                    </a>
                                <% } %>
                                
                                <a href="/product/<%= product.productID %>" 
                                   class="btn btn-outline-primary btn-sm">
                                    <i class="fas fa-eye me-1"></i>Подробнее
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>

                <!-- Пагинация -->
                <% if (totalPages > 1) { %>
                    <nav aria-label="Навигация по страницам" class="mt-4">
                        <ul class="pagination justify-content-center">
                            <!-- Назад -->
                            <li class="page-item <%= currentPage <= 1 ? 'disabled' : '' %>">
                                <a class="page-link border-0 rounded-circle mx-1" 
                                   href="?<%= new URLSearchParams({
                                        search: searchQuery || '',
                                        category: category || '',
                                        minPrice: minPrice || '',
                                        maxPrice: maxPrice || '',
                                        onSale: onSale ? 'true' : '',
                                        sort: sort || '',
                                        page: currentPage - 1
                                    }) %>">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                            
                            <!-- Страницы -->
                            <% for (let i = 1; i <= totalPages; i++) { %>
                                <% if (i === 1 || i === totalPages || (i >= currentPage - 2 && i <= currentPage + 2)) { %>
                                    <li class="page-item <%= i === currentPage ? 'active' : '' %>">
                                        <a class="page-link border-0 rounded-circle mx-1" 
                                           href="?<%= new URLSearchParams({
                                                search: searchQuery || '',
                                                category: category || '',
                                                minPrice: minPrice || '',
                                                maxPrice: maxPrice || '',
                                                onSale: onSale ? 'true' : '',
                                                sort: sort || '',
                                                page: i
                                            }) %>">
                                            <%= i %>
                                        </a>
                                    </li>
                                <% } else if (i === currentPage - 3 || i === currentPage + 3) { %>
                                    <li class="page-item disabled">
                                        <span class="page-link border-0 rounded-circle mx-1">...</span>
                                    </li>
                                <% } %>
                            <% } %>
                            
                            <!-- Вперед -->
                            <li class="page-item <%= currentPage >= totalPages ? 'disabled' : '' %>">
                                <a class="page-link border-0 rounded-circle mx-1" 
                                   href="?<%= new URLSearchParams({
                                        search: searchQuery || '',
                                        category: category || '',
                                        minPrice: minPrice || '',
                                        maxPrice: maxPrice || '',
                                        onSale: onSale ? 'true' : '',
                                        sort: sort || '',
                                        page: currentPage + 1
                                    }) %>">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        </ul>
                    </nav>
                <% } %>
            <% } %>
        </div>
    </div>
</div>

<script>
// Функция для обновления поиска при изменении фильтров
function updateSearch() {
    const form = document.getElementById('searchForm');
    const search = form.querySelector('[name="search"]').value;
    const category = document.querySelector('[name="category"]').value;
    const minPrice = document.querySelector('[name="minPrice"]').value;
    const maxPrice = document.querySelector('[name="maxPrice"]').value;
    const onSale = document.getElementById('onSale').checked ? 'true' : '';
    const sort = document.querySelector('[name="sort"]').value;
    
    const params = new URLSearchParams();
    
    if (search) params.set('search', search);
    if (category) params.set('category', category);
    if (minPrice) params.set('minPrice', minPrice);
    if (maxPrice) params.set('maxPrice', maxPrice);
    if (onSale) params.set('onSale', onSale);
    if (sort) params.set('sort', sort);
    
    window.location.href = `/products?${params.toString()}`;
}

// Инициализация при загрузке страницы
document.addEventListener('DOMContentLoaded', function() {
    // Добавляем обработчики для полей формы
    const formInputs = document.querySelectorAll('#searchForm input');
    formInputs.forEach(input => {
        input.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
                updateSearch();
            }
        });
    });
});
</script>