<div class="container def-bg-settings"> 
    <h1 class="text-center mt-4 mb-5">Каталог товаров</h1>
    
    <div class="row g-4">
        <% products.forEach((product) => { %>
        <div class="col-12">
            <div class="card cards shadow-sm border-0 CardBody" style="border-radius: 12px; overflow: hidden;">
                <div class="row g-0 h-100">
                    <!-- Изображение товара -->
                    <div class="col-md-3 col-lg-2">
                        <a href="/product/<%= product.productID %>" class="text-decoration-none h-100 d-block">
                            <div class="h-100 d-flex align-items-center justify-content-center p-3" style="background-color: #f8f9fa;">
                                <img src="/images/products/<%= product.productThumbnail %>" 
                                     class="img-fluid" 
                                     alt="<%= product.productTitle %>"
                                     style="max-height: 150px; object-fit: contain;">
                            </div>
                        </a>
                    </div>
                    
                    <!-- Информация о товаре -->
                    <div class="col-md-7 col-lg-8">
                        <div class="card-body h-100 d-flex flex-column justify-content-between py-3">
                            <div>
                                <!-- Заголовок и категория -->
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title mb-0" style="font-size: 1.1rem; line-height: 1.3;">
                                        <a href="/product/<%= product.productID %>" class="text-decoration-none text-dark">
                                            <%= product.productTitle %>
                                        </a>
                                    </h5>
                                    <!-- Можно отображать несколько категорий -->
                                    <div class="categories-container mb-2">
                                        <% if (product.categories && product.categories.length > 0) { %>
                                            <% product.categories.forEach((cat, index) => { %>
                                                <% if (index < 3) { %> <!-- Ограничиваем 3 категориями -->
                                                    <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 me-1 mb-1"
                                                        style="font-size: 0.75rem; padding: 0.25rem 0.5rem;">
                                                        <%= cat %>
                                                    </span>
                                                <% } %>
                                            <% }) %>
                                            <% if (product.categories.length > 3) { %>
                                                <span class="badge bg-light text-muted border" style="font-size: 0.75rem; padding: 0.25rem 0.5rem;">
                                                    +<%= product.categories.length - 3 %>
                                                </span>
                                            <% } %>
                                        <% } else { %>
                                            <span class="badge bg-light text-muted border" style="font-size: 0.75rem; padding: 0.25rem 0.5rem;">
                                                Без категории
                                            </span>
                                        <% } %>
                                    </div>
                                </div>
                                
                                <!-- Производитель -->
                                <div class="mb-2">
                                    <small class="text-muted">Производитель:</small>
                                    <span class="ms-1 fw-medium"><%= product.productManufacturer %></span>
                                </div>
                                
                                <!-- Рейтинг -->
                                <div class="d-flex align-items-center mb-3">
                                    <div class="rating me-2">
                                        <% for (let j = 0; j < 5; j++) { %>
                                            <span class="star-wrapper" style="font-size: 0.9rem;">
                                                <i class="far fa-star empty-star"></i>
                                                <% if (product.productRating > j) { %>
                                                    <%
                                                        let width = 100;
                                                        if (product.productRating - j < 1) {
                                                            width = (product.productRating - j) * 100;
                                                        }
                                                    %>
                                                    <span class="filled-star" style="width: <%= width %>%">
                                                        <i class="fas fa-star"></i>
                                                    </span>
                                                <% } %>
                                            </span>
                                        <% } %>
                                    </div>
                                    <small class="text-muted">
                                        <%= product.productRating ? product.productRating.toFixed(1) : '0.0' %>
                                    </small>
                                </div>
                            </div>
                            
                            <!-- Описание (урезанное) -->
                            <div class="mt-auto">
                                <p class="card-text text-muted small mb-0" style="font-size: 0.85rem; line-height: 1.4;">
                                    <% 
                                        const maxLength = 120;
                                        let description = product.productDescription || '';
                                        if (description.length > maxLength) {
                                            description = description.substring(0, maxLength) + '...';
                                        }
                                    %>
                                    <%= description %>
                                </p>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Цена и действия -->
                    <div class="col-md-2 col-lg-2">
                        <div class="h-100 d-flex flex-column align-items-center justify-content-center p-3" 
                             style="background-color: #f8f9fa; border-left: 1px solid rgba(0,0,0,0.05);">
                            
                            <!-- Цена -->
                            <div class="text-center mb-3">
                                <h4 class="fw-bold text-primary mb-0"><%= product.productPrice %>₽</h4>
                            </div>
                            
                            <!-- Кнопки действий -->
                            <div class="d-flex flex-column align-items-center w-100">
                                <% if (session.userId) { %>
                                    <div class="d-flex justify-content-center align-items-center w-100 mb-2">
                                        <button class="btn btn-link p-0" 
                                                type="button" 
                                                title="<%= session.favorites && session.favorites.includes(product.productID) ? 'Убрать из избранного' : 'Добавить в избранное' %>"
                                                onclick="toggleFavorite(event, '<%= product.productID %>')">
                                            <i class="fa-heart <%= session.favorites && session.favorites.includes(product.productID) ? 'fas text-danger' : 'far text-muted' %>" 
                                               id="heart-<%= product.productID %>"
                                               style="font-size: 1.2rem;"></i>
                                        </button>
                                    </div>
                                    
                                    <button class="btn btn-primary w-100" 
                                            type="button" 
                                            onclick="addToCart('<%= product.productID %>')"
                                            style="padding: 0.5rem 1rem;">
                                        <i class="fas fa-shopping-cart me-1"></i>
                                        Купить
                                    </button>
                                <% } else { %>
                                    <a href="/login" class="btn btn-outline-primary w-100" style="padding: 0.5rem 1rem;">
                                        <i class="fas fa-sign-in-alt me-1"></i>
                                        Войти
                                    </a>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <% }) %>
    </div>
</div>