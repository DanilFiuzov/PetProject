<div class="container def-bg-settings long-form-page py-4">
    <div class="row justify-content-center">
        <div class="col-lg-10 col-xl-8">
            <!-- Хлебные крошки -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Главная</a></li>
                    <li class="breadcrumb-item"><a href="/admin/products" class="text-decoration-none">Админ-панель</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Добавить товар</li>
                </ol>
            </nav>
            
            <div class="card border-0 shadow-lg rounded-3">
                <div class="card-header CanvaHeader py-3 border-0">
                    <h3 class="mb-0 text-white">
                        <i class="fas fa-plus-circle me-2"></i>
                        Добавление нового товара
                    </h3>
                </div>
                
                <div class="card-body p-4">
                    <form id="addProductForm" enctype="multipart/form-data">
                        <!-- Основная информация -->
                        <div class="mb-4">
                            <h5 class="text-primary mb-3 pb-2 border-bottom">
                                <i class="fas fa-info-circle me-2"></i>
                                Основная информация
                            </h5>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Название товара *</label>
                                    <input type="text" 
                                           class="form-control" 
                                           name="productTitle" 
                                           required 
                                           placeholder="Например: Гантель Demix 5кг">
                                </div>
                                
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Производитель *</label>
                                    <input type="text" 
                                           class="form-control" 
                                           name="productManufacturer" 
                                           required 
                                           placeholder="Например: Demix">
                                </div>
                                
                                <div class="col-12 mb-3">
                                    <label class="form-label fw-semibold">Описание товара *</label>
                                    <textarea class="form-control" 
                                              name="productDescription" 
                                              rows="4" 
                                              required 
                                              placeholder="Подробное описание товара..."></textarea>
                                </div>
                                
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Цена (руб) *</label>
                                    <div class="input-group">
                                        <input type="number" 
                                               class="form-control" 
                                               name="productPrice" 
                                               min="1" 
                                               step="0.01" 
                                               required 
                                               placeholder="Например: 1999.99">
                                        <span class="input-group-text">₽</span>
                                    </div>
                                </div>
                                
                                <!-- Наличие на складе - НОВОЕ ПОЛЕ -->
                                <div class="col-md-6 mb-3">
                                    <label class="form-label fw-semibold">Количество на складе *</label>
                                    <div class="input-group">
                                        <input type="number" 
                                               class="form-control" 
                                               name="stock_quantity" 
                                               min="0" 
                                               required 
                                               value="0"
                                               placeholder="Например: 10">
                                        <span class="input-group-text">шт.</span>
                                    </div>
                                    <div class="form-text text-success">
                                        <i class="fas fa-info-circle me-1"></i>
                                        Укажите доступное количество товара. При 0 - товар будет помечен как "нет в наличии"
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Скидка -->
                        <div class="mb-4">
                            <h5 class="text-primary mb-3 pb-2 border-bottom">
                                <i class="fas fa-percentage me-2"></i>
                                Скидка и акции
                            </h5>
                            
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <div class="form-check form-switch mb-3">
                                        <input class="form-check-input" 
                                               type="checkbox" 
                                               name="is_on_sale" 
                                               id="is_on_sale"
                                               value="1"
                                               onchange="toggleDiscountFields()">
                                        <label class="form-check-label fw-semibold" for="is_on_sale">
                                            Включить скидку на товар
                                        </label>
                                    </div>
                                </div>
                            </div>
                            
                            <div id="discountFields" style="display: none;">
                                <div class="row">
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label fw-semibold">Процент скидки</label>
                                        <div class="input-group">
                                            <input type="number" 
                                                   class="form-control" 
                                                   name="discount_percentage" 
                                                   min="1" 
                                                   max="99" 
                                                   step="1"
                                                   placeholder="Например: 20">
                                            <span class="input-group-text">%</span>
                                        </div>
                                        <div class="form-text">От 1% до 99%</div>
                                    </div>
                                    
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label fw-semibold">Дата начала</label>
                                        <input type="datetime-local" 
                                               class="form-control" 
                                               name="discount_start_date"
                                               id="discount_start_date">
                                    </div>
                                    
                                    <div class="col-md-4 mb-3">
                                        <label class="form-label fw-semibold">Дата окончания</label>
                                        <input type="datetime-local" 
                                               class="form-control" 
                                               name="discount_end_date"
                                               id="discount_end_date">
                                    </div>
                                </div>
                                
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>Как это работает:</strong><br>
                                    1. Скидка будет автоматически рассчитываться<br>
                                    2. Если не указаны даты - скидка действует постоянно<br>
                                    3. Скидка будет отображаться на всех страницах сайта
                                </div>
                            </div>
                        </div>
                        
                        <!-- Изображение товара -->
                        <div class="mb-4">
                            <h5 class="text-primary mb-3 pb-2 border-bottom">
                                <i class="fas fa-image me-2"></i>
                                Изображение товара
                            </h5>
                            
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Изображение товара *</label>
                                <input type="file" 
                                       class="form-control" 
                                       name="productImage" 
                                       accept="image/jpeg,image/jpg,image/png" 
                                       required
                                       onchange="previewImage(this)">
                                <div class="form-text">Поддерживаемые форматы: JPG, PNG. Максимальный размер: 5MB</div>
                            </div>
                            
                            <div class="image-preview-container text-center mt-3" id="imagePreviewContainer" style="display: none;">
                                <div class="border rounded p-3 bg-light d-inline-block">
                                    <img id="imagePreview" 
                                         src="#" 
                                         alt="Предпросмотр" 
                                         class="img-fluid rounded" 
                                         style="max-height: 200px; max-width: 100%;">
                                </div>
                                <div class="mt-2 text-muted small">Предпросмотр изображения</div>
                            </div>
                        </div>
                        
                        <!-- Категории -->
                        <div class="mb-4">
                            <h5 class="text-primary mb-3 pb-2 border-bottom">
                                <i class="fas fa-tags me-2"></i>
                                Категории товара
                            </h5>
                            
                            <div class="mb-3">
                                <label class="form-label fw-semibold">Выберите категории *</label>
                                <div class="categories-checkbox">
                                    <% if (typeof categories !== 'undefined' && categories.length > 0) { %>
                                        <% categories.forEach((category) => { %>
                                            <div class="form-check form-check-inline me-4 mb-2">
                                                <input class="form-check-input" 
                                                       type="checkbox" 
                                                       name="categories[]" 
                                                       value="<%= category.categorieName %>" 
                                                       id="category<%= category.categorieID %>">
                                                <label class="form-check-label" for="category<%= category.categorieID %>">
                                                    <%= category.categorieName %>
                                                </label>
                                            </div>
                                        <% }); %>
                                    <% } else { %>
                                        <div class="alert alert-warning">
                                            <i class="fas fa-exclamation-triangle me-2"></i>
                                            Категории не найдены. Сначала добавьте категории в систему.
                                        </div>
                                    <% } %>
                                </div>
                                <div class="form-text">Можно выбрать несколько категорий</div>
                            </div>
                        </div>
                        
                        <!-- Характеристики товара -->
                        <div class="mb-4">
                            <h5 class="text-primary mb-3 pb-2 border-bottom d-flex justify-content-between align-items-center">
                                <span>
                                    <i class="fas fa-list-alt me-2"></i>
                                    Характеристики товара
                                </span>
                                <button type="button" 
                                        class="btn btn-sm btn-outline-primary" 
                                        id="addFeatureBtn">
                                    <i class="fas fa-plus me-1"></i>Добавить характеристику
                                </button>
                            </h5>
                            
                            <div id="featuresContainer">
                                <div class="feature-item mb-3 border rounded p-3 bg-light">
                                    <div class="row g-2">
                                        <div class="col-md-5">
                                            <input type="text" 
                                                   class="form-control" 
                                                   name="feature_keys[]" 
                                                   placeholder="Характеристика (например: Вес)"
                                                   required>
                                        </div>
                                        <div class="col-md-5">
                                            <input type="text" 
                                                   class="form-control" 
                                                   name="feature_values[]" 
                                                   placeholder="Значение (например: 5 кг)"
                                                   required>
                                        </div>
                                        <div class="col-md-2">
                                            <button type="button" 
                                                    class="btn btn-outline-danger w-100 remove-feature-btn"
                                                    disabled>
                                                <i class="fas fa-times"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="form-text mt-2">
                                <i class="fas fa-info-circle me-1"></i>
                                Добавьте характеристики товара. Пример: Вес = 5 кг, Материал = Чугун
                            </div>
                        </div>
                        
                        <!-- Кнопки отправки -->
                        <div class="d-flex justify-content-between pt-3 border-top">
                            <a href="/admin/products" class="btn btn-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Назад
                            </a>
                            
                            <button type="submit" 
                                    class="btn btn-primary px-4" 
                                    id="submitBtn">
                                <i class="fas fa-plus-circle me-2"></i>
                                Добавить товар
                            </button>
                        </div>
                    </form>
                </div>
            </div>
            
            <!-- Уведомления -->
            <div id="notificationContainer" class="mt-4"></div>
        </div>
    </div>
</div>

<script>
// Предпросмотр изображения
function previewImage(input) {
    const previewContainer = document.getElementById('imagePreviewContainer');
    const previewImage = document.getElementById('imagePreview');
    
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        
        reader.onload = function(e) {
            previewImage.src = e.target.result;
            previewContainer.style.display = 'block';
        }
        
        reader.readAsDataURL(input.files[0]);
    } else {
        previewContainer.style.display = 'none';
    }
}

// Переключение полей скидки
function toggleDiscountFields() {
    const discountFields = document.getElementById('discountFields');
    const isOnSale = document.getElementById('is_on_sale').checked;
    
    if (isOnSale) {
        discountFields.style.display = 'block';
        // Автозаполнение текущей даты для начала скидки
        if (!document.getElementById('discount_start_date').value) {
            const now = new Date();
            const local = new Date(now);
            local.setMinutes(now.getMinutes() - now.getTimezoneOffset());
            document.getElementById('discount_start_date').value = local.toISOString().slice(0, 16);
        }
    } else {
        discountFields.style.display = 'none';
    }
}

// Добавление новой характеристики
document.getElementById('addFeatureBtn').addEventListener('click', function() {
    const container = document.getElementById('featuresContainer');
    const newItem = document.createElement('div');
    newItem.className = 'feature-item mb-3 border rounded p-3 bg-light';
    newItem.innerHTML = `
        <div class="row g-2">
            <div class="col-md-5">
                <input type="text" 
                       class="form-control" 
                       name="feature_keys[]" 
                       placeholder="Характеристика (например: Вес)"
                       required>
            </div>
            <div class="col-md-5">
                <input type="text" 
                       class="form-control" 
                       name="feature_values[]" 
                       placeholder="Значение (например: 5 кг)"
                       required>
            </div>
            <div class="col-md-2">
                <button type="button" 
                        class="btn btn-outline-danger w-100 remove-feature-btn">
                    <i class="fas fa-times"></i>
                </button>
            </div>
        </div>
    `;
    container.appendChild(newItem);
    
    // Обновляем состояние кнопок удаления
    updateRemoveButtons();
});

// Удаление характеристики
document.addEventListener('click', function(e) {
    if (e.target.closest('.remove-feature-btn')) {
        const item = e.target.closest('.feature-item');
        if (item) {
            item.remove();
            updateRemoveButtons();
        }
    }
});

// Обновление состояния кнопок удаления
function updateRemoveButtons() {
    const items = document.querySelectorAll('.feature-item');
    items.forEach((item, index) => {
        const removeBtn = item.querySelector('.remove-feature-btn');
        if (items.length === 1) {
            removeBtn.disabled = true;
            removeBtn.classList.add('disabled');
        } else {
            removeBtn.disabled = false;
            removeBtn.classList.remove('disabled');
        }
    });
}

// Валидация и отправка формы
document.getElementById('addProductForm').addEventListener('submit', function(e) {
    e.preventDefault();
    
    // Проверка количества на складе
    const stockQuantity = parseInt(document.querySelector('[name="stock_quantity"]').value);
    if (isNaN(stockQuantity) || stockQuantity < 0) {
        showNotification('Количество на складе должно быть неотрицательным числом', 'error');
        return;
    }
    
    // Проверка категорий
    const categories = document.querySelectorAll('[name="categories[]"]:checked');
    if (categories.length === 0) {
        showNotification('Выберите хотя бы одну категорию', 'error');
        return;
    }
    
    // Проверка характеристик
    const featureKeys = document.querySelectorAll('[name="feature_keys[]"]');
    const featureValues = document.querySelectorAll('[name="feature_values[]"]');
    
    for (let i = 0; i < featureKeys.length; i++) {
        if (featureKeys[i].value.trim() === '' || featureValues[i].value.trim() === '') {
            showNotification('Заполните все поля характеристик', 'error');
            return;
        }
    }
    
    // Отправка формы
    const formData = new FormData(this);
    
    // Добавляем скрытое значение is_on_sale если чекбокс не отмечен
    if (!document.getElementById('is_on_sale').checked) {
        formData.set('is_on_sale', '0');
    }
    
    document.getElementById('submitBtn').disabled = true;
    document.getElementById('submitBtn').innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Добавление...';
    
    fetch('/admin/add-product', {
        method: 'POST',
        body: formData
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showNotification('Товар успешно добавлен!', 'success');
            setTimeout(() => {
                window.location.href = '/admin/products';
            }, 1500);
        } else {
            showNotification(data.message || 'Ошибка при добавлении товара', 'error');
            document.getElementById('submitBtn').disabled = false;
            document.getElementById('submitBtn').innerHTML = '<i class="fas fa-plus-circle me-2"></i>Добавить товар';
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showNotification('Произошла ошибка при добавлении товара', 'error');
        document.getElementById('submitBtn').disabled = false;
        document.getElementById('submitBtn').innerHTML = '<i class="fas fa-plus-circle me-2"></i>Добавить товар';
    });
});

// Показ уведомлений
function showNotification(message, type) {
    const container = document.getElementById('notificationContainer');
    const alertType = type === 'success' ? 'alert-success' : 'alert-danger';
    const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
    
    const alert = document.createElement('div');
    alert.className = `alert ${alertType} alert-dismissible fade show`;
    alert.role = 'alert';
    alert.innerHTML = `
        <i class="fas ${icon} me-2"></i>
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    `;
    
    container.innerHTML = '';
    container.appendChild(alert);
    
    // Автоматическое скрытие через 5 секунд
    setTimeout(() => {
        alert.classList.remove('show');
        alert.classList.add('fade');
        setTimeout(() => {
            container.innerHTML = '';
        }, 300);
    }, 5000);
}

// Инициализация при загрузке
document.addEventListener('DOMContentLoaded', function() {
    // Установка минимальной даты для окончания скидки
    const now = new Date();
    const local = new Date(now);
    local.setMinutes(now.getMinutes() - now.getTimezoneOffset());
    document.getElementById('discount_end_date').min = local.toISOString().slice(0, 16);
    
    // Обновление кнопок удаления при загрузке
    updateRemoveButtons();
});
</script>