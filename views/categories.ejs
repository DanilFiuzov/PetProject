<div class="container def-bg-settings py-5">
    <div class="categories-white-block">
        <!-- Заголовок -->
        <div class="text-center mb-5">
            <h1 class="fw-bold" style="color: var(--primary-color);">
                <i class="fas fa-th-large me-2"></i>Категории товаров
            </h1>
            <p class="text-muted lead">Выберите категорию и найдите идеальный спортивный инвентарь</p>
        </div>

        <!-- Сетка категорий -->
        <div class="row g-4">
            <% if (categories.length > 0) {
                categories.forEach(cat => { %>
                    <div class="col-md-6 col-lg-4">
                        <a href="/products?category=<%= cat.categorieID %>" class="text-decoration-none category-card-link">
                            <div class="card border-0 h-100 category-card-gradient">
                                <!-- Область с миниатюрой -->
                                <div class="card-img-gradient">
                                    <img src="/images/categories/<%= cat.categorieThumbnail || 'default-category.jpg' %>"
                                         alt="<%= cat.categorieName %>"
                                         onerror="this.onerror=null;this.src='/images/categories/default-category.jpg';">
                                </div>
                                <!-- Контент -->
                                <div class="card-body text-center">
                                    <h4 class="card-title-category"><%= cat.categorieName %></h4>
                                    <p class="card-text-category">
                                        <i class="fas fa-box me-1"></i><%= cat.productCount || 0 %> товаров
                                    </p>
                                </div>
                            </div>
                        </a>
                    </div>
                <% });
            } else { %>
                <div class="col-12 text-center py-5">
                    <i class="fas fa-folder-open fa-4x text-muted mb-3"></i>
                    <h3 class="text-muted">Категории пока не добавлены</h3>
                </div>
            <% } %>
        </div>
    </div>
</div>