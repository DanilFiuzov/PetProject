<!-- Хлебные крошки -->
<nav aria-label="breadcrumb" class="breadcrumb-container">
    <div class="container">
        <ol class="breadcrumb bg-light p-3 rounded-3">
            <li class="breadcrumb-item">
                <a href="/" class="text-decoration-none text-primary">
                    <i class="fas fa-home me-1"></i>Главная
                </a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">
                <i class="fas fa-heart me-1"></i>Избранное
            </li>
        </ol>
    </div>
</nav>

<!-- Оборачиваем весь контент в центральный контейнер -->
<div class="container-fluid def-bg-settings py-4">
    <div class="row">
        <!-- Боковая панель с информацией об избранном - ВНЕ основного контента -->
        <div class="col-lg-3 col-md-4 filters-sidebar">
            <div class="card border-0 shadow-sm rounded-3 sticky-sidebar">
                <div class="card-body p-4">
                    <!-- Заголовок -->
                    <h5 class="fw-bold mb-3 text-primary">
                        <i class="fas fa-heart me-2"></i>Избранное
                    </h5>
                    
                    <!-- Статистика -->
                    <div class="mb-4">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Товаров:</span>
                            <span class="fw-bold"><%= products.length %> избранных</span>
                        </div>
                        <% if (products.length > 0) { %>
                            <div class="alert alert-info border-0 bg-primary bg-opacity-10 text-primary small p-2 rounded-2">
                                <i class="fas fa-info-circle me-1"></i>
                                Общая сумма: 
                                <% 
                                    let totalFavPrice = 0;
                                    products.forEach(p => {
                                        const price = parseFloat(p.productPrice) || 0;
                                        totalFavPrice += price;
                                    });
                                %>
                                <span class="fw-bold"><%= totalFavPrice.toFixed(2) %>₽</span>
                            </div>
                        <% } %>
                    </div>

                    <!-- Действия -->
                    <div class="d-grid gap-2 mb-4">
                        <% if (products.length > 0) { %>
                            <button class="btn btn-outline-custom-danger" 
                                    onclick="clearAllFavorites()">
                                <i class="fas fa-trash-alt me-2"></i>
                                Очистить все
                            </button>
                        <% } %>
                        <a href="/products" class="btn btn-custom">
                            <i class="fas fa-shopping-bag me-2"></i>
                            Перейти в каталог
                        </a>
                    </div>

                    <!-- Информация о результатах -->
                    <div class="pt-3 border-top">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted">Сохранено:</span>
                            <span class="fw-bold"><%= products.length %> товаров</span>
                        </div>
                        <div class="alert alert-warning border-0 bg-warning bg-opacity-10g small p-2 rounded-2">
                            <i class="fas fa-info-circle me-1"></i>
                            Товары в избранном сохраняются навсегда
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Основной контент избранного -->
        <div class="col-lg-9 col-md-8 catalog-main-content">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1 class="h3 fw-bold mb-0">
                    <i class="fas fa-heart text-primary me-2"></i>
                    Избранные товары
                </h1>
                <div class="text-muted small">
                    Сохранено <%= products.length %> товаров
                </div>
            </div>

            <% if (products.length === 0) { %>
                <div class="card border-0 shadow-sm rounded-3">
                    <div class="card-body text-center py-5">
                        <div class="empty-icon mb-4">
                            <i class="far fa-heart fa-4x text-muted opacity-50"></i>
                        </div>
                        <h4 class="text-muted mb-3">Избранное пусто</h4>
                        <p class="text-muted mb-4">Добавляйте товары в избранное, чтобы вернуться к ним позже</p>
                        <a href="/products" class="btn btn-custom px-4 py-2">
                            <i class="fas fa-shopping-bag me-2"></i>Перейти в каталог
                        </a>
                    </div>
                </div>
            <% } else { %>
                <!-- Список товаров в горизонтальных карточках -->
                <div class="products-list">
                    <% products.forEach((product) => { %>
                    <div class="horizontal-product-card <%= product.stock_quantity <= 0 ? 'out-of-stock' : '' %>"
                         data-product-id="<%= product.productID %>"
                         data-stock-quantity="<%= product.stock_quantity %>">
                        <!-- Изображение -->
                        <div class="product-image">
                            <a href="/product/<%= product.productID %>" class="text-decoration-none">
                                <img src="/images/products/<%= product.productThumbnail %>" 
                                     alt="<%= product.productTitle %>">
                            </a>
                            
                            <!-- Бейджи на изображении -->
                            <div class="image-badges">
                                <% if (product.isDiscounted) { %>
                                    <div class="badge badge-discount">
                                        -<%= product.discountPercentage %>% 
                                    </div>
                                <% } %>
                                <% if (product.productRating >= 4.5) { %>
                                    <div class="badge badge-review">
                                        <i class="fas fa-star me-1"></i><%= product.productRating.toFixed(1) %>
                                    </div>
                                <% } %>
                                <% if (product.stock_quantity <= 0) { %>
                                    <div class="out-of-stock-overlay">
                                        <div class="out-of-stock-badge">
                                            SOLD
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                            
                            <!-- Кнопка избранного -->
                            <% if (session.userId) { %>
                                <% 
                                    // Преобразуем productID в число для сравнения
                                    const productIdNum = parseInt(product.productID);
                                    const isFavorited = session.favorites && session.favorites.some(favId => parseInt(favId) === productIdNum);
                                %>
                                <button class="btn btn-light btn-sm favorite-btn rounded-circle" 
                                        onclick="toggleFavorite(event, <%= product.productID %>)"
                                        title="<%= isFavorited ? 'Убрать из избранного' : 'Добавить в избранное' %>">
                                    <i class="<%= isFavorited ? 'fas fa-heart text-danger' : 'far fa-heart' %>"></i>
                                </button>
                            <% } %>
                        </div>

                        <!-- Основной контент -->
                        <div class="product-content">
                            <!-- Заголовок и мета-информация -->
                            <div>
                                <h5 class="product-title">
                                    <a href="/product/<%= product.productID %>">
                                        <%= product.productTitle %>
                                    </a>
                                </h5>
                                
                                <div class="product-meta">
                                    <span class="manufacturer">
                                        <i class="fas fa-industry me-1"></i><%= product.productManufacturer %>
                                    </span>
                                    
                                    <!-- Категории -->
                                    <% if (product.categories && product.categories.length > 0) { %>
                                        <div class="categories-container">
                                            <% product.categories.slice(0, 2).forEach((cat) => { %>
                                                <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25">
                                                    <%= cat %>
                                                </span>
                                            <% }) %>
                                            <% if (product.categories.length > 2) { %>
                                                <span class="badge bg-light text-muted border">
                                                    +<%= product.categories.length - 2 %>
                                                </span>
                                            <% } %>
                                        </div>
                                    <% } %>
                                </div>
                                
                                <!-- Рейтинг -->
                                <div class="product-rating">
                                    <div class="rating">
                                        <% for (let j = 0; j < 5; j++) { %>
                                            <span class="star-wrapper position-relative">
                                                <i class="far fa-star text-muted"></i>
                                                <% if (product.productRating > j) { %>
                                                    <%
                                                        let width = 100;
                                                        if (product.productRating - j < 1) {
                                                            width = (product.productRating - j) * 100;
                                                        }
                                                    %>
                                                    <span class="position-absolute top-0 start-0 overflow-hidden" style="width: <%= width %>%">
                                                        <i class="fas fa-star text-warning"></i>
                                                    </span>
                                                <% } %>
                                            </span>
                                        <% } %>
                                    </div>
                                    <span class="text-muted small">
                                        <%= product.productRating ? product.productRating.toFixed(1) : '0.0' %>
                                    </span>
                                </div>
                                
                                <!-- Описание -->
                                <p class="product-description">
                                    <% 
                                        const description = product.productDescription || '';
                                        const maxLength = 120;
                                        if (description.length > maxLength) {
                                    %>
                                        <%= description.substring(0, maxLength) %>...
                                    <% } else { %>
                                        <%= description %>
                                    <% } %>
                                </p>
                            </div>
                        </div>

                        <!-- Правая часть с ценой и кнопками -->
                        <div class="product-actions">
                            <div class="price-container">
                                <% 
                                    // Безопасное вычисление цен
                                    const originalPrice = parseFloat(product.originalPrice || product.productPrice) || 0;
                                    const displayPrice = parseFloat(product.displayPrice || product.productPrice) || 0;
                                    const discountedPrice = parseFloat(product.discountedPrice) || displayPrice;
                                %>
                                <% if (product.isDiscounted) { %>
                                    <div class="current-price">
                                        <%= discountedPrice.toFixed(2) %>₽
                                    </div>
                                    <div class="original-price">
                                        <%= originalPrice.toFixed(2) %>₽
                                    </div>
                                <% } else { %>
                                    <div class="current-price">
                                        <%= originalPrice.toFixed(2) %>₽
                                    </div>
                                <% } %>
                                
                                <!-- Индикатор наличия -->
                                <% if (product.stock_quantity <= 0) { %>
                                    <div class="stock-indicator text-danger mt-2">
                                        <i class="fas fa-times-circle me-1"></i>Нет в наличии
                                    </div>
                                <% } else if (product.stock_quantity <= 5) { %>
                                    <div class="stock-indicator text-warning mt-2">
                                        <i class="fas fa-exclamation-triangle me-1"></i>Только <%= product.stock_quantity %> шт.
                                    </div>
                                <% } else { %>
                                    <div class="stock-indicator text-success mt-2">
                                        <i class="fas fa-check-circle me-1"></i>В наличии
                                    </div>
                                <% } %>
                            </div>
                            
                            <div class="action-buttons">
                                <% if (product.stock_quantity <= 0) { %>
                                    <button class="btn btn-outline-secondary btn-sm" disabled>
                                        <i class="fas fa-times me-1"></i>Нет в наличии
                                    </button>
                                <% } else if (session.userId) { %>
                                    <button class="btn btn-custom btn-sm" 
                                            onclick="addToCart('<%= product.productID %>')">
                                        <i class="fas fa-shopping-cart me-1"></i>Купить
                                    </button>
                                <% } else { %>
                                    <a href="/login" class="btn btn-custom btn-sm">
                                        <i class="fas fa-sign-in-alt me-1"></i>Войти
                                    </a>
                                <% } %>
                                
                                <a href="/product/<%= product.productID %>" 
                                   class="btn btn-outline-custom btn-sm">
                                    <i class="fas fa-eye me-1"></i>Подробнее
                                </a>
                            </div>
                        </div>
                    </div>
                    <% }) %>
                </div>

                <!-- Пагинация не нужна для избранного, но можно добавить если много товаров -->
                <div class="mt-4 pt-3 border-top">
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="text-muted">
                            <i class="fas fa-info-circle me-1"></i>
                            Всего сохранено: <%= products.length %> товаров
                        </div>
                        <% if (products.length > 5) { %>
                            <button class="btn btn-outline-custom-danger btn-sm" onclick="clearAllFavorites()">
                                <i class="fas fa-trash-alt me-1"></i>Очистить все
                            </button>
                        <% } %>
                    </div>
                </div>
            <% } %>
        </div>
    </div>
</div>

<script>
function clearAllFavorites() {
    if (confirm('Вы уверены, что хотите очистить все избранные товары? Это действие нельзя отменить.')) {
        fetch('/favorites/clear-all', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            },
            body: JSON.stringify({ customerID: '<%= session.userId %>' })
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showNotification('Все товары удалены из избранного', 'success');
                setTimeout(() => {
                    location.reload();
                }, 1500);
            } else {
                showNotification(data.message || 'Ошибка при очистке избранного', 'error');
            }
        })
        .catch(error => {
            showNotification('Ошибка сети', 'error');
        });
    }
}

// Функция показа уведомлений (если еще не определена)
if (typeof showNotification === 'undefined') {
    window.showNotification = function(message, type = 'info') {
        const types = {
            'success': { icon: 'fa-check-circle', color: 'success' },
            'danger': { icon: 'fa-exclamation-circle', color: 'danger' },
            'info': { icon: 'fa-info-circle', color: 'primary' }
        };
        
        const config = types[type] || types.info;
        
        const notification = document.createElement('div');
        notification.className = `alert alert-${config.color} alert-dismissible fade show position-fixed bottom-0 end-0 m-3 shadow-lg`;
        notification.style.zIndex = '9999';
        notification.style.minWidth = '300px';
        notification.innerHTML = `
            <div class="d-flex align-items-center">
                <i class="fas ${config.icon} fa-2x me-3 text-${config.color}"></i>
                <div>
                    <h6 class="mb-0 fw-bold">${message}</h6>
                </div>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        `;
        
        document.body.appendChild(notification);
        
        setTimeout(() => {
            notification.remove();
        }, 5000);
    };
}
</script>