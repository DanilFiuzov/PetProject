<!-- admin_products.ejs -->
<div class="container def-bg-settings py-4">
    <div class="row">
        <div class="col-12">
            <!-- Хлебные крошки -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Главная</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Админ-панель</li>
                </ol>
            </nav>

            <!-- Вкладки навигации -->
            <ul class="nav nav-tabs nav-fill mb-4" id="adminTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="products-tab" data-bs-toggle="tab" data-bs-target="#products" type="button" role="tab">
                        <i class="fas fa-boxes me-2"></i>Товары
                        <span class="badge bg-primary text-white ms-1"><%= pagination.totalProducts %></span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="categories-tab" data-bs-toggle="tab" data-bs-target="#categories" type="button" role="tab">
                        <i class="fas fa-tags me-2"></i>Категории
                        <span class="badge bg-secondary text-white ms-1"><%= categories.length %></span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="orders-tab" data-bs-toggle="tab" data-bs-target="#orders" type="button" role="tab">
                        <i class="fas fa-shopping-cart me-2"></i>Заказы
                        <span class="badge bg-secondary text-white ms-1" id="ordersBadge"><%= orders ? orders.length : 0 %></span>
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="users-tab" data-bs-toggle="tab" data-bs-target="#users" type="button" role="tab">
                        <i class="fas fa-users me-2"></i>Пользователи
                        <span class="badge bg-secondary text-white ms-1"><%= users ? users.length : 0 %></span>
                    </button>
                </li>
            </ul>

            <!-- Содержимое вкладок -->
            <div class="tab-content" id="adminTabContent">

                <!-- ========== ВКЛАДКА: ТОВАРЫ ========== -->
                <div class="tab-pane fade show active" id="products" role="tabpanel" aria-labelledby="products-tab">
                    <div class="card border-0 shadow-sm no-hover">
                        <div class="card-header CanvaHeader py-3 d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 text-white">
                                <i class="fas fa-boxes me-2"></i>Управление товарами
                            </h5>
                            <a href="/admin/add-product" class="btn btn-light btn-sm">
                                <i class="fas fa-plus me-1"></i> Добавить товар
                            </a>
                        </div>
                        <div class="card-body p-3">
                            <!-- Поиск -->
                            <form method="GET" action="/admin/products" class="row g-2 mb-3">
                                <div class="col-md-12">
                                    <div class="input-group">
                                        <span class="input-group-text"><i class="fas fa-search"></i></span>
                                        <input type="text" class="form-control" name="search" 
                                               value="<%= pagination.searchQuery || '' %>"
                                               placeholder="Поиск по названию, производителю или описанию...">
                                        <button class="btn btn-search-admin" type="submit">Найти</button>
                                    </div>
                                </div>
                            </form>

                            <!-- Таблица товаров -->
                            <% if (products.length === 0) { %>
                                <div class="text-center py-5">
                                    <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                                    <h5 class="text-muted">Товары не найдены</h5>
                                    <% if (pagination.searchQuery) { %>
                                        <p class="text-muted">По запросу "<%= pagination.searchQuery %>" ничего не найдено</p>
                                        <a href="/admin/products" class="btn btn-outline-primary">
                                            <i class="fas fa-arrow-left me-2"></i>Показать все товары
                                        </a>
                                    <% } else { %>
                                        <p class="text-muted">В базе данных пока нет товаров</p>
                                        <a href="/admin/add-product" class="btn btn-custom">
                                            <i class="fas fa-plus-circle me-2"></i>Добавить первый товар
                                        </a>
                                    <% } %>
                                </div>
                            <% } else { %>
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 60px;">ID</th>
                                                <th>Товар</th>
                                                <th class="text-center align-middle">Категории</th>
                                                <th style="width: 100px;" class="text-center align-middle">Цена</th>
                                                <th style="width: 80px;" class="text-center align-middle">Рейтинг</th>
                                                <th style="width: 80px;" class="text-center align-middle">Хар-ки</th>
                                                <th style="width: 50px;" class="text-center align-middle"></th>
                                                <th style="width: 50px;" class="text-center align-middle"></th>
                                                <th style="width: 50px;" class="text-center align-middle"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% products.forEach((product) => { %>
                                            <tr>
                                                <td class="fw-bold">#<%= product.productID %></td>
                                                <td>
                                                    <div class="d-flex align-items-center">
                                                        <div class="me-3">
                                                            <img src="/images/products/<%= product.productThumbnail %>" 
                                                                 alt="<%= product.productTitle %>" 
                                                                 class="rounded" 
                                                                 style="width: 50px; height: 50px; object-fit: cover;">
                                                        </div>
                                                        <div>
                                                            <h6 class="mb-0" style="font-size: 0.9rem;">
                                                                <a href="/product/<%= product.productID %>" 
                                                                   class="text-decoration-none text-dark">
                                                                    <%= product.productTitle %>
                                                                </a>
                                                            </h6>
                                                            <small class="text-muted"><%= product.productManufacturer %></small>
                                                        </div>
                                                    </div>
                                                </td>
                                                <td class="text-center align-middle">
                                                    <% if (product.categories && product.categories.length > 0) { %>
                                                        <% product.categories.forEach((cat, index) => { %>
                                                            <% if (index < 2) { %>
                                                                <span class="cat-badge me-1 mb-1">
                                                                    <% if (cat.icon) { %>
                                                                        <img src="<%= cat.icon %>" alt="" class="cat-badge-icon">
                                                                    <% } %>
                                                                    <span class="cat-badge-text"><%= cat.name %></span>
                                                                </span>
                                                            <% } %>
                                                        <% }) %>
                                                        <% if (product.categories.length > 2) { %>
                                                            <span class="cat-badge me-1 mb-1">
                                                                <span class="cat-badge-text">+<%= product.categories.length - 2 %></span>
                                                            </span>
                                                        <% } %>
                                                    <% } else { %>
                                                        <span class="cat-badge me-1 mb-1">
                                                            <span class="cat-badge-text" style="margin-left: 8px;">Нет</span>
                                                        </span>
                                                    <% } %>
                                                </td>
                                                <td class="fw-bold text-primary text-center align-middle"><%= product.productPrice %>₽</td>
                                                <td class="text-center align-middle">
                                                    <div class="d-flex align-items-center justify-content-center">
                                                        <span class="me-1"><%= product.productRating ? product.productRating.toFixed(1) : '0.0' %></span>
                                                        <i class="fas fa-star text-warning" style="font-size: 0.8rem;"></i>
                                                    </div>
                                                </td>
                                                <td class="text-center align-middle">
                                                    <span class="badge bg-info bg-opacity-10 text-info">
                                                        <%= product.featuresCount %>
                                                    </span>
                                                </td>
                                                <td class="text-center align-middle">
                                                    <a href="/product/<%= product.productID %>" 
                                                       class="admin-action-btn admin-action-btn-eye" title="Просмотр">
                                                        <i class="fas fa-eye"></i>
                                                    </a>
                                                </td>
                                                <td class="text-center align-middle">
                                                    <a href="/admin/edit-product/<%= product.productID %>" 
                                                       class="admin-action-btn admin-action-btn-edit" title="Редактировать">
                                                        <i class="fas fa-edit"></i>
                                                    </a>
                                                </td>
                                                <td class="text-center align-middle">
                                                    <button type="button" 
                                                            class="admin-action-btn admin-action-btn-delete" 
                                                            onclick="confirmDeleteProduct(<%= product.productID %>, '<%= product.productTitle.replace(/'/g, "\\'") %>')" 
                                                            title="Удалить">
                                                        <i class="fas fa-trash"></i>
                                                    </button>
                                                </td>
                                            </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } %>

                            <!-- Пагинация товаров -->
                            <% if (pagination.totalPages > 1) { %>
                                <nav aria-label="Навигация по страницам" class="mt-3">
                                    <ul class="pagination justify-content-center">
                                        <% if (pagination.hasPrev) { %>
                                            <li class="page-item">
                                                <a class="page-link" 
                                                   href="/admin/products?page=<%= pagination.currentPage - 1 %><%= pagination.searchQuery ? '&search=' + pagination.searchQuery : '' %>">
                                                    <i class="fas fa-chevron-left"></i>
                                                </a>
                                            </li>
                                        <% } else { %>
                                            <li class="page-item disabled">
                                                <span class="page-link"><i class="fas fa-chevron-left"></i></span>
                                            </li>
                                        <% } %>
                                        
                                        <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                                            <% if (i === pagination.currentPage) { %>
                                                <li class="page-item active"><span class="page-link"><%= i %></span></li>
                                            <% } else if (i >= pagination.currentPage - 2 && i <= pagination.currentPage + 2) { %>
                                                <li class="page-item">
                                                    <a class="page-link" 
                                                       href="/admin/products?page=<%= i %><%= pagination.searchQuery ? '&search=' + pagination.searchQuery : '' %>">
                                                        <%= i %>
                                                    </a>
                                                </li>
                                            <% } %>
                                        <% } %>
                                        
                                        <% if (pagination.hasNext) { %>
                                            <li class="page-item">
                                                <a class="page-link" 
                                                   href="/admin/products?page=<%= pagination.currentPage + 1 %><%= pagination.searchQuery ? '&search=' + pagination.searchQuery : '' %>">
                                                    <i class="fas fa-chevron-right"></i>
                                                </a>
                                            </li>
                                        <% } else { %>
                                            <li class="page-item disabled">
                                                <span class="page-link"><i class="fas fa-chevron-right"></i></span>
                                            </li>
                                        <% } %>
                                    </ul>
                                </nav>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- ========== ВКЛАДКА: КАТЕГОРИИ ========== -->
                <div class="tab-pane fade" id="categories" role="tabpanel" aria-labelledby="categories-tab">
                    <div class="card border-0 shadow-sm no-hover">
                        <div class="card-header CanvaHeader py-3 d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 text-white">
                                <i class="fas fa-tags me-2"></i>Управление категориями
                            </h5>
                            <a href="/admin/categories/add" class="btn btn-light btn-sm">
                                <i class="fas fa-plus me-1"></i> Добавить категорию
                            </a>
                        </div>
                        <div class="card-body p-0">
                            <% if (categories && categories.length > 0) { %>
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 50px;">ID</th>
                                                <th>Название</th>
                                                <th>Описание</th>
                                                <th style="width: 80px;" class="text-center align-middle">Миниатюра</th>
                                                <th style="width: 50px;" class="text-center align-middle"></th>
                                                <th style="width: 50px;" class="text-center align-middle"></th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% categories.forEach(cat => { %>
                                                <tr>
                                                    <td class="fw-bold">#<%= cat.categorieID %></td>
                                                    <td class="fw-bold"><%= cat.categorieName %></td>
                                                    <td class="text-muted small"><%= cat.categorieDescription || '—' %></td>
                                                    <td class="text-center align-middle">
                                                        <% if (cat.categorieThumbnail) { %>
                                                            <div class="category-thumb-box">
                                                                <img src="/images/categories/<%= cat.categorieThumbnail %>" 
                                                                     alt="<%= cat.categorieName %>">
                                                            </div>
                                                        <% } else { %>
                                                            <div class="category-thumb-box">
                                                                <i class="fas fa-image text-muted"></i>
                                                            </div>
                                                        <% } %>
                                                    </td>
                                                    <td class="text-center align-middle">
                                                        <a href="/admin/categories/edit/<%= cat.categorieID %>" 
                                                           class="admin-action-btn admin-action-btn-edit" title="Редактировать">
                                                            <i class="fas fa-edit"></i>
                                                        </a>
                                                    </td>
                                                    <td class="text-center align-middle">
                                                        <button type="button" 
                                                                class="admin-action-btn admin-action-btn-delete" 
                                                                onclick="deleteCategory(<%= cat.categorieID %>, '<%= cat.categorieName.replace(/'/g, "\\'") %>')" 
                                                                title="Удалить">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } else { %>
                                <div class="text-center py-4">
                                    <i class="fas fa-folder-open fa-3x text-muted mb-2"></i>
                                    <p class="text-muted">Нет созданных категорий</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- ========== ВКЛАДКА: ЗАКАЗЫ ========== -->
                <div class="tab-pane fade" id="orders" role="tabpanel" aria-labelledby="orders-tab">
                    <div class="card border-0 shadow-sm no-hover">
                        <div class="card-header CanvaHeader py-3 d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 text-white">
                                <i class="fas fa-shopping-cart me-2"></i>Управление заказами
                            </h5>
                            <span class="badge bg-light text-dark"><%= orders ? orders.length : 0 %> заказов</span>
                        </div>
                        <div class="card-body p-3">
                            <!-- Фильтры заказов -->
                            <div class="row g-2 mb-3">
                                <div class="col-md-4">
                                    <select class="form-select" id="orderStatusFilter" onchange="filterOrders()">
                                        <option value="">Все статусы</option>
                                        <option value="1">Новый</option>
                                        <option value="2">В обработке</option>
                                        <option value="3">Собран</option>
                                        <option value="4">Доставляется</option>
                                        <option value="5">Доставлен</option>
                                        <option value="6">Отменён</option>
                                    </select>
                                </div>
                                <div class="col-md-4">
                                    <input type="text" class="form-control" id="orderSearchInput" 
                                           placeholder="Поиск по номеру заказа, имени или email" 
                                           onkeyup="filterOrders()">
                                </div>
                                <div class="col-md-4 text-md-end">
                                    <button class="btn btn-custom btn-sm" onclick="refreshOrders()">
                                        <i class="fas fa-sync me-1"></i>Обновить
                                    </button>
                                </div>
                            </div>

                            <!-- Таблица заказов -->
                            <% if (orders && orders.length > 0) { %>
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0" id="ordersTable">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 80px;">№ заказа</th>
                                                <th>Клиент</th>
                                                <th style="width: 140px;">Дата</th>
                                                <th style="width: 120px;" class="text-center">Сумма</th>
                                                <th style="width: 120px;" class="text-center">Статус</th>
                                                <th style="width: 120px;" class="text-center">Оплата</th>
                                                <th style="width: 100px;" class="text-center">Действия</th>
                                            </tr>
                                        </thead>
                                        <tbody id="ordersTableBody">
                                            <% orders.forEach(order => { %>
                                                <tr data-status="<%= order.orderStatusID %>" 
                                                    data-search="<%= order.orderID %> <%= order.customerName %> <%= order.customerEmail %>">
                                                    <td class="fw-bold">#<%= order.orderID %></td>
                                                    <td>
                                                        <div>
                                                            <div><strong><%= order.customerName || 'Не указан' %></strong></div>
                                                            <small class="text-muted"><%= order.customerEmail || '' %></small>
                                                        </div>
                                                    </td>
                                                    <td><%= new Date(order.orderDate).toLocaleDateString('ru-RU') %></td>
                                                    <td class="fw-bold text-center"><%= order.totalAmount %>₽</td>
                                                    <td class="text-center">
                                                        <span class="badge bg-<%= order.orderStatusID === 1 ? 'warning' : 
                                                                              order.orderStatusID === 2 ? 'info' : 
                                                                              order.orderStatusID === 3 ? 'primary' : 
                                                                              order.orderStatusID === 4 ? 'secondary' : 
                                                                              order.orderStatusID === 5 ? 'success' : 
                                                                              'danger' %>">
                                                            <%= order.statusName || 'Новый' %>
                                                        </span>
                                                    </td>
                                                    <td class="text-center">
                                                        <span class="badge bg-<%= order.paymentStatus === 'paid' ? 'success' : 'warning' %>">
                                                            <%= order.paymentStatus === 'paid' ? 'Оплачен' : 'Ожидает' %>
                                                        </span>
                                                    </td>
                                                    <td class="text-center">
                                                        <button class="admin-action-btn admin-action-btn-eye" 
                                                                onclick="viewOrder(<%= order.orderID %>)" 
                                                                title="Просмотр заказа">
                                                            <i class="fas fa-eye"></i>
                                                        </button>
                                                        <button class="admin-action-btn admin-action-btn-edit" 
                                                                onclick="updateOrderStatus(<%= order.orderID %>)" 
                                                                title="Изменить статус">
                                                            <i class="fas fa-pen"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } else { %>
                                <div class="text-center py-5">
                                    <i class="fas fa-shopping-bag fa-3x text-muted mb-3"></i>
                                    <h5 class="text-muted">Заказов пока нет</h5>
                                    <p class="text-muted">Когда пользователи оформят заказы, они появятся здесь</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- ========== ВКЛАДКА: ПОЛЬЗОВАТЕЛИ ========== -->
                <div class="tab-pane fade" id="users" role="tabpanel" aria-labelledby="users-tab">
                    <div class="card border-0 shadow-sm no-hover">
                        <div class="card-header CanvaHeader py-3 d-flex justify-content-between align-items-center">
                            <h5 class="mb-0 text-white">
                                <i class="fas fa-users me-2"></i>Управление пользователями
                            </h5>
                            <span class="badge bg-light text-dark"><%= users ? users.length : 0 %> пользователей</span>
                        </div>
                        <div class="card-body p-3">
                            <!-- Поиск пользователей -->
                            <div class="row g-2 mb-3">
                                <div class="col-md-8">
                                    <input type="text" class="form-control" id="userSearchInput" 
                                           placeholder="Поиск по имени, email или ID" 
                                           onkeyup="filterUsers()">
                                </div>
                                <div class="col-md-4 text-md-end">
                                    <select class="form-select" id="userRankFilter" onchange="filterUsers()">
                                        <option value="">Все роли</option>
                                        <option value="admin">Администраторы</option>
                                        <option value="user">Пользователи</option>
                                    </select>
                                </div>
                            </div>

                            <!-- Таблица пользователей -->
                            <% if (users && users.length > 0) { %>
                                <div class="table-responsive">
                                    <table class="table table-hover mb-0" id="usersTable">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 60px;">ID</th>
                                                <th>Пользователь</th>
                                                <th>Email</th>
                                                <th style="width: 120px;" class="text-center">Роль</th>
                                                <th style="width: 140px;" class="text-center">Дата регистрации</th>
                                                <th style="width: 80px;" class="text-center">Действия</th>
                                            </tr>
                                        </thead>
                                        <tbody id="usersTableBody">
                                            <% users.forEach(user => { %>
                                                <tr data-rank="<%= user.customerRank %>" 
                                                    data-search="<%= user.customerID %> <%= user.customerName %> <%= user.customerEmail %>">
                                                    <td class="fw-bold">#<%= user.customerID %></td>
                                                    <td>
                                                        <div class="d-flex align-items-center">
                                                            <div class="me-2">
                                                                <img src="<%= user.customerThumbnail || '/images/Avatars/default.png' %>" 
                                                                     alt="<%= user.customerName %>" 
                                                                     class="rounded-circle" 
                                                                     style="width: 40px; height: 40px; object-fit: cover;">
                                                            </div>
                                                            <div>
                                                                <div><strong><%= user.customerName %></strong></div>
                                                                <small class="text-muted">ID: <%= user.customerID %></small>
                                                            </div>
                                                        </div>
                                                    </td>
                                                    <td><%= user.customerEmail %></td>
                                                    <td class="text-center">
                                                        <span class="badge bg-<%= user.customerRank === 'admin' ? 'danger' : 'secondary' %>">
                                                            <%= user.customerRank === 'admin' ? 'Админ' : 'Пользователь' %>
                                                        </span>
                                                    </td>
                                                    <td class="text-center"><%= new Date(user.created_at).toLocaleDateString('ru-RU') %></td>
                                                    <td class="text-center">
                                                        <button class="admin-action-btn admin-action-btn-edit" 
                                                                onclick="toggleUserRank(<%= user.customerID %>, '<%= user.customerRank %>')" 
                                                                title="Изменить роль">
                                                            <i class="fas fa-user-cog"></i>
                                                        </button>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } else { %>
                                <div class="text-center py-5">
                                    <i class="fas fa-user-slash fa-3x text-muted mb-3"></i>
                                    <h5 class="text-muted">Пользователей пока нет</h5>
                                    <p class="text-muted">Зарегистрированные пользователи появятся здесь</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ========== МОДАЛЬНОЕ ОКНО ДЛЯ ЗАКАЗА ========== -->
<div class="modal fade" id="orderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header CanvaHeader">
                <h5 class="modal-title text-white"><i class="fas fa-shopping-bag me-2"></i>Детали заказа #<span id="orderModalNumber"></span></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="orderModalBody">
                <!-- Загружается динамически -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрыть</button>
            </div>
        </div>
    </div>
</div>

<script>
// ========================================
// ФУНКЦИИ ДЛЯ ТОВАРОВ
// ========================================

function confirmDeleteProduct(productID, productTitle) {
    if (confirm(`Вы уверены, что хотите удалить товар "${productTitle}"?`)) {
        fetch(`/admin/delete-product/${productID}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                showNotification('Товар успешно удален', 'success');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                showNotification(data.message || 'Ошибка при удалении', 'error');
            }
        })
        .catch(() => showNotification('Произошла ошибка', 'error'));
    }
}

// ========================================
// ФУНКЦИИ ДЛЯ КАТЕГОРИЙ
// ========================================

function deleteCategory(catID, catName) {
    if (confirm(`Вы уверены, что хотите удалить категорию "${catName}"?`)) {
        fetch(`/admin/categories/delete/${catID}`, {
            method: 'DELETE',
            headers: { 'Content-Type': 'application/json' }
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                showNotification(data.message, 'success');
                setTimeout(() => window.location.reload(), 1000);
            } else {
                showNotification(data.message || 'Ошибка', 'error');
            }
        })
        .catch(() => showNotification('Ошибка при удалении категории', 'error'));
    }
}

// ========================================
// ФУНКЦИИ ДЛЯ ЗАКАЗОВ
// ========================================

function filterOrders() {
    const statusFilter = document.getElementById('orderStatusFilter').value;
    const searchInput = document.getElementById('orderSearchInput').value.toLowerCase();
    const rows = document.querySelectorAll('#ordersTableBody tr');
    let visibleCount = 0;

    rows.forEach(row => {
        const status = row.dataset.status;
        const searchData = row.dataset.search.toLowerCase();
        let show = true;

        if (statusFilter && status !== statusFilter) show = false;
        if (searchInput && !searchData.includes(searchInput)) show = false;

        row.style.display = show ? '' : 'none';
        if (show) visibleCount++;
    });

    document.getElementById('ordersBadge').textContent = visibleCount;
}

function viewOrder(orderID) {
    fetch(`/admin/order/${orderID}`)
        .then(res => {
            if (!res.ok) throw new Error('Ошибка загрузки');
            return res.json();
        })
        .then(data => {
            document.getElementById('orderModalNumber').textContent = orderID;
            
            let itemsHtml = data.items.map(item => `
                <tr>
                    <td>${item.productTitle}</td>
                    <td class="text-center">${item.quantity}</td>
                    <td class="text-end">${item.price}₽</td>
                    <td class="text-end">${(item.price * item.quantity)}₽</td>
                </tr>
            `).join('');

            document.getElementById('orderModalBody').innerHTML = `
                <div class="row g-3">
                    <div class="col-md-6">
                        <h6><i class="fas fa-user me-2"></i>Информация о клиенте</h6>
                        <p class="mb-1"><strong>Имя:</strong> ${data.order.customerName || 'Не указан'}</p>
                        <p class="mb-1"><strong>Email:</strong> ${data.order.customerEmail || 'Не указан'}</p>
                        <p class="mb-1"><strong>Телефон:</strong> ${data.order.customerPhone || 'Не указан'}</p>
                    </div>
                    <div class="col-md-6">
                        <h6><i class="fas fa-truck me-2"></i>Доставка</h6>
                        <p class="mb-1"><strong>Тип:</strong> ${data.order.deliveryType === 'pickup' ? 'Самовывоз' : 'Доставка'}</p>
                        ${data.order.deliveryType === 'pickup' ? 
                            `<p class="mb-1"><strong>Пункт выдачи:</strong> ${data.order.pointName || 'Не указан'}</p>` : 
                            `<p class="mb-1"><strong>Адрес:</strong> ${data.order.deliveryAddress || 'Не указан'}</p>`
                        }
                        <p class="mb-1"><strong>Способ оплаты:</strong> ${data.order.paymentType === 'online' ? 'Онлайн' : 'При получении'}</p>
                        <p class="mb-1"><strong>Статус оплаты:</strong> <span class="badge bg-${data.order.paymentStatus === 'paid' ? 'success' : 'warning'}">${data.order.paymentStatus === 'paid' ? 'Оплачен' : 'Ожидает'}</span></p>
                    </div>
                </div>
                <hr>
                <h6><i class="fas fa-box me-2"></i>Товары в заказе</h6>
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr><th>Товар</th><th class="text-center">Кол-во</th><th class="text-end">Цена</th><th class="text-end">Сумма</th></tr>
                        </thead>
                        <tbody>${itemsHtml}</tbody>
                        <tfoot>
                            <tr><td colspan="3" class="text-end fw-bold">Итого:</td><td class="text-end fw-bold">${data.order.totalAmount}₽</td></tr>
                        </tfoot>
                    </table>
                </div>
                ${data.order.comment ? `<div class="alert alert-light"><strong>Комментарий:</strong> ${data.order.comment}</div>` : ''}
            `;

            new bootstrap.Modal(document.getElementById('orderModal')).show();
        })
        .catch(err => {
            showNotification('Ошибка загрузки заказа', 'error');
            console.error(err);
        });
}

function updateOrderStatus(orderID) {
    const statuses = [
        { id: 1, name: 'Новый' },
        { id: 2, name: 'В обработке' },
        { id: 3, name: 'Собран' },
        { id: 4, name: 'Доставляется' },
        { id: 5, name: 'Доставлен' },
        { id: 6, name: 'Отменён' }
    ];

    const options = statuses.map(s => `<option value="${s.id}">${s.name}</option>`).join('');
    const newStatus = prompt(`Выберите новый статус для заказа #${orderID}:\n\n1 - Новый\n2 - В обработке\n3 - Собран\n4 - Доставляется\n5 - Доставлен\n6 - Отменён`, '2');
    
    if (newStatus === null) return;
    const statusId = parseInt(newStatus);
    if (isNaN(statusId) || statusId < 1 || statusId > 6) {
        showNotification('Неверный статус', 'error');
        return;
    }

    fetch(`/admin/order/${orderID}/status`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ statusID: statusId })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            showNotification('Статус заказа обновлён', 'success');
            setTimeout(() => window.location.reload(), 1000);
        } else {
            showNotification(data.message || 'Ошибка', 'error');
        }
    })
    .catch(() => showNotification('Ошибка при обновлении статуса', 'error'));
}

function refreshOrders() {
    showNotification('Обновление заказов...', 'info');
    setTimeout(() => window.location.reload(), 500);
}

// ========================================
// ФУНКЦИИ ДЛЯ ПОЛЬЗОВАТЕЛЕЙ
// ========================================

function filterUsers() {
    const rankFilter = document.getElementById('userRankFilter').value;
    const searchInput = document.getElementById('userSearchInput').value.toLowerCase();
    const rows = document.querySelectorAll('#usersTableBody tr');

    rows.forEach(row => {
        const rank = row.dataset.rank;
        const searchData = row.dataset.search.toLowerCase();
        let show = true;

        if (rankFilter && rank !== rankFilter) show = false;
        if (searchInput && !searchData.includes(searchInput)) show = false;

        row.style.display = show ? '' : 'none';
    });
}

function toggleUserRank(userID, currentRank) {
    const newRank = currentRank === 'admin' ? 'user' : 'admin';
    const confirmMsg = currentRank === 'admin' 
        ? `Вы уверены, что хотите снять права администратора с пользователя #${userID}?` 
        : `Вы уверены, что хотите назначить пользователя #${userID} администратором?`;

    if (!confirm(confirmMsg)) return;

    fetch(`/admin/user/${userID}/rank`, {
        method: 'PUT',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ rank: newRank })
    })
    .then(res => res.json())
    .then(data => {
        if (data.success) {
            showNotification(`Роль пользователя обновлена на ${newRank === 'admin' ? 'Администратор' : 'Пользователь'}`, 'success');
            setTimeout(() => window.location.reload(), 1000);
        } else {
            showNotification(data.message || 'Ошибка', 'error');
        }
    })
    .catch(() => showNotification('Ошибка при обновлении роли', 'error'));
}

// ========================================
// УНИВЕРСАЛЬНЫЕ ФУНКЦИИ
// ========================================

function showNotification(message, type = 'info') {
    const colors = {
        success: '#28a745',
        error: '#dc3545',
        info: '#17a2b8',
        warning: '#ffc107'
    };

    const notification = document.createElement('div');
    notification.className = `alert alert-${type} alert-dismissible fade show`;
    notification.style.cssText = `
        position: fixed;
        top: 20px;
        right: 20px;
        z-index: 9999;
        min-width: 300px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        border-left: 4px solid ${colors[type] || colors.info};
    `;
    notification.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    
    document.body.appendChild(notification);
    
    setTimeout(() => {
        if (notification.parentNode) notification.remove();
    }, 3000);
}
</script>