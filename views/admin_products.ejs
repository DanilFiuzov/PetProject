<div class="container def-bg-settings py-4">
    <div class="row">
        <div class="col-12">
            <!-- Хлебные крошки -->
            <nav aria-label="breadcrumb" class="mb-4">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a href="/" class="text-decoration-none">Главная</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Управление товарами</li>
                </ol>
            </nav>
            
            <!-- Заголовок и кнопки -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="h2 mb-0">
                        <i class="fas fa-boxes text-primary me-2"></i>
                        Управление товарами
                    </h1>
                    <p class="text-muted mb-0">
                        Всего товаров: <span class="fw-bold"><%= pagination.totalProducts %></span>
                    </p>
                </div>
                <div>
                    <a href="/admin/add-product" class="btn btn-primary">
                        <i class="fas fa-plus-circle me-2"></i>Добавить товар
                    </a>
                </div>
            </div>
            
            <!-- Поиск и фильтры -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body">
                    <form method="GET" action="/admin/products" class="row g-3">
                        <div class="col-md-8">
                            <div class="input-group">
                                <span class="input-group-text">
                                    <i class="fas fa-search"></i>
                                </span>
                                <input type="text" 
                                       class="form-control" 
                                       name="search" 
                                       value="<%= pagination.searchQuery || '' %>"
                                       placeholder="Поиск по названию, производителю или описанию...">
                                <button class="btn btn-outline-primary" type="submit">Найти</button>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex justify-content-end">
                                <% if (pagination.searchQuery) { %>
                                    <a href="/admin/products" class="btn btn-outline-secondary me-2">
                                        <i class="fas fa-times me-1"></i>Сбросить
                                    </a>
                                <% } %>
                                <select class="form-select" name="limit" onchange="this.form.submit()" style="width: auto;">
                                    <option value="10" <%= pagination.limit == 10 ? 'selected' : '' %>>10 на странице</option>
                                    <option value="25" <%= pagination.limit == 25 ? 'selected' : '' %>>25 на странице</option>
                                    <option value="50" <%= pagination.limit == 50 ? 'selected' : '' %>>50 на странице</option>
                                </select>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
            
            <!-- Таблица товаров -->
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-0">
                    <% if (products.length === 0) { %>
                        <div class="text-center py-5">
                            <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
                            <h5 class="text-muted">Товары не найдены</h5>
                            <% if (pagination.searchQuery) { %>
                                <p class="text-muted">По запросу "<%= pagination.searchQuery %>" ничего не найдено</p>
                                <a href="/admin/products" class="btn btn-outline-primary">
                                    <i class="fas fa-arrow-left me-2"></i>Показать все товары
                                </a>
                            <% } else { %>
                                <p class="text-muted">В базе данных пока нет товаров</p>
                                <a href="/admin/add-product" class="btn btn-primary">
                                    <i class="fas fa-plus-circle me-2"></i>Добавить первый товар
                                </a>
                            <% } %>
                        </div>
                    <% } else { %>
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="CanvaHeader text-white">
                                    <tr>
                                        <th style="width: 60px;">ID</th>
                                        <th>Товар</th>
                                        <th>Категории</th>
                                        <th style="width: 100px;">Цена</th>
                                        <th style="width: 80px;">Рейтинг</th>
                                        <th style="width: 80px;">Хар-ки</th>
                                        <th style="width: 150px;">Действия</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% products.forEach((product) => { %>
                                    <tr>
                                        <td class="fw-bold">#<%= product.productID %></td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="me-3">
                                                    <img src="/images/products/<%= product.productThumbnail %>" 
                                                         alt="<%= product.productTitle %>" 
                                                         class="rounded" 
                                                         style="width: 50px; height: 50px; object-fit: cover;">
                                                </div>
                                                <div>
                                                    <h6 class="mb-0" style="font-size: 0.9rem;">
                                                        <a href="/product/<%= product.productID %>" 
                                                           class="text-decoration-none text-dark">
                                                            <%= product.productTitle %>
                                                        </a>
                                                    </h6>
                                                    <small class="text-muted"><%= product.productManufacturer %></small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <% if (product.categories && product.categories.length > 0) { %>
                                                <% product.categories.forEach((cat, index) => { %>
                                                    <% if (index < 2) { %>
                                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 me-1 mb-1"
                                                              style="font-size: 0.7rem; padding: 0.2rem 0.4rem;">
                                                            <%= cat %>
                                                        </span>
                                                    <% } %>
                                                <% }) %>
                                                <% if (product.categories.length > 2) { %>
                                                    <span class="badge bg-light text-muted" style="font-size: 0.7rem;">
                                                        +<%= product.categories.length - 2 %>
                                                    </span>
                                                <% } %>
                                            <% } else { %>
                                                <span class="text-muted small">Нет категорий</span>
                                            <% } %>
                                        </td>
                                        <td class="fw-bold text-primary"><%= product.productPrice %>₽</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <span class="me-1"><%= product.productRating ? product.productRating.toFixed(1) : '0.0' %></span>
                                                <i class="fas fa-star text-warning" style="font-size: 0.8rem;"></i>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-info bg-opacity-10 text-info">
                                                <%= product.featuresCount %>
                                            </span>
                                        </td>
                                        <td>
                                            <div class="btn-group btn-group-sm" role="group">
                                                <a href="/product/<%= product.productID %>" 
                                                   class="btn btn-outline-primary" 
                                                   title="Просмотр">
                                                    <i class="fas fa-eye"></i>
                                                </a>
                                                <a href="/admin/edit-product/<%= product.productID %>" 
                                                   class="btn btn-outline-warning" 
                                                   title="Редактировать">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                                <button type="button" 
                                                        class="btn btn-outline-danger" 
                                                        onclick="confirmDelete(<%= product.productID %>, '<%= product.productTitle.replace(/'/g, "\\'") %>')"
                                                        title="Удалить">
                                                    <i class="fas fa-trash"></i>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } %>
                </div>
            </div>
            
            <!-- Пагинация -->
            <% if (pagination.totalPages > 1) { %>
                <nav aria-label="Навигация по страницам">
                    <ul class="pagination justify-content-center">
                        <% if (pagination.hasPrev) { %>
                            <li class="page-item">
                                <a class="page-link" 
                                   href="/admin/products?page=<%= pagination.currentPage - 1 %><%= pagination.searchQuery ? '&search=' + pagination.searchQuery : '' %>">
                                    <i class="fas fa-chevron-left"></i>
                                </a>
                            </li>
                        <% } else { %>
                            <li class="page-item disabled">
                                <span class="page-link"><i class="fas fa-chevron-left"></i></span>
                            </li>
                        <% } %>
                        
                        <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                            <% if (i === pagination.currentPage) { %>
                                <li class="page-item active">
                                    <span class="page-link"><%= i %></span>
                                </li>
                            <% } else if (i >= pagination.currentPage - 2 && i <= pagination.currentPage + 2) { %>
                                <li class="page-item">
                                    <a class="page-link" 
                                       href="/admin/products?page=<%= i %><%= pagination.searchQuery ? '&search=' + pagination.searchQuery : '' %>">
                                        <%= i %>
                                    </a>
                                </li>
                            <% } %>
                        <% } %>
                        
                        <% if (pagination.hasNext) { %>
                            <li class="page-item">
                                <a class="page-link" 
                                   href="/admin/products?page=<%= pagination.currentPage + 1 %><%= pagination.searchQuery ? '&search=' + pagination.searchQuery : '' %>">
                                    <i class="fas fa-chevron-right"></i>
                                </a>
                            </li>
                        <% } else { %>
                            <li class="page-item disabled">
                                <span class="page-link"><i class="fas fa-chevron-right"></i></span>
                            </li>
                        <% } %>
                    </ul>
                </nav>
            <% } %>
        </div>
    </div>
</div>

<script>
// Функция подтверждения удаления
function confirmDelete(productID, productTitle) {
    if (confirm(`Вы уверены, что хотите удалить товар "${productTitle}"?\n\nЭто действие нельзя отменить. Все данные о товаре будут удалены.`)) {
        deleteProduct(productID);
    }
}

// Функция удаления товара
function deleteProduct(productID) {
    fetch(`/admin/delete-product/${productID}`, {
        method: 'DELETE',
        headers: {
            'Content-Type': 'application/json'
        }
    })
    .then(response => response.json())
    .then(data => {
        if (data.success) {
            showNotification('Товар успешно удален', 'success');
            // Обновляем страницу через 1 секунду
            setTimeout(() => {
                window.location.reload();
            }, 1000);
        } else {
            showNotification(data.message || 'Ошибка при удалении товара', 'error');
        }
    })
    .catch(error => {
        console.error('Error:', error);
        showNotification('Произошла ошибка при удалении товара', 'error');
    });
}

// Всплывающее уведомление
function showNotification(message, type) {
    const notification = document.createElement('div');
    notification.className = `alert alert-${type} alert-dismissible fade show`;
    notification.style.position = 'fixed';
    notification.style.top = '20px';
    notification.style.right = '20px';
    notification.style.zIndex = '9999';
    notification.style.minWidth = '300px';
    notification.innerHTML = `
        ${message}
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    `;
    
    document.body.appendChild(notification);
    
    // Автоматическое скрытие через 3 секунды
    setTimeout(() => {
        if (notification.parentNode) {
            notification.remove();
        }
    }, 3000);
}
</script>